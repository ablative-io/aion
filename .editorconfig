# Editor defaults for the aion repo, matching the enforced formatters:
# rustfmt (4-space Rust), biome (2-space TS/JS/JSON, apps/aion-ops-console/biome.json),
# gleam format (2-space), and the AWL lexer — which requires two-space
# indentation and rejects tab characters outright.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.rs]
indent_size = 4

# AWL indentation is two spaces per level; tabs are a lex error
# ("tabs are not allowed in indentation").
[*.awl]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
