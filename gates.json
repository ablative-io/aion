{
  "repo": "aion",
  "legs": [
    {"name": "fmt", "cmd": "cargo fmt --all --check", "kind": "check"},
    {"name": "clippy", "cmd": "cargo clippy --workspace --all-targets -- -D warnings", "kind": "check"},
    {"name": "tests-rs", "cmd": "cargo test -p aion-rs", "kind": "cargo-test"},
    {"name": "tests-awl", "cmd": "cargo test -p aion-awl", "kind": "cargo-test"},
    {"name": "tests-pkg", "cmd": "cargo test -p aion-awl-package -p aion-package", "kind": "cargo-test"},
    {"name": "tests-core", "cmd": "cargo test -p aion-core", "kind": "cargo-test"}
  ]
}
