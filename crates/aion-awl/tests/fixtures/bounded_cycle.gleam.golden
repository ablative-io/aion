//// Fix until accepted.

import aion/activity
import aion/codec.{type Codec}
import aion/duration
import aion/error
import aion/signal
import aion/workflow
import gleam/dynamic.{type Dynamic}
import gleam/dynamic/decode
import gleam/json
import gleam/list
import gleam/option.{type Option, None, Some}

pub type AwlError {
  AwlDecodeInputFailed(String)
  AwlActivityFailed(String)
  AwlSignalFailed(String)
  AwlChildFailed(String)
  AwlTimerFailed(String)
  AwlTimedOut(String)
  AwlFailed
}

pub type BoundedCycleInput {
  BoundedCycleInput(
    state: ReviewState,
  )
}

pub type ReviewState {
  ReviewState(
    accepted: Bool,
    notes: String,
  )
}

pub type Failed {
  Failed(
    reason: String,
  )
}

/// Typed definition binding the codecs to the execute function.
pub fn definition() -> workflow.WorkflowDefinition(BoundedCycleInput, ReviewState, AwlError) {
  workflow.define(
    "bounded_cycle",
    bounded_cycle_input_codec(),
    review_state_codec(),
    awl_error_codec(),
    execute,
  )
}

/// Engine entry point.
pub fn run(raw_input: Dynamic) -> Result(String, AwlError) {
  case decode.run(raw_input, decode.string) {
    Ok(raw_json) ->
      case bounded_cycle_input_codec().decode(raw_json) {
        Ok(input) ->
          case execute(input) {
            Ok(result) -> Ok(review_state_codec().encode(result))
            Error(workflow_error) -> Error(workflow_error)
          }
        Error(codec.DecodeError(reason: reason, path: _)) ->
          Error(AwlDecodeInputFailed("failed to decode workflow input: " <> reason))
      }
    Error(_) -> Error(AwlDecodeInputFailed("workflow input payload was not a string"))
  }
}

/// Workflow body generated from the AWL steps.
pub fn execute(input: BoundedCycleInput) -> Result(ReviewState, AwlError) {
  let state = input.state

  let assert Ok(state) =
    seed_activity() |> workflow.run |> map_activity_error

  let assert Ok(state) =
    fix_loop(3, state)

  Ok(state)
}

/// Bounded `repeat` loop for step `fix`: runs the step body up to the
/// cap, threading the `as` binding through iterations and exiting early
/// when the `until` condition holds.
fn fix_loop(remaining, state) {
  case remaining <= 0 {
    True -> Ok(state)
    False -> {
      let attempt =
        awl_retry(2, 5000, 2, 60000, fn() { workflow.spawn_and_wait("fix_round", fn(_: json.Json) { Error(AwlChildFailed("child workflow body runs in its own execution")) }, json.object([#("state", review_state_to_json(state))]), json_value_codec(), review_state_codec(), awl_error_codec()) |> map_child_error })
      case attempt {
        Ok(state) ->
          case state.accepted {
            True -> Ok(state)
            False -> fix_loop(remaining - 1, state)
          }
        Error(awl_error) -> Error(awl_error)
      }
    }
  }
}

pub type SeedInput {
  SeedInput
}

fn seed_activity() -> activity.Activity(SeedInput, ReviewState) {
  activity.new(
    "seed",
    SeedInput,
    seed_input_codec(),
    review_state_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
  )
}

pub type FixRoundInput {
  FixRoundInput(
    state: ReviewState,
  )
}

fn fix_round_activity(
  state: ReviewState,
) -> activity.Activity(FixRoundInput, ReviewState) {
  activity.new(
    "fix_round",
    FixRoundInput(
      state: state,
    ),
    fix_round_input_codec(),
    review_state_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
  )
}

fn awl_error_codec() -> Codec(AwlError) {
  codec.json_codec(awl_error_to_json, awl_error_decoder())
}

fn awl_error_to_json(error_value: AwlError) -> json.Json {
  case error_value {
    AwlDecodeInputFailed(message) -> json.object([#("tag", json.string("AwlDecodeInputFailed")), #("message", json.string(message))])
    AwlActivityFailed(message) -> json.object([#("tag", json.string("AwlActivityFailed")), #("message", json.string(message))])
    AwlSignalFailed(message) -> json.object([#("tag", json.string("AwlSignalFailed")), #("message", json.string(message))])
    AwlChildFailed(message) -> json.object([#("tag", json.string("AwlChildFailed")), #("message", json.string(message))])
    AwlTimerFailed(message) -> json.object([#("tag", json.string("AwlTimerFailed")), #("message", json.string(message))])
    AwlTimedOut(message) -> json.object([#("tag", json.string("AwlTimedOut")), #("message", json.string(message))])
    AwlFailed -> json.object([#("tag", json.string("AwlFailed"))])
  }
}

fn awl_error_decoder() -> decode.Decoder(AwlError) {
  use tag <- decode.field("tag", decode.string)
  case tag {
    "AwlDecodeInputFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(AwlDecodeInputFailed(message))
    }
    "AwlActivityFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(AwlActivityFailed(message))
    }
    "AwlSignalFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(AwlSignalFailed(message))
    }
    "AwlChildFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(AwlChildFailed(message))
    }
    "AwlTimerFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(AwlTimerFailed(message))
    }
    "AwlTimedOut" -> {
      use message <- decode.field("message", decode.string)
      decode.success(AwlTimedOut(message))
    }
    "AwlFailed" -> decode.success(AwlFailed)
    _ -> decode.failure(AwlFailed, "AwlError")
  }
}

fn bounded_cycle_input_codec() -> Codec(BoundedCycleInput) {
  codec.json_codec(bounded_cycle_input_to_json, bounded_cycle_input_decoder())
}

fn bounded_cycle_input_to_json(bounded_cycle_input: BoundedCycleInput) -> json.Json {
  json.object([
    #("state", review_state_to_json(bounded_cycle_input.state)),
  ])
}

fn bounded_cycle_input_decoder() -> decode.Decoder(BoundedCycleInput) {
  use state <- decode.field("state", review_state_decoder())
  decode.success(BoundedCycleInput(
    state: state,
  ))
}

fn review_state_codec() -> Codec(ReviewState) {
  codec.json_codec(review_state_to_json, review_state_decoder())
}

fn review_state_to_json(review_state: ReviewState) -> json.Json {
  json.object([
    #("accepted", bool_to_json(review_state.accepted)),
    #("notes", string_to_json(review_state.notes)),
  ])
}

fn review_state_decoder() -> decode.Decoder(ReviewState) {
  use accepted <- decode.field("accepted", bool_decoder())
  use notes <- decode.field("notes", string_decoder())
  decode.success(ReviewState(
    accepted: accepted,
    notes: notes,
  ))
}

fn failed_codec() -> Codec(Failed) {
  codec.json_codec(failed_to_json, failed_decoder())
}

fn failed_to_json(failed: Failed) -> json.Json {
  json.object([
    #("reason", string_to_json(failed.reason)),
  ])
}

fn failed_decoder() -> decode.Decoder(Failed) {
  use reason <- decode.field("reason", string_decoder())
  decode.success(Failed(
    reason: reason,
  ))
}

fn seed_input_codec() -> Codec(SeedInput) {
  codec.json_codec(seed_input_to_json, seed_input_decoder())
}

fn seed_input_to_json(_: SeedInput) -> json.Json {
  json.object([
  ])
}

fn seed_input_decoder() -> decode.Decoder(SeedInput) {
  decode.success(SeedInput)
}

fn fix_round_input_codec() -> Codec(FixRoundInput) {
  codec.json_codec(fix_round_input_to_json, fix_round_input_decoder())
}

fn fix_round_input_to_json(fix_round_input: FixRoundInput) -> json.Json {
  json.object([
    #("state", review_state_to_json(fix_round_input.state)),
  ])
}

fn fix_round_input_decoder() -> decode.Decoder(FixRoundInput) {
  use state <- decode.field("state", review_state_decoder())
  decode.success(FixRoundInput(
    state: state,
  ))
}

fn string_codec() -> Codec(String) { codec.json_codec(json.string, decode.string) }
fn int_codec() -> Codec(Int) { codec.json_codec(json.int, decode.int) }
fn float_codec() -> Codec(Float) { codec.json_codec(json.float, decode.float) }
fn bool_codec() -> Codec(Bool) { codec.json_codec(json.bool, decode.bool) }
fn nil_codec() -> Codec(Nil) { codec.json_codec(fn(_) { json.object([]) }, decode.success(Nil)) }

fn string_to_json(value: String) -> json.Json { json.string(value) }
fn int_to_json(value: Int) -> json.Json { json.int(value) }
fn float_to_json(value: Float) -> json.Json { json.float(value) }
fn bool_to_json(value: Bool) -> json.Json { json.bool(value) }
fn nil_to_json(_: Nil) -> json.Json { json.object([]) }

fn string_decoder() -> decode.Decoder(String) { decode.string }
fn int_decoder() -> decode.Decoder(Int) { decode.int }
fn float_decoder() -> decode.Decoder(Float) { decode.float }
fn bool_decoder() -> decode.Decoder(Bool) { decode.bool }
fn nil_decoder() -> decode.Decoder(Nil) { decode.success(Nil) }

fn list_to_json(values: List(a), item_to_json: fn(a) -> json.Json) -> json.Json { json.array(values, item_to_json) }
fn list_decoder(item_decoder: decode.Decoder(a)) -> decode.Decoder(List(a)) { decode.list(item_decoder) }
fn option_to_json(value: Option(a), item_to_json: fn(a) -> json.Json) -> json.Json { json.nullable(value, item_to_json) }
fn option_decoder(item_decoder: decode.Decoder(a)) -> decode.Decoder(Option(a)) { decode.optional(item_decoder) }

fn try(result: Result(a, AwlError), next: fn(a) -> Result(b, AwlError)) -> Result(b, AwlError) {
  case result { Ok(value) -> next(value) Error(awl_error) -> Error(awl_error) }
}

fn map_activity_error(result: Result(a, error.ActivityError)) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(AwlActivityFailed("activity failed")) }
}

fn map_receive_error(result: Result(a, error.ReceiveError)) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(AwlSignalFailed("signal receive failed")) }
}

fn map_child_error(result: Result(a, error.ChildError(AwlError))) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(AwlChildFailed("child workflow failed")) }
}

fn map_timer_error(result: Result(a, error.EngineError)) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(AwlTimerFailed("timer failed")) }
}

/// Encode-only codec for child workflow inputs: the parent assembles the
/// child's input record as JSON and never decodes it back.
fn json_value_codec() -> Codec(json.Json) {
  codec.Codec(
    encode: json.to_string,
    decode: fn(_) {
      Error(codec.DecodeError(reason: "child call input is encode-only", path: []))
    },
  )
}

/// Bounded retry with backoff for child workflow calls: `attempts` total
/// attempts with an SDK timer sleep between them (fixed when `multiplier`
/// is 1, exponential capped at `max_delay_ms` otherwise).
fn awl_retry(
  attempts: Int,
  delay_ms: Int,
  multiplier: Int,
  max_delay_ms: Int,
  operation: fn() -> Result(value, AwlError),
) -> Result(value, AwlError) {
  case operation() {
    Ok(value) -> Ok(value)
    Error(awl_error) ->
      case attempts <= 1 {
        True -> Error(awl_error)
        False ->
          case workflow.sleep(duration.milliseconds(delay_ms)) {
            Ok(_) -> {
              let next_delay_ms = delay_ms * multiplier
              let capped_delay_ms = case next_delay_ms > max_delay_ms {
                True -> max_delay_ms
                False -> next_delay_ms
              }
              awl_retry(attempts - 1, capped_delay_ms, multiplier, max_delay_ms, operation)
            }
            Error(_) -> Error(AwlTimerFailed("timer failed while backing off"))
          }
      }
  }
}

