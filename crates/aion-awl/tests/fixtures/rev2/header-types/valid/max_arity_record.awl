//! A record at high field arity — a wide tuple through the codec and onto the wire.
workflow max_arity_record
  input seed: String
  outcome built: type Wide, route success

type Wide {
  f01: String,
  f02: String,
  f03: String,
  f04: String,
  f05: String,
  f06: String,
  f07: String,
  f08: String,
  f09: String,
  f10: String,
  f11: String,
  f12: String,
  f13: String,
  f14: String,
  f15: String,
  f16: String,
  f17: String,
  f18: String,
  f19: String,
  f20: String,
}

step build
  route built(f01: seed, f02: seed, f03: seed, f04: seed, f05: seed, f06: seed, f07: seed, f08: seed, f09: seed, f10: seed, f11: seed, f12: seed, f13: seed, f14: seed, f15: seed, f16: seed, f17: seed, f18: seed, f19: seed, f20: seed)
