{
  "type": "object",
  "required": ["title", "attachments"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "attachments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contact": {
      "type": "string",
      "format": "email",
      "description": "Present only when the submitter wants a reply."
    },
    "category": {
      "type": "string",
      "enum": ["bug", "feature", "question"]
    }
  }
}
