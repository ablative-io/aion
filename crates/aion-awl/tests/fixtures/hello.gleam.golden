//// Say hello with a guarded enrichment step.

import aion/activity
import aion/codec.{type Codec}
import aion/duration
import aion/error
import aion/signal
import aion/workflow
import gleam/dynamic.{type Dynamic}
import gleam/dynamic/decode
import gleam/json
import gleam/list
import gleam/option.{type Option, None, Some}

pub type AwlError {
  DecodeInputFailed(String)
  ActivityFailed(String)
  SignalFailed(String)
  ChildFailed(String)
  TimerFailed(String)
  TimedOut(String)
  Failed
}

pub type HelloInput {
  HelloInput(
    name: String,
  )
}

pub type Greeting {
  Greeting(
    message: String,
    excited: Bool,
  )
}

/// Typed definition binding the codecs to the execute function.
pub fn definition() -> workflow.WorkflowDefinition(HelloInput, Greeting, AwlError) {
  workflow.define(
    "hello",
    hello_input_codec(),
    greeting_codec(),
    awl_error_codec(),
    execute,
  )
}

/// Engine entry point.
pub fn run(raw_input: Dynamic) -> Result(String, AwlError) {
  case decode.run(raw_input, decode.string) {
    Ok(raw_json) ->
      case hello_input_codec().decode(raw_json) {
        Ok(input) ->
          case execute(input) {
            Ok(result) -> Ok(greeting_codec().encode(result))
            Error(workflow_error) -> Error(workflow_error)
          }
        Error(codec.DecodeError(reason: reason, path: _)) ->
          Error(DecodeInputFailed("failed to decode workflow input: " <> reason))
      }
    Error(_) -> Error(DecodeInputFailed("workflow input payload was not a string"))
  }
}

/// Workflow body generated from the AWL steps.
pub fn execute(input: HelloInput) -> Result(Greeting, AwlError) {
  let name = input.name

  let assert Ok(greeting) =
    greet_activity(name) |> workflow.run |> map_activity_error

  let greeting = case greeting.excited == False {
    True -> {
      let assert Ok(greeting) =
        exclaim_activity(greeting) |> workflow.run |> map_activity_error
      greeting
    }
    False -> greeting
  }

  Ok(greeting)
}

pub type GreetInput {
  GreetInput(
    name: String,
  )
}

fn greet_activity(
  name: String,
) -> activity.Activity(GreetInput, Greeting) {
  activity.new(
    "greet",
    GreetInput(
      name: name,
    ),
    greet_input_codec(),
    greeting_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
  )
}

pub type ExclaimInput {
  ExclaimInput(
    greeting: Greeting,
  )
}

fn exclaim_activity(
  greeting: Greeting,
) -> activity.Activity(ExclaimInput, Greeting) {
  activity.new(
    "exclaim",
    ExclaimInput(
      greeting: greeting,
    ),
    exclaim_input_codec(),
    greeting_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
  )
}

fn awl_error_codec() -> Codec(AwlError) {
  codec.json_codec(awl_error_to_json, awl_error_decoder())
}

fn awl_error_to_json(error_value: AwlError) -> json.Json {
  case error_value {
    DecodeInputFailed(message) -> json.object([#("tag", json.string("DecodeInputFailed")), #("message", json.string(message))])
    ActivityFailed(message) -> json.object([#("tag", json.string("ActivityFailed")), #("message", json.string(message))])
    SignalFailed(message) -> json.object([#("tag", json.string("SignalFailed")), #("message", json.string(message))])
    ChildFailed(message) -> json.object([#("tag", json.string("ChildFailed")), #("message", json.string(message))])
    TimerFailed(message) -> json.object([#("tag", json.string("TimerFailed")), #("message", json.string(message))])
    TimedOut(message) -> json.object([#("tag", json.string("TimedOut")), #("message", json.string(message))])
    Failed -> json.object([#("tag", json.string("Failed"))])
  }
}

fn awl_error_decoder() -> decode.Decoder(AwlError) {
  use tag <- decode.field("tag", decode.string)
  case tag {
    "DecodeInputFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(DecodeInputFailed(message))
    }
    "ActivityFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(ActivityFailed(message))
    }
    "SignalFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(SignalFailed(message))
    }
    "ChildFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(ChildFailed(message))
    }
    "TimerFailed" -> {
      use message <- decode.field("message", decode.string)
      decode.success(TimerFailed(message))
    }
    "TimedOut" -> {
      use message <- decode.field("message", decode.string)
      decode.success(TimedOut(message))
    }
    "Failed" -> decode.success(Failed)
    _ -> decode.failure(Failed, "AwlError")
  }
}

fn hello_input_codec() -> Codec(HelloInput) {
  codec.json_codec(hello_input_to_json, hello_input_decoder())
}

fn hello_input_to_json(hello_input: HelloInput) -> json.Json {
  json.object([
    #("name", string_to_json(hello_input.name)),
  ])
}

fn hello_input_decoder() -> decode.Decoder(HelloInput) {
  use name <- decode.field("name", string_decoder())
  decode.success(HelloInput(
    name: name,
  ))
}

fn greeting_codec() -> Codec(Greeting) {
  codec.json_codec(greeting_to_json, greeting_decoder())
}

fn greeting_to_json(greeting: Greeting) -> json.Json {
  json.object([
    #("message", string_to_json(greeting.message)),
    #("excited", bool_to_json(greeting.excited)),
  ])
}

fn greeting_decoder() -> decode.Decoder(Greeting) {
  use message <- decode.field("message", string_decoder())
  use excited <- decode.field("excited", bool_decoder())
  decode.success(Greeting(
    message: message,
    excited: excited,
  ))
}

fn greet_input_codec() -> Codec(GreetInput) {
  codec.json_codec(greet_input_to_json, greet_input_decoder())
}

fn greet_input_to_json(greet_input: GreetInput) -> json.Json {
  json.object([
    #("name", string_to_json(greet_input.name)),
  ])
}

fn greet_input_decoder() -> decode.Decoder(GreetInput) {
  use name <- decode.field("name", string_decoder())
  decode.success(GreetInput(
    name: name,
  ))
}

fn exclaim_input_codec() -> Codec(ExclaimInput) {
  codec.json_codec(exclaim_input_to_json, exclaim_input_decoder())
}

fn exclaim_input_to_json(exclaim_input: ExclaimInput) -> json.Json {
  json.object([
    #("greeting", greeting_to_json(exclaim_input.greeting)),
  ])
}

fn exclaim_input_decoder() -> decode.Decoder(ExclaimInput) {
  use greeting <- decode.field("greeting", greeting_decoder())
  decode.success(ExclaimInput(
    greeting: greeting,
  ))
}

fn string_codec() -> Codec(String) { codec.json_codec(json.string, decode.string) }
fn int_codec() -> Codec(Int) { codec.json_codec(json.int, decode.int) }
fn float_codec() -> Codec(Float) { codec.json_codec(json.float, decode.float) }
fn bool_codec() -> Codec(Bool) { codec.json_codec(json.bool, decode.bool) }
fn nil_codec() -> Codec(Nil) { codec.json_codec(fn(_) { json.object([]) }, decode.success(Nil)) }

fn string_to_json(value: String) -> json.Json { json.string(value) }
fn int_to_json(value: Int) -> json.Json { json.int(value) }
fn float_to_json(value: Float) -> json.Json { json.float(value) }
fn bool_to_json(value: Bool) -> json.Json { json.bool(value) }
fn nil_to_json(_: Nil) -> json.Json { json.object([]) }

fn string_decoder() -> decode.Decoder(String) { decode.string }
fn int_decoder() -> decode.Decoder(Int) { decode.int }
fn float_decoder() -> decode.Decoder(Float) { decode.float }
fn bool_decoder() -> decode.Decoder(Bool) { decode.bool }
fn nil_decoder() -> decode.Decoder(Nil) { decode.success(Nil) }

fn list_to_json(values: List(a), item_to_json: fn(a) -> json.Json) -> json.Json { json.array(values, item_to_json) }
fn list_decoder(item_decoder: decode.Decoder(a)) -> decode.Decoder(List(a)) { decode.list(item_decoder) }
fn option_to_json(value: Option(a), item_to_json: fn(a) -> json.Json) -> json.Json { json.nullable(value, item_to_json) }
fn option_decoder(item_decoder: decode.Decoder(a)) -> decode.Decoder(Option(a)) { decode.optional(item_decoder) }

fn try(result: Result(a, AwlError), next: fn(a) -> Result(b, AwlError)) -> Result(b, AwlError) {
  case result { Ok(value) -> next(value) Error(awl_error) -> Error(awl_error) }
}

fn map_activity_error(result: Result(a, error.ActivityError)) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(ActivityFailed("activity failed")) }
}

fn map_receive_error(result: Result(a, error.ReceiveError)) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(SignalFailed("signal receive failed")) }
}

fn map_child_error(result: Result(a, error.ChildError(AwlError))) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(ChildFailed("child workflow failed")) }
}

fn map_timer_error(result: Result(a, error.EngineError)) -> Result(a, AwlError) {
  case result { Ok(value) -> Ok(value) Error(_) -> Error(TimerFailed("timer failed")) }
}

