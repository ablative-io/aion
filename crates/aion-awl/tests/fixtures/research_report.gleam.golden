//// Research a brief, gate it through a durable human review, publish.

import aion/activity
import aion/codec.{type Codec}
import aion/duration
import aion/error
import aion/signal
import aion/workflow
import gleam/dynamic.{type Dynamic}
import gleam/dynamic/decode
import gleam/json
import gleam/list
import gleam/option.{type Option, None, Some}

pub type AwlError {
  AwlDecodeInputFailed(String)
  AwlActivityFailed(String)
  AwlSignalFailed(String)
  AwlChildFailed(String)
  AwlTimerFailed(String)
  AwlTimedOut(String)
  AwlFailed
}

pub type Dir {
  Dir(value: String)
}

pub type ResearchReportInput {
  ResearchReportInput(
    brief: Brief,
    corpus: Dir,
  )
}

pub type Brief {
  Brief(
    topic: String,
    audience: String,
    depth: Int,
  )
}

pub type Question {
  Question(
    text: String,
    angle: String,
  )
}

pub type Finding {
  Finding(
    question: String,
    summary: String,
    sources: List(String),
  )
}

pub type Report {
  Report(
    title: String,
    body: String,
    findings: List(Finding),
  )
}

pub type Approval {
  Approval(
    ok: Bool,
    notes: String,
  )
}

pub type Published {
  Published(
    report: Report,
    url: String,
  )
}

/// Typed definition binding the codecs to the execute function.
pub fn definition() -> workflow.WorkflowDefinition(ResearchReportInput, Published, AwlError) {
  workflow.define(
    "research_report",
    research_report_input_codec(),
    published_codec(),
    awl_error_codec(),
    execute,
  )
}

/// Engine entry point.
pub fn run(raw_input: Dynamic) -> Result(String, AwlError) {
  case decode.run(raw_input, decode.string) {
    Ok(raw_json) ->
      case research_report_input_codec().decode(raw_json) {
        Ok(input) ->
          case execute(input) {
            Ok(result) -> Ok(published_codec().encode(result))
            Error(workflow_error) -> Error(workflow_error)
          }
        Error(codec.DecodeError(reason: reason, path: _)) ->
          Error(AwlDecodeInputFailed("failed to decode workflow input: " <> reason))
      }
    Error(_) -> Error(AwlDecodeInputFailed("workflow input payload was not a string"))
  }
}

/// Workflow body generated from the AWL steps.
pub fn execute(input: ResearchReportInput) -> Result(Published, AwlError) {
  let brief = input.brief
  let corpus = input.corpus

  // Break the brief into distinct research questions.
  let assert Ok(questions) =
    plan_activity(brief) |> workflow.run |> map_activity_error

  // One agent per question, parallel across workers, exactly-once on failover.
  let assert Ok(findings) =
    workflow.map(questions, fn(q) {
      investigate_activity(q, corpus) |> activity.retry(activity.RetryPolicy(max_attempts: 3, backoff: activity.Fixed(duration.milliseconds(30000))))
    }) |> map_activity_error

  let assert Ok(draft) =
    synthesize_activity(findings, "") |> workflow.run |> map_activity_error

  // Durable gate — parks free while idle, survives restarts, resumable weeks later.
  case workflow.with_timeout(fn() { workflow.receive(review_signal()) |> map_receive_error }, duration.milliseconds(259200000)) {
    Ok(approval) -> {
      // One revision pass if the reviewer pushed back.
      let draft = case !approval.ok {
        True -> {
          let assert Ok(draft) =
            synthesize_activity(findings, approval.notes) |> workflow.run |> map_activity_error
          draft
        }
        False -> draft
      }

      let assert Ok(assets) =
        upload_assets_activity(draft) |> workflow.run |> map_activity_error

      let assert Ok(url) =
        case publish_activity(draft, assets) |> workflow.run |> map_activity_error {
          Ok(value) -> Ok(value)
          Error(_) -> {
            let assert Ok(_) = delete_assets_activity(assets) |> workflow.run |> map_activity_error
            Error(AwlFailed)
          }
        }

      Ok(Published(report: draft, url: url))
    }
    Error(error.TimedOutError(_)) -> Ok(Published(report: draft, url: ""))
    Error(error.InnerError(inner)) -> Error(inner)
    Error(error.TimeoutEngineFailure(message)) -> Error(AwlTimerFailed(message))
  }
}

pub type PlanInput {
  PlanInput(
    brief: Brief,
  )
}

fn plan_activity(
  brief: Brief,
) -> activity.Activity(PlanInput, List(Question)) {
  activity.new(
    "plan",
    PlanInput(
      brief: brief,
    ),
    plan_input_codec(),
    list_question_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
  )
}

pub type InvestigateInput {
  InvestigateInput(
    q: Question,
    corpus: Dir,
  )
}

fn investigate_activity(
  q: Question,
  corpus: Dir,
) -> activity.Activity(InvestigateInput, Finding) {
  activity.new(
    "investigate",
    InvestigateInput(
      q: q,
      corpus: corpus,
    ),
    investigate_input_codec(),
    finding_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
  )
}

pub type SynthesizeInput {
  SynthesizeInput(
    findings: List(Finding),
    notes: String,
  )
}

fn synthesize_activity(
  findings: List(Finding),
  notes: String,
) -> activity.Activity(SynthesizeInput, Report) {
  activity.new(
    "synthesize",
    SynthesizeInput(
      findings: findings,
      notes: notes,
    ),
    synthesize_input_codec(),
    report_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
  )
}

pub type UploadAssetsInput {
  UploadAssetsInput(
    report: Report,
  )
}

fn upload_assets_activity(
  report: Report,
) -> activity.Activity(UploadAssetsInput, List(String)) {
  activity.new(
    "upload_assets",
    UploadAssetsInput(
      report: report,
    ),
    upload_assets_input_codec(),
    list_string_codec(),
    fn(_) { Error(error.terminal("activity body is provided by a worker")) },
