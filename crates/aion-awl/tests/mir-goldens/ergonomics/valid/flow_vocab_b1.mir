  v5 = field(v0, 2)
  v6 = call_local verdict_to_json$field1(v5) live_after=[v4]
  v7 = list([v4, v6])
  v8 = call_rt gleam@list:flatten/1(v7)
  tail_rt gleam@json:object/1(v8)
