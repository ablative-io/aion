module flow_vocab_b1 source=flow_vocab_b1.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_run:
    aion@activity:task_queue/2 [activities] (v2, lit#16)
    aion@workflow:run/1 [activities] (v3)
    aion@activity:task_queue/2 [activities] (v7, lit#19)
    aion@workflow:run/1 [activities] (v8)
    aion@activity:task_queue/2 [activities] (v15, lit#22)
    aion@workflow:run/1 [activities] (v16)
