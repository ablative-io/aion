== atoms ==
  [0] verdict
  [1] run_agent_input
  [2] stamp_input
  [3] flow_vocab_b1_input
  [4] done_outcome
  [5] some
  [6] none
  [7] ok
== literals ==
  [0] "passed"
  [1] "note"
  [2] "passed"
  [3] "note"
  [4] "prompt"
  [5] "output_schema"
  [6] "text"
  [7] "task"
  [8] "done"
  [9] "outcome"
  [10] ""
  [11] "FlowVocabB1Outcome"
  [12] "done"
  [13] "payload"
  [14] "\n  Hello from the flow vocabulary.\n   Task follows: "
  [15] "{\"description\":\"One verdict, minted by the checking agent.\",\"properties\":{\"note\":{\"type\":\"string\"},\"passed\":{\"description\":\"Whether the run passed.\",\"type\":\"boolean\"}},\"required\":[\"passed\"],\"type\":\"object\"}"
  [16] "vocab"
  [17] "\n  Hello from the flow vocabulary.\n  "
  [18] "{\n  \"type\": \"object\",\n  \"properties\": { \"id\": { \"type\": \"string\", \"description\": \"git-ref-safe slug\" } },\n  \"required\": [\"id\"],\n  \"additionalProperties\": false\n}"
  [19] "vocab"
  [20] "run: "
  [21] " extra: "
  [22] "vocab"
== types ==
  record Verdict tag=verdict
    passed: bool
    note: nullable(string) optional
  record RunAgentInput tag=run_agent_input
    prompt: string
    output_schema: string
  record StampInput tag=stamp_input
    text: string
  record FlowVocabB1Input tag=flow_vocab_b1_input
    task: string
  union FlowVocabB1Outcome
    done -> done_outcome(string)
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=flow_vocab_b1_input_codec output=flow_vocab_b1_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(flow_vocab_b1.FlowVocabB1Input, flow_vocab_b1.FlowVocabB1Outcome, AwlError)
  T-DEF name="flow_vocab_b1" input=flow_vocab_b1_input_codec output=flow_vocab_b1_outcome_codec
== fn execute/1 origin=execute ==
  sig: (flow_vocab_b1.FlowVocabB1Input) -> Result(flow_vocab_b1.FlowVocabB1Outcome, AwlError)
  T-EXEC fields=[task:String] entry=step_run args=[0]
