== fn step_run/1 origin=region(run) ==
  sig: (String) -> Result(flow_vocab_b1.FlowVocabB1Outcome, AwlError)
  v1 = concat lit#14 v0
  v2 = call_local run_agent_activity(v1, lit#15)
  v3 = call_rt aion@activity:task_queue/2(v2, lit#16)
  v4 = call_rt aion@workflow:run/1(v3)
  v5 = call_rt aion@awl@error:map_activity_error/1(v4)
  v6 = try_bind v5
  v7 = call_local run_agent_activity(lit#17, lit#18) live_after=[v6]
  v8 = call_rt aion@activity:task_queue/2(v7, lit#19) live_after=[v6]
  v9 = call_rt aion@workflow:run/1(v8) live_after=[v6]
  v10 = call_rt aion@awl@error:map_activity_error/1(v9) live_after=[v6]
  v11 = try_bind v10 live_after=[v6]
  v14 = concat lit#20 v6
  v13 = concat v14 lit#21
  v12 = concat v13 v11
  v15 = call_local stamp_activity(v12)
  v16 = call_rt aion@activity:task_queue/2(v15, lit#22)
  v17 = call_rt aion@workflow:run/1(v16)
  v18 = call_rt aion@awl@error:map_activity_error/1(v17)
  v19 = try_bind v18
  v20 = record(done_outcome, [v19])
  v21 = record(ok, [v20])
  return v21
