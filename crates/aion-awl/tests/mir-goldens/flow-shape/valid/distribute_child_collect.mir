module fan_children source=fan_children.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  awl_r0_wave_step_delegate:
    aion@workflow:spawn_and_wait/6 [children] (lit#13, v2, v1, v3, v4, v5)
  wave_fanout_0:
    aion@workflow:spawn/6 [children] (lit#12, v3, v2, v4, v5, v6)
  wave_fanout_1:
    aion@child:await/1 [children] (v1)
== durable families == children
== atoms ==
  [0] job
  [1] verdict
  [2] done
  [3] fan_children_input
  [4] done_outcome
  [5] ok
== literals ==
  [0] "name"
  [1] "ok"
  [2] "count"
  [3] "jobs"
  [4] "done"
  [5] "outcome"
  [6] "FanChildrenOutcome"
  [7] "done"
  [8] "payload"
  [9] "child"
  [10] "outcome"
  [11] "payload"
  [12] "run_job"
  [13] "run_job"
== types ==
  record Job tag=job
    name: string
  record Verdict tag=verdict
    ok: bool
  record Done tag=done
    count: int
  record FanChildrenInput tag=fan_children_input
    jobs: list(ref(Job))
  union FanChildrenOutcome
    done -> done_outcome(ref(Done))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fan_children_input_codec output=fan_children_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(fan_children.FanChildrenInput, fan_children.FanChildrenOutcome, AwlError)
  T-DEF name="fan_children" input=fan_children_input_codec output=fan_children_outcome_codec
== fn execute/1 origin=execute ==
  sig: (fan_children.FanChildrenInput) -> Result(fan_children.FanChildrenOutcome, AwlError)
  T-EXEC fields=[jobs:List(fan_children.Job)] entry=step_wave args=[0]
