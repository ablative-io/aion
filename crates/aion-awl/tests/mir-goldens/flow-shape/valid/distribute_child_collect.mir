== fn step_wave/1 origin=region(wave) ==
  sig: (List(fan_children.Job)) -> Result(fan_children.FanChildrenOutcome, AwlError)
  v1 = make_closure wave_fanout_0 captures=[]
  v2 = call_rt gleam@list:try_fold/3(v0, nil, v1)
  v3 = try_bind v2
  v4 = call_rt gleam@list:reverse/1(v3)
  v5 = make_closure wave_fanout_1 captures=[]
  v6 = call_rt gleam@list:try_fold/3(v4, nil, v5)
  v7 = try_bind v6
  v8 = call_rt gleam@list:reverse/1(v7)
  v9 = call_rt gleam@list:length/1(v8)
  v10 = record(done, [v9])
  v11 = record(done_outcome, [v10])
  v12 = record(ok, [v11])
  return v12
== fn awl_r0_wave/1 origin=region_wrapper(r0:wave) ==
  sig: (fan_children.Job) -> Result(fan_children.Verdict, AwlError)
  tail_local awl_r0_wave_step_delegate(v0)
== fn awl_r0_wave_step_delegate/1 origin=region(r0:wave::delegate) ==
  sig: (fan_children.Job) -> Result(fan_children.Verdict, AwlError)
  v1 = json_obj {"job": v0|>job_to_json}
  v2 = make_closure awl$child_witness captures=[]
  v3 = call_rt aion@awl@codec:json_value/0() live_after=[v1, v2]
  v4 = call_local awl_child_output_verdict_codec() live_after=[v1, v2, v3]
  v5 = call_rt aion@awl@error:codec/0() live_after=[v1, v2, v3, v4]
  v6 = call_rt aion@workflow:spawn_and_wait/6(lit#13, v2, v1, v3, v4, v5)
  v7 = call_rt aion@awl@error:map_child_error/1(v6)
  v8 = try_bind v7
  v9 = record(ok, [v8])
  return v9
== fn wave_fanout_0/2 origin=fork(wave#0) ==
  sig: (List(ChildHandle(fan_children.Verdict, AwlError)), fan_children.Job) -> Result(List(ChildHandle(fan_children.Verdict, AwlError)), AwlError)
  v2 = json_obj {"job": v1|>job_to_json}
  v3 = make_closure awl$child_witness captures=[]
  v4 = call_rt aion@awl@codec:json_value/0() live_after=[v0, v2, v3]
  v5 = call_local awl_child_output_verdict_codec() live_after=[v0, v2, v3, v4]
  v6 = call_rt aion@awl@error:codec/0() live_after=[v0, v2, v3, v4, v5]
  v7 = call_rt aion@workflow:spawn/6(lit#12, v3, v2, v4, v5, v6) live_after=[v0]
  v8 = call_rt aion@awl@error:map_spawn_error/1(v7) live_after=[v0]
  v9 = try_bind v8 live_after=[v0]
  v10 = cons v9 v0
  v11 = record(ok, [v10])
  return v11
== fn wave_fanout_1/2 origin=fork(wave#1) ==
  sig: (List(fan_children.Verdict), ChildHandle(fan_children.Verdict, AwlError)) -> Result(List(fan_children.Verdict), AwlError)
  v2 = call_rt aion@child:await/1(v1) live_after=[v0]
  v3 = call_rt aion@awl@error:map_child_error/1(v2) live_after=[v0]
  v4 = try_bind v3 live_after=[v0]
  v5 = cons v4 v0
  v6 = record(ok, [v5])
  return v6
