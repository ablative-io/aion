module rollout source=rollout.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  awl_r0_ordered_step_push:
    aion@activity:task_queue/2 [activities] (v2, lit#16)
    aion@workflow:run/1 [activities] (v3)
  awl_r0_ordered_step_confirm:
    aion@activity:task_queue/2 [activities] (v6, lit#18)
    aion@workflow:run/1 [activities] (v7)
== durable families == activities
== atoms ==
  [0] host
  [1] attempt
  [2] report
  [3] trouble
  [4] deploy_input
  [5] verify_input
  [6] rollout_input
  [7] done_outcome
  [8] ok
  [9] awl_outcome_failure
  [10] error
  [11] awl_visits_exceeded
== literals ==
  [0] "name"
  [1] "canary"
  [2] "host"
  [3] "ok"
  [4] "rolled"
  [5] "reason"
  [6] "host"
  [7] "attempt"
  [8] "hosts"
  [9] "done"
  [10] "outcome"
  [11] "RolloutOutcome"
  [12] "done"
  [13] "payload"
  [14] "a host failed verification"
  [15] "failed"
  [16] "ops"
  [17] "step `confirm` exceeded its `max … visits` bound at line 28, column 3"
  [18] "ops"
== types ==
  record Host tag=host
    name: string
    canary: bool
  record Attempt tag=attempt
    host: string
    ok: bool
  record Report tag=report
    rolled: int
  record Trouble tag=trouble
    reason: string
  record DeployInput tag=deploy_input
    host: ref(Host)
  record VerifyInput tag=verify_input
    attempt: ref(Attempt)
  record RolloutInput tag=rollout_input
    hosts: list(ref(Host))
  union RolloutOutcome
    done -> done_outcome(ref(Report))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=rollout_input_codec output=rollout_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(rollout.RolloutInput, rollout.RolloutOutcome, AwlError)
  T-DEF name="rollout" input=rollout_input_codec output=rollout_outcome_codec
== fn execute/1 origin=execute ==
  sig: (rollout.RolloutInput) -> Result(rollout.RolloutOutcome, AwlError)
  T-EXEC fields=[hosts:List(rollout.Host)] entry=step_ordered args=[0]
== fn host_codec/0 origin=codec_template(RecordTrio, Host, record#0) ==
  sig: () -> Codec(rollout.Host)
  v0 = make_closure host_to_json captures=[]
  v1 = call_local host_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn host_to_json/1 origin=codec_template(RecordTrio, Host, record#0) ==
  sig: (rollout.Host) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"name": v1|>awlc.string_to_json, "canary": v2|>awlc.bool_to_json}
  return v3
== fn host_decoder/0 origin=codec_template(RecordTrio, Host, record#0) ==
  sig: () -> Decoder(rollout.Host)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure host_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn host_decoder$0/1 origin=lifted(host_decoder, #0) ==
  sig: (String) -> Decoder(rollout.Host)
  v1 = call_rt aion@awl@codec:bool_decoder/0() live_after=[v0]
  v2 = make_closure host_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn host_decoder$1/2 origin=lifted(host_decoder, #1) ==
  sig: (Bool, String) -> Decoder(rollout.Host)
  v2 = record(host, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
