== fn rollout_outcome_decoder/0 origin=codec_template(UnionTrio, RolloutOutcome, union#7) ==
  sig: () -> Decoder(rollout.RolloutOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure rollout_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#10, v0, v1)
== fn rollout_outcome_decoder$outcome/1 origin=lifted(rollout_outcome_decoder, #0) ==
  sig: (String) -> Decoder(rollout.RolloutOutcome)
  if cmp Eq v0 lit#12:
    v3 = call_local report_decoder()
    v4 = make_closure rollout_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#13, v3, v4)
  else:
    v1 = record(report, [0])
    v2 = record(done_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#11)
== fn rollout_outcome_decoder$arm0/1 origin=lifted(rollout_outcome_decoder, #1) ==
  sig: (rollout.Report) -> Decoder(rollout.RolloutOutcome)
  v1 = record(done_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
