== fn deploy_activity/1 origin=activity_wrapper(deploy, raw=false) ==
  sig: (rollout.Host) -> Activity(rollout.DeployInput, rollout.Attempt)
  T-ACT action=deploy input_codec=deploy_input_codec return=attempt_codec
== fn verify_activity/1 origin=activity_wrapper(verify, raw=false) ==
  sig: (rollout.Attempt) -> Activity(rollout.VerifyInput, rollout.Attempt)
  T-ACT action=verify input_codec=verify_input_codec return=attempt_codec
== fn step_ordered/1 origin=region(ordered) ==
  sig: (List(rollout.Host)) -> Result(rollout.RolloutOutcome, AwlError)
  v1 = make_closure ordered_fanout_0 captures=[]
  v2 = call_rt gleam@list:try_fold/3(v0, nil, v1)
  v3 = try_bind v2
  v4 = call_rt gleam@list:reverse/1(v3)
  v5 = call_rt gleam@list:length/1(v4) live_after=[v4]
  tail_local step_judge(v4, v5)
== fn step_judge/2 origin=chain_step(ordered.judge) ==
  sig: (List(rollout.Attempt), Int) -> Result(rollout.RolloutOutcome, AwlError)
  v2 = make_closure awl_predicate_0 captures=[]
  v3 = call_rt gleam@list:all/2(v0, v2) live_after=[v1]
  if is_true v3:
    v4 = record(report, [v1])
    v5 = record(done_outcome, [v4])
    v6 = record(ok, [v5])
    return v6
  else:
    v7 = record(trouble, [lit#14])
    v8 = call_local trouble_to_json(v7)
    v9 = call_rt gleam@json:to_string/1(v8)
    v10 = record(awl_outcome_failure, [lit#15, v9])
    v11 = record(error, [v10])
    return v11
== fn awl_r0_ordered/1 origin=region_wrapper(r0:ordered) ==
  sig: (rollout.Host) -> Result(rollout.Attempt, AwlError)
  tail_local awl_r0_ordered_step_push(0, v0)
== fn awl_r0_ordered_step_push/2 origin=region(r0:ordered::push) ==
  sig: (Int, rollout.Host) -> Result(rollout.Attempt, AwlError)
  v2 = call_local deploy_activity(v1) live_after=[v0, v1]
  v3 = call_rt aion@activity:task_queue/2(v2, lit#16) live_after=[v0, v1]
  v4 = call_rt aion@workflow:run/1(v3) live_after=[v0, v1]
  v5 = call_rt aion@awl@error:map_activity_error/1(v4) live_after=[v0, v1]
  v6 = try_bind v5 live_after=[v0, v1]
  tail_local awl_r0_ordered_step_confirm(v6, v0, v1)
== fn awl_r0_ordered_step_confirm/3 origin=chain_step(r0:ordered::push.confirm) ==
  sig: (rollout.Attempt, Int, rollout.Host) -> Result(rollout.Attempt, AwlError)
  v3 = increment v1
  if cmp Gt v3 3:
    v4 = record(awl_visits_exceeded, [lit#17])
    v5 = record(error, [v4])
    return v5
  else:
    v6 = call_local verify_activity(v0) live_after=[v2, v3]
    v7 = call_rt aion@activity:task_queue/2(v6, lit#18) live_after=[v2, v3]
    v8 = call_rt aion@workflow:run/1(v7) live_after=[v2, v3]
    v9 = call_rt aion@awl@error:map_activity_error/1(v8) live_after=[v2, v3]
    v10 = try_bind v9 live_after=[v2, v3]
    v11 = field(v10, 2)
    if is_true v11:
      v12 = record(ok, [v10])
      return v12
    else:
      v13 = cmp Lt v3 3
      if is_true v13:
        tail_local awl_r0_ordered_step_push(v3, v2)
      else:
        v14 = record(ok, [v10])
        return v14
== fn ordered_fanout_0/2 origin=fork(ordered#0) ==
  sig: (List(rollout.Attempt), rollout.Host) -> Result(List(rollout.Attempt), AwlError)
  v2 = call_local awl_r0_ordered(v1) live_after=[v0]
  v3 = try_bind v2 live_after=[v0]
  v4 = cons v3 v0
  v5 = record(ok, [v4])
  return v5
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
== fn awl_predicate_0/1 origin=lifted(execute, #0) ==
  sig: (rollout.Attempt) -> Bool
  v1 = field(v0, 2)
  return v1
