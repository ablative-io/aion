  sig: () -> Decoder(fan_scores.Score)
  v0 = call_rt aion@awl@codec:int_decoder/0()
  v1 = make_closure score_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v0, v1)
== fn score_decoder$0/1 origin=lifted(score_decoder, #0) ==
  sig: (Int) -> Decoder(fan_scores.Score)
  v1 = record(score, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn done_codec/0 origin=codec_template(RecordTrio, Done, record#2) ==
  sig: () -> Codec(fan_scores.Done)
  v0 = make_closure done_to_json captures=[]
  v1 = call_local done_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn done_to_json/1 origin=codec_template(RecordTrio, Done, record#2) ==
  sig: (fan_scores.Done) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"total": v1|>awlc.int_to_json}
  return v2
== fn done_decoder/0 origin=codec_template(RecordTrio, Done, record#2) ==
  sig: () -> Decoder(fan_scores.Done)
  v0 = call_rt aion@awl@codec:int_decoder/0()
  v1 = make_closure done_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v0, v1)
== fn done_decoder$0/1 origin=lifted(done_decoder, #0) ==
  sig: (Int) -> Decoder(fan_scores.Done)
  v1 = record(done, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn score_input_codec/0 origin=codec_template(RecordTrio, ScoreInput, record#3) ==
  sig: () -> Codec(fan_scores.ScoreInput)
  v0 = make_closure score_input_to_json captures=[]
  v1 = call_local score_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn score_input_to_json/1 origin=codec_template(RecordTrio, ScoreInput, record#3) ==
  sig: (fan_scores.ScoreInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"doc": v1|>doc_to_json}
  return v2
