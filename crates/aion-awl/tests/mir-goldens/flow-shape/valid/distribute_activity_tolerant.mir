  sig: () -> Decoder(fan_scores.ScoreInput)
  v0 = call_local doc_decoder()
  v1 = make_closure score_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#3, v0, v1)
== fn score_input_decoder$0/1 origin=lifted(score_input_decoder, #0) ==
  sig: (fan_scores.Doc) -> Decoder(fan_scores.ScoreInput)
  v1 = record(score_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn fan_scores_input_codec/0 origin=codec_template(RecordTrio, FanScoresInput, record#4) ==
  sig: () -> Codec(fan_scores.FanScoresInput)
  v0 = make_closure fan_scores_input_to_json captures=[]
  v1 = call_local fan_scores_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
