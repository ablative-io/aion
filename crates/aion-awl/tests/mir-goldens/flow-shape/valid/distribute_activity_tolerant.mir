module fan_scores source=fan_scores.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_wave:
    aion@workflow:map_settled/2 [activities] (v0, v1)
  awl_r0_wave_step_mark:
    aion@activity:task_queue/2 [activities] (v1, lit#11)
    aion@workflow:run/1 [activities] (v2)
  wave_fanout_0:
    aion@activity:task_queue/2 [activities] (v1, lit#10)
== durable families == activities
== atoms ==
  [0] doc
  [1] score
  [2] done
  [3] score_input
  [4] fan_scores_input
  [5] done_outcome
  [6] ok
  [7] some
  [8] none
== literals ==
  [0] "title"
  [1] "points"
  [2] "total"
  [3] "doc"
  [4] "docs"
  [5] "done"
  [6] "outcome"
  [7] "FanScoresOutcome"
  [8] "done"
  [9] "payload"
  [10] "judge"
  [11] "judge"
== types ==
  record Doc tag=doc
    title: string
  record Score tag=score
    points: int
  record Done tag=done
    total: int
  record ScoreInput tag=score_input
    doc: ref(Doc)
  record FanScoresInput tag=fan_scores_input
    docs: list(ref(Doc))
  union FanScoresOutcome
    done -> done_outcome(ref(Done))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fan_scores_input_codec output=fan_scores_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(fan_scores.FanScoresInput, fan_scores.FanScoresOutcome, AwlError)
  T-DEF name="fan_scores" input=fan_scores_input_codec output=fan_scores_outcome_codec
== fn execute/1 origin=execute ==
  sig: (fan_scores.FanScoresInput) -> Result(fan_scores.FanScoresOutcome, AwlError)
  T-EXEC fields=[docs:List(fan_scores.Doc)] entry=step_wave args=[0]
== fn doc_codec/0 origin=codec_template(RecordTrio, Doc, record#0) ==
  sig: () -> Codec(fan_scores.Doc)
  v0 = make_closure doc_to_json captures=[]
  v1 = call_local doc_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn doc_to_json/1 origin=codec_template(RecordTrio, Doc, record#0) ==
  sig: (fan_scores.Doc) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"title": v1|>awlc.string_to_json}
  return v2
== fn doc_decoder/0 origin=codec_template(RecordTrio, Doc, record#0) ==
  sig: () -> Decoder(fan_scores.Doc)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure doc_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn doc_decoder$0/1 origin=lifted(doc_decoder, #0) ==
  sig: (String) -> Decoder(fan_scores.Doc)
  v1 = record(doc, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn score_codec/0 origin=codec_template(RecordTrio, Score, record#1) ==
  sig: () -> Codec(fan_scores.Score)
  v0 = make_closure score_to_json captures=[]
  v1 = call_local score_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn score_to_json/1 origin=codec_template(RecordTrio, Score, record#1) ==
  sig: (fan_scores.Score) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"points": v1|>awlc.int_to_json}
  return v2
