  sig: (List(fan_scores.Doc)) -> Json
  v1 = make_closure doc_to_json captures=[]
  tail_rt gleam@json:array/2(v0, v1)
== fn list_doc_decoder/0 origin=codec_template(CompositeTrio, List(Doc), composite(list(ref(Doc)))) ==
  sig: () -> Decoder(List(fan_scores.Doc))
  v0 = call_local doc_decoder()
  tail_rt gleam@dynamic@decode:list/1(v0)
== fn score_activity/1 origin=activity_wrapper(score, raw=false) ==
  sig: (fan_scores.Doc) -> Activity(fan_scores.ScoreInput, fan_scores.Score)
  T-ACT action=score input_codec=score_input_codec return=score_codec
== fn step_wave/1 origin=region(wave) ==
  sig: (List(fan_scores.Doc)) -> Result(fan_scores.FanScoresOutcome, AwlError)
  v1 = make_closure wave_fanout_0 captures=[]
  v2 = call_rt aion@workflow:map_settled/2(v0, v1)
  v3 = make_closure wave_fanout_1 captures=[]
  v4 = call_rt gleam@list:map/2(v2, v3)
  v5 = call_rt gleam@list:length/1(v4)
  v6 = record(done, [v5])
  v7 = record(done_outcome, [v6])
  v8 = record(ok, [v7])
  return v8
== fn awl_r0_wave/1 origin=region_wrapper(r0:wave) ==
  sig: (fan_scores.Doc) -> Result(fan_scores.Score, AwlError)
  tail_local awl_r0_wave_step_mark(v0)
== fn awl_r0_wave_step_mark/1 origin=region(r0:wave::mark) ==
  sig: (fan_scores.Doc) -> Result(fan_scores.Score, AwlError)
  v1 = call_local score_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#11)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(ok, [v5])
  return v6
== fn wave_fanout_0/1 origin=fork(wave#0) ==
  sig: (fan_scores.Doc) -> Activity(fan_scores.ScoreInput, fan_scores.Score)
  v1 = call_local score_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#10)
  return v2
== fn wave_fanout_1/1 origin=fork(wave#1) ==
  sig: (Result(fan_scores.Score, AwlError)) -> Option(fan_scores.Score)
  if is_tagged v0 ok/2:
    v1 = field(v0, 1)
    v2 = record(some, [v1])
    return v2
  else:
    return 'none'
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
