  sig: () -> Decoder(fan_scores.FanScoresInput)
  v0 = call_local list_doc_decoder()
  v1 = make_closure fan_scores_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#4, v0, v1)
== fn fan_scores_input_decoder$0/1 origin=lifted(fan_scores_input_decoder, #0) ==
  sig: (List(fan_scores.Doc)) -> Decoder(fan_scores.FanScoresInput)
  v1 = record(fan_scores_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn fan_scores_outcome_codec/0 origin=codec_template(UnionTrio, FanScoresOutcome, union#5) ==
  sig: () -> Codec(fan_scores.FanScoresOutcome)
  v0 = make_closure fan_scores_outcome_to_json captures=[]
  v1 = call_local fan_scores_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn fan_scores_outcome_to_json/1 origin=codec_template(UnionTrio, FanScoresOutcome, union#5) ==
  sig: (fan_scores.FanScoresOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#5|>awlc.string_to_json, "payload": v1|>done_to_json}
  return v2
== fn fan_scores_outcome_decoder/0 origin=codec_template(UnionTrio, FanScoresOutcome, union#5) ==
  sig: () -> Decoder(fan_scores.FanScoresOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure fan_scores_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#6, v0, v1)
== fn fan_scores_outcome_decoder$outcome/1 origin=lifted(fan_scores_outcome_decoder, #0) ==
  sig: (String) -> Decoder(fan_scores.FanScoresOutcome)
  if cmp Eq v0 lit#8:
    v3 = call_local done_decoder()
    v4 = make_closure fan_scores_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#9, v3, v4)
  else:
    v1 = record(done, [0])
    v2 = record(done_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#7)
== fn fan_scores_outcome_decoder$arm0/1 origin=lifted(fan_scores_outcome_decoder, #1) ==
  sig: (fan_scores.Done) -> Decoder(fan_scores.FanScoresOutcome)
  v1 = record(done_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
