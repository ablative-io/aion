module ordered_tolerant source=ordered_tolerant.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  awl_r0_ordered_step_push:
    aion@activity:task_queue/2 [activities] (v1, lit#11)
    aion@workflow:run/1 [activities] (v2)
  ordered_fanout_0:
    aion@activity:task_queue/2 [activities] (v2, lit#10)
    aion@workflow:run/1 [activities] (v3)
== durable families == activities
== atoms ==
  [0] host
  [1] attempt
  [2] report
  [3] deploy_input
  [4] ordered_tolerant_input
  [5] done_outcome
  [6] ok
  [7] some
  [8] none
== literals ==
  [0] "name"
  [1] "ok"
  [2] "tried"
  [3] "host"
  [4] "hosts"
  [5] "done"
  [6] "outcome"
  [7] "OrderedTolerantOutcome"
  [8] "done"
  [9] "payload"
  [10] "ops"
  [11] "ops"
== types ==
  record Host tag=host
    name: string
  record Attempt tag=attempt
    ok: bool
  record Report tag=report
    tried: int
  record DeployInput tag=deploy_input
    host: ref(Host)
  record OrderedTolerantInput tag=ordered_tolerant_input
    hosts: list(ref(Host))
  union OrderedTolerantOutcome
    done -> done_outcome(ref(Report))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=ordered_tolerant_input_codec output=ordered_tolerant_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(ordered_tolerant.OrderedTolerantInput, ordered_tolerant.OrderedTolerantOutcome, AwlError)
  T-DEF name="ordered_tolerant" input=ordered_tolerant_input_codec output=ordered_tolerant_outcome_codec
== fn execute/1 origin=execute ==
  sig: (ordered_tolerant.OrderedTolerantInput) -> Result(ordered_tolerant.OrderedTolerantOutcome, AwlError)
  T-EXEC fields=[hosts:List(ordered_tolerant.Host)] entry=step_ordered args=[0]
