== fn deploy_activity/1 origin=activity_wrapper(deploy, raw=false) ==
  sig: (ordered_tolerant.Host) -> Activity(ordered_tolerant.DeployInput, ordered_tolerant.Attempt)
  T-ACT action=deploy input_codec=deploy_input_codec return=attempt_codec
== fn step_ordered/1 origin=region(ordered) ==
  sig: (List(ordered_tolerant.Host)) -> Result(ordered_tolerant.OrderedTolerantOutcome, AwlError)
  v1 = make_closure ordered_fanout_0 captures=[]
  v2 = call_rt gleam@list:fold/3(v0, nil, v1)
  v3 = call_rt gleam@list:reverse/1(v2)
  v4 = call_rt gleam@list:length/1(v3)
  v5 = record(report, [v4])
  v6 = record(done_outcome, [v5])
  v7 = record(ok, [v6])
  return v7
== fn awl_r0_ordered/1 origin=region_wrapper(r0:ordered) ==
  sig: (ordered_tolerant.Host) -> Result(ordered_tolerant.Attempt, AwlError)
  tail_local awl_r0_ordered_step_push(v0)
== fn awl_r0_ordered_step_push/1 origin=region(r0:ordered::push) ==
  sig: (ordered_tolerant.Host) -> Result(ordered_tolerant.Attempt, AwlError)
  v1 = call_local deploy_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#11)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(ok, [v5])
  return v6
== fn ordered_fanout_0/2 origin=fork(ordered#0) ==
  sig: (List(Option(ordered_tolerant.Attempt)), ordered_tolerant.Host) -> List(Option(ordered_tolerant.Attempt))
  v2 = call_local deploy_activity(v1) live_after=[v0]
  v3 = call_rt aion@activity:task_queue/2(v2, lit#10) live_after=[v0]
  v4 = call_rt aion@workflow:run/1(v3) live_after=[v0]
  if is_tagged v4 ok/2:
    v5 = field(v4, 1)
    v6 = record(some, [v5])
    v7 = cons v6 v0
    return v7
  else:
    v8 = cons 'none' v0
    return v8
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
