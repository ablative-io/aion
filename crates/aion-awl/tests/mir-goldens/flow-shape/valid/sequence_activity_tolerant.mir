  sig: () -> Decoder(ordered_tolerant.OrderedTolerantOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure ordered_tolerant_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#6, v0, v1)
== fn ordered_tolerant_outcome_decoder$outcome/1 origin=lifted(ordered_tolerant_outcome_decoder, #0) ==
  sig: (String) -> Decoder(ordered_tolerant.OrderedTolerantOutcome)
  if cmp Eq v0 lit#8:
    v3 = call_local report_decoder()
    v4 = make_closure ordered_tolerant_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#9, v3, v4)
  else:
    v1 = record(report, [0])
    v2 = record(done_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#7)
