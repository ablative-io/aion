  tail_rt gleam@dynamic@decode:field/3(lit#1, v0, v1)
== fn shouted_decoder$0/1 origin=lifted(shouted_decoder, #0) ==
  sig: (String) -> Decoder(awl_hello.Shouted)
  v1 = record(shouted, [v0])
