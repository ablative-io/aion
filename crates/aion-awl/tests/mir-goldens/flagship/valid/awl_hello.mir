module awl_hello source=awl_hello.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_greet_and_shout:
    aion@activity:task_queue/2 [activities] (v1, lit#0)
    aion@workflow:run/1 [activities] (v2)
    aion@activity:task_queue/2 [activities] (v7, lit#1)
    aion@workflow:run/1 [activities] (v8)
== durable families == activities
== atoms ==
  [0] greeting
  [1] shouted
  [2] greet_input
  [3] shout_input
  [4] awl_hello_input
  [5] shouted_outcome
  [6] ok
== types ==
  record Greeting tag=greeting
    greeting: string
  record Shouted tag=shouted
    text: string
  record GreetInput tag=greet_input
    name: string
  record ShoutInput tag=shout_input
    text: string
  record AwlHelloInput tag=awl_hello_input
    name: string
  union AwlHelloOutcome
    shouted -> shouted_outcome(ref(Shouted))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=awl_hello_input_codec output=awl_hello_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(awl_hello.AwlHelloInput, awl_hello.AwlHelloOutcome, AwlError)
  T-DEF name="awl_hello" input=awl_hello_input_codec output=awl_hello_outcome_codec
== fn execute/1 origin=execute ==
  sig: (awl_hello.AwlHelloInput) -> Result(awl_hello.AwlHelloOutcome, AwlError)
  T-EXEC fields=[name:String] entry=step_greet_and_shout args=[0]
== fn greeting_codec/0 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: () -> Codec(awl_hello.Greeting)
  v0 = make_closure greeting_to_json captures=[]
  v1 = call_local greeting_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn greeting_to_json/1 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: (awl_hello.Greeting) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"greeting": v1|>awlc.string_to_json}
  return v2
== fn greeting_decoder/0 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: () -> Decoder(awl_hello.Greeting)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn shouted_codec/0 origin=codec_template(RecordTrio, Shouted, record#1) ==
  sig: () -> Codec(awl_hello.Shouted)
  v0 = make_closure shouted_to_json captures=[]
  v1 = call_local shouted_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn shouted_to_json/1 origin=codec_template(RecordTrio, Shouted, record#1) ==
  sig: (awl_hello.Shouted) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"text": v1|>awlc.string_to_json}
  return v2
== fn shouted_decoder/0 origin=codec_template(RecordTrio, Shouted, record#1) ==
  sig: () -> Decoder(awl_hello.Shouted)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn greet_input_codec/0 origin=codec_template(RecordTrio, GreetInput, record#2) ==
  sig: () -> Codec(awl_hello.GreetInput)
  v0 = make_closure greet_input_to_json captures=[]
  v1 = call_local greet_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn greet_input_to_json/1 origin=codec_template(RecordTrio, GreetInput, record#2) ==
  sig: (awl_hello.GreetInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"name": v1|>awlc.string_to_json}
  return v2
== fn greet_input_decoder/0 origin=codec_template(RecordTrio, GreetInput, record#2) ==
  sig: () -> Decoder(awl_hello.GreetInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn shout_input_codec/0 origin=codec_template(RecordTrio, ShoutInput, record#3) ==
  sig: () -> Codec(awl_hello.ShoutInput)
  v0 = make_closure shout_input_to_json captures=[]
  v1 = call_local shout_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn shout_input_to_json/1 origin=codec_template(RecordTrio, ShoutInput, record#3) ==
  sig: (awl_hello.ShoutInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"text": v1|>awlc.string_to_json}
  return v2
== fn shout_input_decoder/0 origin=codec_template(RecordTrio, ShoutInput, record#3) ==
  sig: () -> Decoder(awl_hello.ShoutInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn awl_hello_input_codec/0 origin=codec_template(RecordTrio, AwlHelloInput, record#4) ==
  sig: () -> Codec(awl_hello.AwlHelloInput)
  v0 = make_closure awl_hello_input_to_json captures=[]
  v1 = call_local awl_hello_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn awl_hello_input_to_json/1 origin=codec_template(RecordTrio, AwlHelloInput, record#4) ==
  sig: (awl_hello.AwlHelloInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"name": v1|>awlc.string_to_json}
  return v2
== fn awl_hello_input_decoder/0 origin=codec_template(RecordTrio, AwlHelloInput, record#4) ==
  sig: () -> Decoder(awl_hello.AwlHelloInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn awl_hello_outcome_codec/0 origin=codec_template(UnionTrio, AwlHelloOutcome, union#5) ==
  sig: () -> Codec(awl_hello.AwlHelloOutcome)
  v0 = make_closure awl_hello_outcome_to_json captures=[]
  v1 = call_local awl_hello_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn awl_hello_outcome_to_json/1 origin=codec_template(UnionTrio, AwlHelloOutcome, union#5) ==
  sig: (awl_hello.AwlHelloOutcome) -> Json
  v1 = json_obj {}
  return v1
== fn awl_hello_outcome_decoder/0 origin=codec_template(UnionTrio, AwlHelloOutcome, union#5) ==
  sig: () -> Decoder(awl_hello.AwlHelloOutcome)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn greet_activity/1 origin=activity_wrapper(greet, raw=false) ==
  sig: (String) -> Activity(awl_hello.GreetInput, awl_hello.Greeting)
  T-ACT action=greet input_codec=greet_input_codec return=greeting_codec
== fn shout_activity/1 origin=activity_wrapper(shout, raw=false) ==
  sig: (String) -> Activity(awl_hello.ShoutInput, awl_hello.Shouted)
  T-ACT action=shout input_codec=shout_input_codec return=shouted_codec
== fn step_greet_and_shout/1 origin=region(greet_and_shout) ==
  sig: (String) -> Result(awl_hello.AwlHelloOutcome, AwlError)
  v1 = call_local greet_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#0)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = field(v5, 1)
  v7 = call_local shout_activity(v6)
  v8 = call_rt aion@activity:task_queue/2(v7, lit#1)
  v9 = call_rt aion@workflow:run/1(v8)
  v10 = call_rt aion@awl@error:map_activity_error/1(v9)
  v11 = try_bind v10
  v12 = record(shouted_outcome, [v11])
  v13 = record(ok, [v12])
  return v13
