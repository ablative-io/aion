  v1 = make_closure greet_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v0, v1)
== fn greet_input_decoder$0/1 origin=lifted(greet_input_decoder, #0) ==
  sig: (String) -> Decoder(awl_hello.GreetInput)
  v1 = record(greet_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
