  sig: () -> Decoder(calls_and_side_effects.CallsAndSideEffectsOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure calls_and_side_effects_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#7, v0, v1)
== fn calls_and_side_effects_outcome_decoder$outcome/1 origin=lifted(calls_and_side_effects_outcome_decoder, #0) ==
  sig: (String) -> Decoder(calls_and_side_effects.CallsAndSideEffectsOutcome)
  if cmp Eq v0 lit#11:
    v3 = call_local workspace_decoder()
    v4 = make_closure calls_and_side_effects_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#12, v3, v4)
  else:
    v1 = record(workspace, [lit#8, lit#9])
    v2 = record(ready_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#10)
== fn calls_and_side_effects_outcome_decoder$arm0/1 origin=lifted(calls_and_side_effects_outcome_decoder, #1) ==
  sig: (calls_and_side_effects.Workspace) -> Decoder(calls_and_side_effects.CallsAndSideEffectsOutcome)
  v1 = record(ready_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn announce_activity/1 origin=activity_wrapper(announce, raw=false) ==
  sig: (String) -> Activity(calls_and_side_effects.AnnounceInput, calls_and_side_effects.Ack)
  T-ACT action=announce input_codec=announce_input_codec return=ack_codec
== fn provision_activity/1 origin=activity_wrapper(provision, raw=false) ==
  sig: (String) -> Activity(calls_and_side_effects.ProvisionInput, calls_and_side_effects.Workspace)
  T-ACT action=provision input_codec=provision_input_codec return=workspace_codec
== fn step_provision/1 origin=region(provision) ==
  sig: (String) -> Result(calls_and_side_effects.CallsAndSideEffectsOutcome, AwlError)
  v1 = call_local provision_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#13)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  tail_local step_announce(v5)
== fn step_announce/1 origin=chain_step(provision.announce) ==
  sig: (calls_and_side_effects.Workspace) -> Result(calls_and_side_effects.CallsAndSideEffectsOutcome, AwlError)
  v1 = call_local announce_activity(lit#14) live_after=[v0]
  v2 = call_rt aion@activity:task_queue/2(v1, lit#15) live_after=[v0]
  v3 = call_rt aion@workflow:run/1(v2) live_after=[v0]
  v4 = call_rt aion@awl@error:map_activity_error/1(v3) live_after=[v0]
  v5 = try_bind v4 live_after=[v0]
  tail_local step_handoff(v0)
== fn step_handoff/1 origin=chain_step(provision.handoff) ==
  sig: (calls_and_side_effects.Workspace) -> Result(calls_and_side_effects.CallsAndSideEffectsOutcome, AwlError)
  v1 = record(ready_outcome, [v0])
  v2 = record(ok, [v1])
  return v2
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
