  sig: (calls_and_side_effects.CallsAndSideEffectsOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#6|>awlc.string_to_json, "payload": v1|>workspace_to_json}
  return v2
