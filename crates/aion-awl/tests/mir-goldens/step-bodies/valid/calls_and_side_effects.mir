module calls_and_side_effects source=calls_and_side_effects.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_provision:
    aion@activity:task_queue/2 [activities] (v1, lit#13)
    aion@workflow:run/1 [activities] (v2)
  step_announce:
    aion@activity:task_queue/2 [activities] (v1, lit#15)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] workspace
  [1] ack
  [2] announce_input
  [3] provision_input
  [4] calls_and_side_effects_input
  [5] ready_outcome
  [6] ok
== literals ==
  [0] "path"
  [1] "branch"
  [2] "delivered"
  [3] "message"
  [4] "repo_root"
  [5] "repo_root"
  [6] "ready"
  [7] "outcome"
  [8] ""
  [9] ""
  [10] "CallsAndSideEffectsOutcome"
  [11] "ready"
  [12] "payload"
  [13] "infra"
  [14] "workspace provisioned"
  [15] "infra"
== types ==
  record Workspace tag=workspace
    path: string
    branch: string
  record Ack tag=ack
    delivered: bool
  record AnnounceInput tag=announce_input
    message: string
  record ProvisionInput tag=provision_input
    repo_root: string
  record CallsAndSideEffectsInput tag=calls_and_side_effects_input
    repo_root: string
  union CallsAndSideEffectsOutcome
    ready -> ready_outcome(ref(Workspace))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=calls_and_side_effects_input_codec output=calls_and_side_effects_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(calls_and_side_effects.CallsAndSideEffectsInput, calls_and_side_effects.CallsAndSideEffectsOutcome, AwlError)
  T-DEF name="calls_and_side_effects" input=calls_and_side_effects_input_codec output=calls_and_side_effects_outcome_codec
== fn execute/1 origin=execute ==
  sig: (calls_and_side_effects.CallsAndSideEffectsInput) -> Result(calls_and_side_effects.CallsAndSideEffectsOutcome, AwlError)
  T-EXEC fields=[repo_root:String] entry=step_provision args=[0]
== fn workspace_codec/0 origin=codec_template(RecordTrio, Workspace, record#0) ==
  sig: () -> Codec(calls_and_side_effects.Workspace)
  v0 = make_closure workspace_to_json captures=[]
  v1 = call_local workspace_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn workspace_to_json/1 origin=codec_template(RecordTrio, Workspace, record#0) ==
  sig: (calls_and_side_effects.Workspace) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"path": v1|>awlc.string_to_json, "branch": v2|>awlc.string_to_json}
  return v3
== fn workspace_decoder/0 origin=codec_template(RecordTrio, Workspace, record#0) ==
  sig: () -> Decoder(calls_and_side_effects.Workspace)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure workspace_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn workspace_decoder$0/1 origin=lifted(workspace_decoder, #0) ==
  sig: (String) -> Decoder(calls_and_side_effects.Workspace)
  v1 = call_rt aion@awl@codec:string_decoder/0() live_after=[v0]
  v2 = make_closure workspace_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn workspace_decoder$1/2 origin=lifted(workspace_decoder, #1) ==
  sig: (String, String) -> Decoder(calls_and_side_effects.Workspace)
  v2 = record(workspace, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
