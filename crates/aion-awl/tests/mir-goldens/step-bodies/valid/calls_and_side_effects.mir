  sig: () -> Codec(calls_and_side_effects.CallsAndSideEffectsOutcome)
  v0 = make_closure calls_and_side_effects_outcome_to_json captures=[]
  v1 = call_local calls_and_side_effects_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
