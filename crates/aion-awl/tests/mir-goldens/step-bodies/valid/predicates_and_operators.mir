module predicates_and_operators source=predicates_and_operators.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_decide:
    aion@activity:task_queue/2 [activities] (v2, lit#0)
    aion@workflow:run/1 [activities] (v3)
== durable families == activities
== atoms ==
  [0] candidate
  [1] shipped
  [2] held
  [3] stamp_input
  [4] predicates_and_operators_input
  [5] shipped_outcome
  [6] none
  [7] awl_outcome_failure
  [8] error
  [9] ok
== types ==
  record Candidate tag=candidate
    name: string
    score: int
    age_days: int
    stale: bool
    veto_note: nullable(string) optional
  record Shipped tag=shipped
    name: string
  record Held tag=held
    name: string
    reason: string
  record StampInput tag=stamp_input
    name: string
  record PredicatesAndOperatorsInput tag=predicates_and_operators_input
    candidate: ref(Candidate)
  union PredicatesAndOperatorsOutcome
    shipped -> shipped_outcome(ref(Shipped))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=predicates_and_operators_input_codec output=predicates_and_operators_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(predicates_and_operators.PredicatesAndOperatorsInput, predicates_and_operators.PredicatesAndOperatorsOutcome, AwlError)
  T-DEF name="predicates_and_operators" input=predicates_and_operators_input_codec output=predicates_and_operators_outcome_codec
== fn execute/1 origin=execute ==
  sig: (predicates_and_operators.PredicatesAndOperatorsInput) -> Result(predicates_and_operators.PredicatesAndOperatorsOutcome, AwlError)
  T-EXEC fields=[candidate:predicates_and_operators.Candidate] entry=step_decide args=[0]
== fn candidate_codec/0 origin=codec_template(RecordTrio, Candidate, record#0) ==
  sig: () -> Codec(predicates_and_operators.Candidate)
  v0 = make_closure candidate_to_json captures=[]
  v1 = call_local candidate_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn candidate_to_json/1 origin=codec_template(RecordTrio, Candidate, record#0) ==
  sig: (predicates_and_operators.Candidate) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = field(v0, 3)
  v4 = field(v0, 4)
  v5 = field(v0, 5)
  v6 = json_obj {"name": v1|>awlc.string_to_json, "score": v2|>awlc.int_to_json, "age_days": v3|>awlc.int_to_json, "stale": v4|>awlc.bool_to_json, "veto_note": v5|>awlc.nil_to_json}
  return v6
== fn candidate_decoder/0 origin=codec_template(RecordTrio, Candidate, record#0) ==
  sig: () -> Decoder(predicates_and_operators.Candidate)
  tail_rt gleam@dynamic@decode:success/1(nil)
