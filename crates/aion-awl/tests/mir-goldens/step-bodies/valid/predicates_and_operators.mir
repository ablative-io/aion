== types ==
  record Candidate tag=candidate
    name: string
    score: int
    age_days: int
    stale: bool
    veto_note: nullable(string) optional
  record Shipped tag=shipped
    name: string
  record Held tag=held
    name: string
    reason: string
  record StampInput tag=stamp_input
    name: string
  record PredicatesAndOperatorsInput tag=predicates_and_operators_input
    candidate: ref(Candidate)
  union PredicatesAndOperatorsOutcome
    shipped -> shipped_outcome(ref(Shipped))
