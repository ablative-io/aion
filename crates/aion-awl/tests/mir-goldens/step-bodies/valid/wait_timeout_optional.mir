== fn hold_for_signoff_wait_0_case/1 origin=wait(hold_for_signoff#1) ==
  sig: (Result(wait_timeout_optional.Signoff, aion/error.TimeoutResultError(AwlError))) -> Result(Option(wait_timeout_optional.Signoff), AwlError)
  if is_tagged v0 ok/2:
    v1 = field(v0, 1)
    v2 = record(some, [v1])
    v3 = record(ok, [v2])
    return v3
  else:
    v7 = field(v0, 1)
    if is_tagged v7 timed_out_error/2:
      v4 = record(ok, ['none'])
      return v4
    else:
      if is_tagged v7 inner_error/2:
        v5 = field(v7, 1)
        v6 = record(error, [v5])
        return v6
      else:
        v8 = field(v7, 1)
        v9 = record(awl_timer_failed, [v8])
        v10 = record(error, [v9])
        return v10
