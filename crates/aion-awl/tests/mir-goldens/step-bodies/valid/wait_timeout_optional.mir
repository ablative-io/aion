== types ==
  record Signoff tag=signoff
    reviewer: string
  record Ack tag=ack
    requested: bool
  record Shipped tag=shipped
    change_id: string
    reviewer: string
  record Escalated tag=escalated
    change_id: string
    reason: string
  record RequestSignoffInput tag=request_signoff_input
    change_id: string
  record WaitTimeoutOptionalInput tag=wait_timeout_optional_input
    change_id: string
  union WaitTimeoutOptionalOutcome
    shipped -> shipped_outcome(ref(Shipped))
