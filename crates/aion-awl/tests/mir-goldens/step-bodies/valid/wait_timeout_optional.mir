== fn step_hold_for_signoff/1 origin=chain_step(request.hold_for_signoff) ==
  sig: (String) -> Result(wait_timeout_optional.WaitTimeoutOptionalOutcome, AwlError)
  v1 = make_closure hold_for_signoff_wait_0_receive captures=[]
  v2 = call_rt aion@duration:milliseconds/1(172800000) live_after=[v0, v1]
  v3 = call_rt aion@workflow:with_timeout/2(v1, v2) live_after=[v0]
  v4 = call_local hold_for_signoff_wait_0_case(v3) live_after=[v0]
  v5 = try_bind v4 live_after=[v0]
  v6 = cmp Ne v5 'none'
  if is_true v6:
    v7 = assert_some v5
    v8 = field(v7, 1)
    v9 = record(shipped, [v0, v8])
    v10 = record(shipped_outcome, [v9])
    v11 = record(ok, [v10])
    return v11
  else:
    v12 = record(escalated, [v0, lit#16])
    v13 = call_local escalated_to_json(v12)
    v14 = call_rt gleam@json:to_string/1(v13)
    v15 = record(awl_outcome_failure, [lit#17, v14])
    v16 = record(error, [v15])
    return v16
