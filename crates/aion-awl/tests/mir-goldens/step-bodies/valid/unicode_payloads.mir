== fn unicode_payloads_input_decoder/0 origin=codec_template(RecordTrio, UnicodePayloadsInput, record#1) ==
  sig: () -> Decoder(unicode_payloads.UnicodePayloadsInput)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure unicode_payloads_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v0, v1)
== fn unicode_payloads_input_decoder$0/1 origin=lifted(unicode_payloads_input_decoder, #0) ==
  sig: (String) -> Decoder(unicode_payloads.UnicodePayloadsInput)
  v1 = record(unicode_payloads_input, [v0])
