== fn unicode_payloads_outcome_codec/0 origin=codec_template(UnionTrio, UnicodePayloadsOutcome, union#2) ==
  sig: () -> Codec(unicode_payloads.UnicodePayloadsOutcome)
  v0 = make_closure unicode_payloads_outcome_to_json captures=[]
  v1 = call_local unicode_payloads_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn unicode_payloads_outcome_to_json/1 origin=codec_template(UnionTrio, UnicodePayloadsOutcome, union#2) ==
  sig: (unicode_payloads.UnicodePayloadsOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#3|>awlc.string_to_json, "payload": v1|>greeting_to_json}
  return v2
== fn unicode_payloads_outcome_decoder/0 origin=codec_template(UnionTrio, UnicodePayloadsOutcome, union#2) ==
  sig: () -> Decoder(unicode_payloads.UnicodePayloadsOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure unicode_payloads_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#4, v0, v1)
== fn unicode_payloads_outcome_decoder$outcome/1 origin=lifted(unicode_payloads_outcome_decoder, #0) ==
  sig: (String) -> Decoder(unicode_payloads.UnicodePayloadsOutcome)
  if cmp Eq v0 lit#8:
    v3 = call_local greeting_decoder()
    v4 = make_closure unicode_payloads_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#9, v3, v4)
  else:
    v1 = record(greeting, [lit#5, lit#6])
    v2 = record(greeted_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#7)
