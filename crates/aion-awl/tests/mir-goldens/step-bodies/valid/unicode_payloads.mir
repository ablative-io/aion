  sig: (unicode_payloads.Greeting) -> Decoder(unicode_payloads.UnicodePayloadsOutcome)
  v1 = record(greeted_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn step_greet/1 origin=region(greet) ==
  sig: (String) -> Result(unicode_payloads.UnicodePayloadsOutcome, AwlError)
  v1 = concat lit#10 v0
  v2 = record(greeting, [v1, v0])
  v3 = record(greeted_outcome, [v2])
  v4 = record(ok, [v3])
  return v4
