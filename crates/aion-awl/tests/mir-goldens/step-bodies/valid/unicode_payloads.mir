    who: string
  record UnicodePayloadsInput tag=unicode_payloads_input
    name: string
  union UnicodePayloadsOutcome
    greeted -> greeted_outcome(ref(Greeting))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=unicode_payloads_input_codec output=unicode_payloads_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(unicode_payloads.UnicodePayloadsInput, unicode_payloads.UnicodePayloadsOutcome, AwlError)
  T-DEF name="unicode_payloads" input=unicode_payloads_input_codec output=unicode_payloads_outcome_codec
== fn execute/1 origin=execute ==
  sig: (unicode_payloads.UnicodePayloadsInput) -> Result(unicode_payloads.UnicodePayloadsOutcome, AwlError)
  T-EXEC fields=[name:String] entry=step_greet args=[0]
== fn greeting_codec/0 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: () -> Codec(unicode_payloads.Greeting)
  v0 = make_closure greeting_to_json captures=[]
  v1 = call_local greeting_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn greeting_to_json/1 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: (unicode_payloads.Greeting) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"message": v1|>awlc.string_to_json, "who": v2|>awlc.string_to_json}
  return v3
== fn greeting_decoder/0 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: () -> Decoder(unicode_payloads.Greeting)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure greeting_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn greeting_decoder$0/1 origin=lifted(greeting_decoder, #0) ==
  sig: (String) -> Decoder(unicode_payloads.Greeting)
  v1 = call_rt aion@awl@codec:string_decoder/0() live_after=[v0]
  v2 = make_closure greeting_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn greeting_decoder$1/2 origin=lifted(greeting_decoder, #1) ==
  sig: (String, String) -> Decoder(unicode_payloads.Greeting)
  v2 = record(greeting, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
