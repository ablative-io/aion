== fn send_activity/2 origin=activity_wrapper(send, raw=false) ==
  sig: (String, String) -> Activity(index_and_concat.SendInput, index_and_concat.Receipt)
  T-ACT action=send input_codec=send_input_codec return=receipt_codec
== fn step_send_kickoff/2 origin=region(send_kickoff) ==
  sig: (List(String), String) -> Result(index_and_concat.IndexAndConcatOutcome, AwlError)
  v2 = call_rt aion@awl@runtime:index/3(v0, 0, lit#13) live_after=[v1]
  v3 = try_bind v2 live_after=[v1]
  v4 = concat lit#14 v1
  v5 = call_local send_activity(v3, v4)
  v6 = call_rt aion@activity:task_queue/2(v5, lit#15)
  v7 = call_rt aion@workflow:run/1(v6)
  v8 = call_rt aion@awl@error:map_activity_error/1(v7)
  v9 = try_bind v8
  v10 = record(sent_outcome, [v9])
  v11 = record(ok, [v10])
  return v11
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
