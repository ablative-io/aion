module index_and_concat source=index_and_concat.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_send_kickoff:
    aion@activity:task_queue/2 [activities] (v5, lit#15)
    aion@workflow:run/1 [activities] (v6)
== durable families == activities
== atoms ==
  [0] receipt
  [1] send_input
  [2] index_and_concat_input
  [3] sent_outcome
  [4] ok
== literals ==
  [0] "to"
  [1] "body"
  [2] "to"
  [3] "body"
  [4] "reviewers"
  [5] "topic"
  [6] "sent"
  [7] "outcome"
  [8] ""
  [9] ""
  [10] "IndexAndConcatOutcome"
  [11] "sent"
  [12] "payload"
  [13] "index 0 out of range at line 13, column 12"
  [14] "kickoff: "
  [15] "mailer"
== types ==
  record Receipt tag=receipt
    to: string
    body: string
  record SendInput tag=send_input
    to: string
    body: string
  record IndexAndConcatInput tag=index_and_concat_input
    reviewers: list(string)
    topic: string
  union IndexAndConcatOutcome
    sent -> sent_outcome(ref(Receipt))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=index_and_concat_input_codec output=index_and_concat_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(index_and_concat.IndexAndConcatInput, index_and_concat.IndexAndConcatOutcome, AwlError)
  T-DEF name="index_and_concat" input=index_and_concat_input_codec output=index_and_concat_outcome_codec
== fn execute/1 origin=execute ==
  sig: (index_and_concat.IndexAndConcatInput) -> Result(index_and_concat.IndexAndConcatOutcome, AwlError)
  T-EXEC fields=[reviewers:List(String), topic:String] entry=step_send_kickoff args=[0, 1]
