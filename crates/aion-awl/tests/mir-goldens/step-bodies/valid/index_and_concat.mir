  sig: (index_and_concat.Receipt) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"to": v1|>awlc.string_to_json, "body": v2|>awlc.string_to_json}
  return v3
