== fn step_decide/2 origin=region(decide) ==
  sig: (List(collection_predicates.Finding), List(collection_predicates.Round)) -> Result(collection_predicates.CollectionPredicatesOutcome, AwlError)
  v2 = make_closure awl_predicate_0 captures=[]
  v3 = call_rt gleam@list:any/2(v0, v2) live_after=[v0, v1]
  v4 = make_closure awl_predicate_1 captures=[]
  v5 = call_rt gleam@list:all/2(v0, v4) live_after=[v1, v3]
  v6 = make_closure awl_predicate_2 captures=[]
  v7 = call_rt gleam@list:any/2(v1, v6) live_after=[v3, v5]
  if is_true v7:
    if is_true v3:
      if is_true v5:
        v9 = list([])
        v10 = make_closure awl_predicate_4 captures=[]
        v11 = call_rt gleam@list:all/2(v9, v10) live_after=[v5, v7]
        v13 = list([])
        v14 = make_closure awl_predicate_5 captures=[]
        v15 = call_rt gleam@list:any/2(v13, v14) live_after=[v5, v7, v11]
        v12 = not v15
        v8 = boolop And v11 v12
        v16 = record(verdict, [v7, v5, v8])
        v17 = record(accepted_outcome, [v16])
        v18 = record(ok, [v17])
        return v18
      else:
        v20 = list([])
        v21 = make_closure awl_predicate_6 captures=[]
        v22 = call_rt gleam@list:all/2(v20, v21) live_after=[v5, v7]
        v24 = list([])
        v25 = make_closure awl_predicate_7 captures=[]
        v26 = call_rt gleam@list:any/2(v24, v25) live_after=[v5, v7, v22]
        v23 = not v26
        v19 = boolop And v22 v23
        v27 = record(verdict, [v7, v5, v19])
        v28 = call_local verdict_to_json(v27)
        v29 = call_rt gleam@json:to_string/1(v28)
        v30 = record(awl_outcome_failure, [lit#16, v29])
        v31 = record(error, [v30])
        return v31
    else:
      v33 = list([])
      v34 = make_closure awl_predicate_8 captures=[]
      v35 = call_rt gleam@list:all/2(v33, v34) live_after=[v5, v7]
      v37 = list([])
      v38 = make_closure awl_predicate_9 captures=[]
      v39 = call_rt gleam@list:any/2(v37, v38) live_after=[v5, v7, v35]
      v36 = not v39
      v32 = boolop And v35 v36
      v40 = record(verdict, [v7, v5, v32])
      v41 = call_local verdict_to_json(v40)
      v42 = call_rt gleam@json:to_string/1(v41)
      v43 = record(awl_outcome_failure, [lit#17, v42])
      v44 = record(error, [v43])
      return v44
  else:
    v46 = list([])
    v47 = make_closure awl_predicate_10 captures=[]
    v48 = call_rt gleam@list:all/2(v46, v47) live_after=[v5, v7]
    v50 = list([])
    v51 = make_closure awl_predicate_11 captures=[]
    v52 = call_rt gleam@list:any/2(v50, v51) live_after=[v5, v7, v48]
    v49 = not v52
    v45 = boolop And v48 v49
    v53 = record(verdict, [v7, v5, v45])
    v54 = call_local verdict_to_json(v53)
    v55 = call_rt gleam@json:to_string/1(v54)
    v56 = record(awl_outcome_failure, [lit#18, v55])
    v57 = record(error, [v56])
    return v57
