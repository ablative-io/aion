== fn collection_predicates_outcome_decoder$outcome/1 origin=lifted(collection_predicates_outcome_decoder, #0) ==
  sig: (String) -> Decoder(collection_predicates.CollectionPredicatesOutcome)
  if cmp Eq v0 lit#11:
    v3 = call_local verdict_decoder()
    v4 = make_closure collection_predicates_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#12, v3, v4)
  else:
    v1 = record(verdict, ['false', 'false', 'false'])
    v2 = record(accepted_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#10)
