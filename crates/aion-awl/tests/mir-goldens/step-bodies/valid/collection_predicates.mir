  sig: (collection_predicates.Finding) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"severity": v1|>awlc.string_to_json, "blocking": v2|>awlc.bool_to_json}
  return v3
