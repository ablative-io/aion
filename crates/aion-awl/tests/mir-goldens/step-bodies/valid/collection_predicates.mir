module collection_predicates source=collection_predicates.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
== durable families ==
== atoms ==
  [0] finding
  [1] round
  [2] verdict
  [3] collection_predicates_input
  [4] accepted_outcome
  [5] false
  [6] true
  [7] ok
  [8] awl_outcome_failure
  [9] error
== literals ==
  [0] "severity"
  [1] "blocking"
  [2] "findings"
  [3] "nested_blocker"
  [4] "all_consistent"
  [5] "empty_truth"
  [6] "findings"
  [7] "rounds"
  [8] "accepted"
  [9] "outcome"
  [10] "CollectionPredicatesOutcome"
  [11] "accepted"
  [12] "payload"
  [13] "blocker"
  [14] "blocker"
  [15] "blocker"
  [16] "rejected"
  [17] "rejected"
  [18] "rejected"
== types ==
  record Finding tag=finding
    severity: string
    blocking: bool
  record Round tag=round
    findings: list(ref(Finding))
  record Verdict tag=verdict
    nested_blocker: bool
    all_consistent: bool
    empty_truth: bool
  record CollectionPredicatesInput tag=collection_predicates_input
    findings: list(ref(Finding))
    rounds: list(ref(Round))
  union CollectionPredicatesOutcome
    accepted -> accepted_outcome(ref(Verdict))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=collection_predicates_input_codec output=collection_predicates_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(collection_predicates.CollectionPredicatesInput, collection_predicates.CollectionPredicatesOutcome, AwlError)
  T-DEF name="collection_predicates" input=collection_predicates_input_codec output=collection_predicates_outcome_codec
== fn execute/1 origin=execute ==
  sig: (collection_predicates.CollectionPredicatesInput) -> Result(collection_predicates.CollectionPredicatesOutcome, AwlError)
  T-EXEC fields=[findings:List(collection_predicates.Finding), rounds:List(collection_predicates.Round)] entry=step_decide args=[0, 1]
== fn finding_codec/0 origin=codec_template(RecordTrio, Finding, record#0) ==
  sig: () -> Codec(collection_predicates.Finding)
  v0 = make_closure finding_to_json captures=[]
  v1 = call_local finding_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
