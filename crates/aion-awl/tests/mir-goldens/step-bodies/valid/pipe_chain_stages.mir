  sig: (pipe_chain_stages.ShoutInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"text": v1|>awlc.string_to_json}
  return v2
== fn shout_input_decoder/0 origin=codec_template(RecordTrio, ShoutInput, record#3) ==
  sig: () -> Decoder(pipe_chain_stages.ShoutInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn pipe_chain_stages_input_codec/0 origin=codec_template(RecordTrio, PipeChainStagesInput, record#4) ==
  sig: () -> Codec(pipe_chain_stages.PipeChainStagesInput)
  v0 = make_closure pipe_chain_stages_input_to_json captures=[]
  v1 = call_local pipe_chain_stages_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn pipe_chain_stages_input_to_json/1 origin=codec_template(RecordTrio, PipeChainStagesInput, record#4) ==
  sig: (pipe_chain_stages.PipeChainStagesInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"name": v1|>awlc.string_to_json}
  return v2
