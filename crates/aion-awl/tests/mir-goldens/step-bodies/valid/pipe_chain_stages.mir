module pipe_chain_stages source=pipe_chain_stages.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_greet:
    aion@activity:task_queue/2 [activities] (v1, lit#11)
    aion@workflow:run/1 [activities] (v2)
  step_shout:
    aion@activity:task_queue/2 [activities] (v1, lit#12)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] greeting
  [1] shouted
  [2] greet_input
  [3] shout_input
  [4] pipe_chain_stages_input
  [5] shouted_outcome
  [6] ok
== literals ==
  [0] "greeting"
  [1] "text"
  [2] "name"
  [3] "text"
  [4] "name"
  [5] "shouted"
  [6] "outcome"
  [7] ""
  [8] "PipeChainStagesOutcome"
  [9] "shouted"
  [10] "payload"
  [11] "voice"
  [12] "voice"
== types ==
  record Greeting tag=greeting
    greeting: string
  record Shouted tag=shouted
    text: string
  record GreetInput tag=greet_input
    name: string
  record ShoutInput tag=shout_input
    text: string
  record PipeChainStagesInput tag=pipe_chain_stages_input
    name: string
  union PipeChainStagesOutcome
    shouted -> shouted_outcome(ref(Shouted))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=pipe_chain_stages_input_codec output=pipe_chain_stages_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(pipe_chain_stages.PipeChainStagesInput, pipe_chain_stages.PipeChainStagesOutcome, AwlError)
  T-DEF name="pipe_chain_stages" input=pipe_chain_stages_input_codec output=pipe_chain_stages_outcome_codec
== fn execute/1 origin=execute ==
  sig: (pipe_chain_stages.PipeChainStagesInput) -> Result(pipe_chain_stages.PipeChainStagesOutcome, AwlError)
  T-EXEC fields=[name:String] entry=step_greet args=[0]
== fn greeting_codec/0 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: () -> Codec(pipe_chain_stages.Greeting)
  v0 = make_closure greeting_to_json captures=[]
  v1 = call_local greeting_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn greeting_to_json/1 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: (pipe_chain_stages.Greeting) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"greeting": v1|>awlc.string_to_json}
  return v2
== fn greeting_decoder/0 origin=codec_template(RecordTrio, Greeting, record#0) ==
  sig: () -> Decoder(pipe_chain_stages.Greeting)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure greeting_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn greeting_decoder$0/1 origin=lifted(greeting_decoder, #0) ==
  sig: (String) -> Decoder(pipe_chain_stages.Greeting)
  v1 = record(greeting, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
