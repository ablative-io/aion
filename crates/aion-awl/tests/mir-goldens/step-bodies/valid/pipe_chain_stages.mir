  sig: (pipe_chain_stages.PipeChainStagesOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#5|>awlc.string_to_json, "payload": v1|>shouted_to_json}
  return v2
== fn pipe_chain_stages_outcome_decoder/0 origin=codec_template(UnionTrio, PipeChainStagesOutcome, union#5) ==
  sig: () -> Decoder(pipe_chain_stages.PipeChainStagesOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure pipe_chain_stages_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#6, v0, v1)
== fn pipe_chain_stages_outcome_decoder$outcome/1 origin=lifted(pipe_chain_stages_outcome_decoder, #0) ==
  sig: (String) -> Decoder(pipe_chain_stages.PipeChainStagesOutcome)
  if cmp Eq v0 lit#9:
    v3 = call_local shouted_decoder()
    v4 = make_closure pipe_chain_stages_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#10, v3, v4)
  else:
    v1 = record(shouted, [lit#7])
    v2 = record(shouted_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#8)
== fn pipe_chain_stages_outcome_decoder$arm0/1 origin=lifted(pipe_chain_stages_outcome_decoder, #1) ==
  sig: (pipe_chain_stages.Shouted) -> Decoder(pipe_chain_stages.PipeChainStagesOutcome)
  v1 = record(shouted_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn greet_activity/1 origin=activity_wrapper(greet, raw=false) ==
  sig: (String) -> Activity(pipe_chain_stages.GreetInput, pipe_chain_stages.Greeting)
  T-ACT action=greet input_codec=greet_input_codec return=greeting_codec
== fn shout_activity/1 origin=activity_wrapper(shout, raw=false) ==
  sig: (String) -> Activity(pipe_chain_stages.ShoutInput, pipe_chain_stages.Shouted)
  T-ACT action=shout input_codec=shout_input_codec return=shouted_codec
== fn step_greet/1 origin=region(greet) ==
  sig: (String) -> Result(pipe_chain_stages.PipeChainStagesOutcome, AwlError)
  v1 = call_local greet_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#11)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = field(v5, 1)
  tail_local step_shout(v6)
== fn step_shout/1 origin=chain_step(greet.shout) ==
  sig: (String) -> Result(pipe_chain_stages.PipeChainStagesOutcome, AwlError)
  v1 = call_local shout_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#12)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(shouted_outcome, [v5])
  v7 = record(ok, [v6])
  return v7
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
