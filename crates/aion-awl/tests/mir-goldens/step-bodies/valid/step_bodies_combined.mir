module step_bodies_combined source=step_bodies_combined.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_gather:
    aion@activity:task_queue/2 [activities] (v2, lit#24)
    aion@workflow:run/1 [activities] (v3)
  step_page_lead:
    aion@activity:task_queue/2 [activities] (v6, lit#29)
    aion@workflow:run/1 [activities] (v7)
    aion@workflow:sleep/1 [timers] (v11)
  step_hold_for_ack:
    aion@workflow:with_timeout/2 [timers] (v3, v4)
  hold_for_ack_wait_0_receive:
    aion@workflow:receive/1 [signals] (v0)
== durable families == timers, activities, signals
== atoms ==
  [0] reading
  [1] diagnostics
  [2] page_ack
  [3] page_sent
  [4] resolved
  [5] escalated
  [6] gather_input
  [7] page_input
  [8] step_bodies_combined_input
  [9] resolved_outcome
  [10] ok
  [11] some
  [12] none
  [13] error
  [14] timed_out_error
  [15] inner_error
  [16] awl_timer_failed
  [17] awl_outcome_failure
== literals ==
  [0] "name"
  [1] "severity"
  [2] "anomalous"
  [3] "incident_id"
  [4] "readings"
  [5] "responder"
  [6] "pager_id"
  [7] "incident_id"
  [8] "responder"
  [9] "anomaly_count"
  [10] "incident_id"
  [11] "reason"
  [12] "incident_id"
  [13] "responder"
  [14] "message"
  [15] "incident_id"
  [16] "responders"
  [17] "resolved"
  [18] "outcome"
  [19] ""
  [20] ""
  [21] "StepBodiesCombinedOutcome"
  [22] "resolved"
  [23] "payload"
  [24] "ops"
  [25] "nobody"
  [26] "nobody"
  [27] "index 0 out of range at line 34, column 19"
  [28] "incident "
  [29] "ops"
  [30] "no ack from "
  [31] "index 0 out of range at line 44, column 72"
  [32] "escalated"
== types ==
  record Reading tag=reading
    name: string
    severity: int
    anomalous: bool
  record Diagnostics tag=diagnostics
    incident_id: string
    readings: list(ref(Reading))
  record PageAck tag=page_ack
    responder: string
  record PageSent tag=page_sent
    pager_id: string
  record Resolved tag=resolved
    incident_id: string
    responder: string
    anomaly_count: int
  record Escalated tag=escalated
    incident_id: string
    reason: string
  record GatherInput tag=gather_input
    incident_id: string
  record PageInput tag=page_input
    responder: string
    message: string
  record StepBodiesCombinedInput tag=step_bodies_combined_input
    incident_id: string
    responders: list(string)
  union StepBodiesCombinedOutcome
    resolved -> resolved_outcome(ref(Resolved))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=step_bodies_combined_input_codec output=step_bodies_combined_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(step_bodies_combined.StepBodiesCombinedInput, step_bodies_combined.StepBodiesCombinedOutcome, AwlError)
  T-DEF name="step_bodies_combined" input=step_bodies_combined_input_codec output=step_bodies_combined_outcome_codec
== fn execute/1 origin=execute ==
  sig: (step_bodies_combined.StepBodiesCombinedInput) -> Result(step_bodies_combined.StepBodiesCombinedOutcome, AwlError)
  T-EXEC fields=[incident_id:String, responders:List(String)] entry=step_gather args=[0, 1]
