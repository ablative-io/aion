module wait_and_sleep source=wait_and_sleep.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_cooldown:
    aion@workflow:sleep/1 [timers] (v1)
  step_hold:
    aion@workflow:receive/1 [signals] (v1)
  step_deploy:
    aion@activity:task_queue/2 [activities] (v3, lit#13)
    aion@workflow:run/1 [activities] (v4)
== durable families == timers, activities, signals
== atoms ==
  [0] approval
  [1] deployed
  [2] deploy_input
  [3] wait_and_sleep_input
  [4] deployed_outcome
  [5] ok
== literals ==
  [0] "approver"
  [1] "build_id"
  [2] "approver"
  [3] "build_id"
  [4] "approver"
  [5] "build_id"
  [6] "deployed"
  [7] "outcome"
  [8] ""
  [9] ""
  [10] "WaitAndSleepOutcome"
  [11] "deployed"
  [12] "payload"
  [13] "deployer"
== types ==
  record Approval tag=approval
    approver: string
  record Deployed tag=deployed
    build_id: string
    approver: string
  record DeployInput tag=deploy_input
    build_id: string
    approver: string
  record WaitAndSleepInput tag=wait_and_sleep_input
    build_id: string
  union WaitAndSleepOutcome
    deployed -> deployed_outcome(ref(Deployed))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=wait_and_sleep_input_codec output=wait_and_sleep_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(wait_and_sleep.WaitAndSleepInput, wait_and_sleep.WaitAndSleepOutcome, AwlError)
  T-DEF name="wait_and_sleep" input=wait_and_sleep_input_codec output=wait_and_sleep_outcome_codec
== fn execute/1 origin=execute ==
  sig: (wait_and_sleep.WaitAndSleepInput) -> Result(wait_and_sleep.WaitAndSleepOutcome, AwlError)
  T-EXEC fields=[build_id:String] entry=step_cooldown args=[0]
== fn approval_codec/0 origin=codec_template(RecordTrio, Approval, record#0) ==
  sig: () -> Codec(wait_and_sleep.Approval)
  v0 = make_closure approval_to_json captures=[]
  v1 = call_local approval_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn approval_to_json/1 origin=codec_template(RecordTrio, Approval, record#0) ==
  sig: (wait_and_sleep.Approval) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"approver": v1|>awlc.string_to_json}
  return v2
== fn approval_decoder/0 origin=codec_template(RecordTrio, Approval, record#0) ==
  sig: () -> Decoder(wait_and_sleep.Approval)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure approval_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn approval_decoder$0/1 origin=lifted(approval_decoder, #0) ==
  sig: (String) -> Decoder(wait_and_sleep.Approval)
  v1 = record(approval, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn deployed_codec/0 origin=codec_template(RecordTrio, Deployed, record#1) ==
  sig: () -> Codec(wait_and_sleep.Deployed)
  v0 = make_closure deployed_to_json captures=[]
  v1 = call_local deployed_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn deployed_to_json/1 origin=codec_template(RecordTrio, Deployed, record#1) ==
  sig: (wait_and_sleep.Deployed) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"build_id": v1|>awlc.string_to_json, "approver": v2|>awlc.string_to_json}
  return v3
== fn deployed_decoder/0 origin=codec_template(RecordTrio, Deployed, record#1) ==
  sig: () -> Decoder(wait_and_sleep.Deployed)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure deployed_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v0, v1)
== fn deployed_decoder$0/1 origin=lifted(deployed_decoder, #0) ==
  sig: (String) -> Decoder(wait_and_sleep.Deployed)
  v1 = call_rt aion@awl@codec:string_decoder/0() live_after=[v0]
  v2 = make_closure deployed_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v1, v2)
== fn deployed_decoder$1/2 origin=lifted(deployed_decoder, #1) ==
  sig: (String, String) -> Decoder(wait_and_sleep.Deployed)
  v2 = record(deployed, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
