== fn fetch_findings_activity/1 origin=activity_wrapper(fetch_findings, raw=false) ==
  sig: (String) -> Activity(combinators.FetchFindingsInput, List(combinators.Finding))
  T-ACT action=fetch_findings input_codec=fetch_findings_input_codec return=list_finding_codec
== fn step_fetch/1 origin=region(fetch) ==
  sig: (String) -> Result(combinators.CombinatorsOutcome, AwlError)
  v1 = call_local fetch_findings_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#13)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  tail_local step_tally(v5)
== fn step_tally/1 origin=chain_step(fetch.tally) ==
  sig: (List(combinators.Finding)) -> Result(combinators.CombinatorsOutcome, AwlError)
  v1 = make_closure awl_combinator_0 captures=[]
  v2 = call_rt gleam@list:filter/2(v0, v1) live_after=[v0]
  v3 = make_closure awl_combinator_1 captures=[]
  v4 = call_rt gleam@list:sort/2(v2, v3) live_after=[v0, v2]
  v5 = make_closure awl_combinator_2 captures=[]
  v6 = call_rt gleam@list:map/2(v4, v5) live_after=[v0, v2]
  v7 = call_rt gleam@list:length/1(v2) live_after=[v0, v2, v6]
  v8 = call_rt gleam@list:length/1(v0) live_after=[v2, v6, v7]
  v9 = cmp Eq v2 nil
  if is_true v9:
    v10 = record(clean, [v8])
    v11 = record(clean_outcome, [v10])
    v12 = record(ok, [v11])
    return v12
  else:
    v13 = record(blocked, [v6, v7])
    v14 = call_local blocked_to_json(v13)
    v15 = call_rt gleam@json:to_string/1(v14)
    v16 = record(awl_outcome_failure, [lit#14, v15])
    v17 = record(error, [v16])
    return v17
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
== fn awl_combinator_0/1 origin=lifted(execute, #0) ==
  sig: (combinators.Finding) -> Bool
  v1 = field(v0, 2)
  return v1
== fn awl_combinator_1/2 origin=lifted(execute, #1) ==
  sig: (combinators.Finding, combinators.Finding) -> gleam/order.Order
  v2 = field(v0, 3)
  v3 = field(v1, 3)
  tail_rt gleam@int:compare/2(v2, v3)
== fn awl_combinator_2/1 origin=lifted(execute, #2) ==
  sig: (combinators.Finding) -> String
  v1 = field(v0, 1)
  return v1
