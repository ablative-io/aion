module combinators source=combinators.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_fetch:
    aion@activity:task_queue/2 [activities] (v1, lit#13)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] finding
  [1] clean
  [2] blocked
  [3] fetch_findings_input
  [4] combinators_input
  [5] clean_outcome
  [6] ok
  [7] awl_outcome_failure
  [8] error
== literals ==
  [0] "title"
  [1] "blocking"
  [2] "severity"
  [3] "total"
  [4] "blocker_titles"
  [5] "blocker_count"
  [6] "source"
  [7] "source"
  [8] "clean"
  [9] "outcome"
  [10] "CombinatorsOutcome"
  [11] "clean"
  [12] "payload"
  [13] "registry"
  [14] "blocked"
== types ==
  record Finding tag=finding
    title: string
    blocking: bool
    severity: int
  record Clean tag=clean
    total: int
  record Blocked tag=blocked
    blocker_titles: list(string)
    blocker_count: int
  record FetchFindingsInput tag=fetch_findings_input
    source: string
  record CombinatorsInput tag=combinators_input
    source: string
  union CombinatorsOutcome
    clean -> clean_outcome(ref(Clean))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=combinators_input_codec output=combinators_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(combinators.CombinatorsInput, combinators.CombinatorsOutcome, AwlError)
  T-DEF name="combinators" input=combinators_input_codec output=combinators_outcome_codec
== fn execute/1 origin=execute ==
  sig: (combinators.CombinatorsInput) -> Result(combinators.CombinatorsOutcome, AwlError)
  T-EXEC fields=[source:String] entry=step_fetch args=[0]
== fn finding_codec/0 origin=codec_template(RecordTrio, Finding, record#0) ==
  sig: () -> Codec(combinators.Finding)
  v0 = make_closure finding_to_json captures=[]
  v1 = call_local finding_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn finding_to_json/1 origin=codec_template(RecordTrio, Finding, record#0) ==
  sig: (combinators.Finding) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = field(v0, 3)
  v4 = json_obj {"title": v1|>awlc.string_to_json, "blocking": v2|>awlc.bool_to_json, "severity": v3|>awlc.int_to_json}
  return v4
== fn finding_decoder/0 origin=codec_template(RecordTrio, Finding, record#0) ==
  sig: () -> Decoder(combinators.Finding)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure finding_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn finding_decoder$0/1 origin=lifted(finding_decoder, #0) ==
  sig: (String) -> Decoder(combinators.Finding)
  v1 = call_rt aion@awl@codec:bool_decoder/0() live_after=[v0]
  v2 = make_closure finding_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn finding_decoder$1/2 origin=lifted(finding_decoder, #1) ==
  sig: (Bool, String) -> Decoder(combinators.Finding)
  v2 = call_rt aion@awl@codec:int_decoder/0() live_after=[v0, v1]
  v3 = make_closure finding_decoder$2 captures=[v1, v0]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v2, v3)
== fn finding_decoder$2/3 origin=lifted(finding_decoder, #2) ==
  sig: (Int, String, Bool) -> Decoder(combinators.Finding)
  v3 = record(finding, [v1, v2, v0])
  tail_rt gleam@dynamic@decode:success/1(v3)
