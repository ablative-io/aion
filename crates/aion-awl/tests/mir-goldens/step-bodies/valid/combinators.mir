== fn combinators_outcome_decoder$outcome/1 origin=lifted(combinators_outcome_decoder, #0) ==
  sig: (String) -> Decoder(combinators.CombinatorsOutcome)
  if cmp Eq v0 lit#11:
    v3 = call_local clean_decoder()
    v4 = make_closure combinators_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#12, v3, v4)
  else:
    v1 = record(clean, [0])
    v2 = record(clean_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#10)
== fn combinators_outcome_decoder$arm0/1 origin=lifted(combinators_outcome_decoder, #1) ==
  sig: (combinators.Clean) -> Decoder(combinators.CombinatorsOutcome)
  v1 = record(clean_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
