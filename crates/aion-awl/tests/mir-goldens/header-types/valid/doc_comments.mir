  sig: () -> Decoder(summarize_document.SummarizeDocumentOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure summarize_document_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#8, v0, v1)
== fn summarize_document_outcome_decoder$outcome/1 origin=lifted(summarize_document_outcome_decoder, #0) ==
  sig: (String) -> Decoder(summarize_document.SummarizeDocumentOutcome)
  if cmp Eq v0 lit#11:
    v3 = call_local summary_decoder()
    v4 = make_closure summarize_document_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#12, v3, v4)
  else:
    v1 = record(summary, [lit#9, 0])
    v2 = record(summarized_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#10)
== fn summarize_document_outcome_decoder$arm0/1 origin=lifted(summarize_document_outcome_decoder, #1) ==
  sig: (summarize_document.Summary) -> Decoder(summarize_document.SummarizeDocumentOutcome)
  v1 = record(summarized_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn fetch_activity/1 origin=activity_wrapper(fetch, raw=false) ==
  sig: (String) -> Activity(summarize_document.FetchInput, summarize_document.Document)
  T-ACT action=fetch input_codec=fetch_input_codec return=document_codec
== fn summarize_activity/1 origin=activity_wrapper(summarize, raw=false) ==
  sig: (summarize_document.Document) -> Activity(summarize_document.SummarizeInput, summarize_document.Summary)
  T-ACT action=summarize input_codec=summarize_input_codec return=summary_codec
== fn step_fetch_and_summarize/1 origin=region(fetch_and_summarize) ==
  sig: (String) -> Result(summarize_document.SummarizeDocumentOutcome, AwlError)
  v1 = call_local fetch_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#13)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = call_local summarize_activity(v5)
  v7 = call_rt aion@activity:task_queue/2(v6, lit#14)
  v8 = call_rt aion@workflow:run/1(v7)
  v9 = call_rt aion@awl@error:map_activity_error/1(v8)
  v10 = try_bind v9
  v11 = record(summarized_outcome, [v10])
  v12 = record(ok, [v11])
  return v12
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
