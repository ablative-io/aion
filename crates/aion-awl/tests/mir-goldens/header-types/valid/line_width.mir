module measure_widths source=measure_widths.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_measure:
    aion@activity:task_queue/2 [activities] (v1, lit#19)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] short_record
  [1] wide_record
  [2] measure_input
  [3] measure_widths_input
  [4] measured_outcome
  [5] false
  [6] ok
== literals ==
  [0] "id"
  [1] "label"
  [2] "request_identifier"
  [3] "normalized_request_body"
  [4] "response_status_code"
  [5] "response_elapsed_milliseconds"
  [6] "summary"
  [7] "retryable"
  [8] "request"
  [9] "request"
  [10] "measured"
  [11] "outcome"
  [12] ""
  [13] ""
  [14] float(0.0)
  [15] ""
  [16] "MeasureWidthsOutcome"
  [17] "measured"
  [18] "payload"
  [19] "measurer"
== types ==
  record ShortRecord tag=short_record
    id: int
    label: string
  record WideRecord tag=wide_record
    request_identifier: string
    normalized_request_body: string
    response_status_code: int
    response_elapsed_milliseconds: float
    summary: ref(ShortRecord)
    retryable: bool
  record MeasureInput tag=measure_input
    request: string
  record MeasureWidthsInput tag=measure_widths_input
    request: string
  union MeasureWidthsOutcome
    measured -> measured_outcome(ref(WideRecord))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=measure_widths_input_codec output=measure_widths_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(measure_widths.MeasureWidthsInput, measure_widths.MeasureWidthsOutcome, AwlError)
  T-DEF name="measure_widths" input=measure_widths_input_codec output=measure_widths_outcome_codec
== fn execute/1 origin=execute ==
  sig: (measure_widths.MeasureWidthsInput) -> Result(measure_widths.MeasureWidthsOutcome, AwlError)
  T-EXEC fields=[request:String] entry=step_measure args=[0]
== fn short_record_codec/0 origin=codec_template(RecordTrio, ShortRecord, record#0) ==
  sig: () -> Codec(measure_widths.ShortRecord)
  v0 = make_closure short_record_to_json captures=[]
  v1 = call_local short_record_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn short_record_to_json/1 origin=codec_template(RecordTrio, ShortRecord, record#0) ==
  sig: (measure_widths.ShortRecord) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"id": v1|>awlc.int_to_json, "label": v2|>awlc.string_to_json}
  return v3
== fn short_record_decoder/0 origin=codec_template(RecordTrio, ShortRecord, record#0) ==
  sig: () -> Decoder(measure_widths.ShortRecord)
  v0 = call_rt aion@awl@codec:int_decoder/0()
  v1 = make_closure short_record_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn short_record_decoder$0/1 origin=lifted(short_record_decoder, #0) ==
  sig: (Int) -> Decoder(measure_widths.ShortRecord)
  v1 = call_rt aion@awl@codec:string_decoder/0() live_after=[v0]
  v2 = make_closure short_record_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn short_record_decoder$1/2 origin=lifted(short_record_decoder, #1) ==
  sig: (String, Int) -> Decoder(measure_widths.ShortRecord)
  v2 = record(short_record, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
== fn wide_record_codec/0 origin=codec_template(RecordTrio, WideRecord, record#1) ==
  sig: () -> Codec(measure_widths.WideRecord)
  v0 = make_closure wide_record_to_json captures=[]
  v1 = call_local wide_record_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn wide_record_to_json/1 origin=codec_template(RecordTrio, WideRecord, record#1) ==
  sig: (measure_widths.WideRecord) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = field(v0, 3)
  v4 = field(v0, 4)
  v5 = field(v0, 5)
  v6 = field(v0, 6)
  v7 = json_obj {"request_identifier": v1|>awlc.string_to_json, "normalized_request_body": v2|>awlc.string_to_json, "response_status_code": v3|>awlc.int_to_json, "response_elapsed_milliseconds": v4|>awlc.float_to_json, "summary": v5|>short_record_to_json, "retryable": v6|>awlc.bool_to_json}
  return v7
