  sig: (measure_widths.MeasureWidthsOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#10|>awlc.string_to_json, "payload": v1|>wide_record_to_json}
  return v2
== fn measure_widths_outcome_decoder/0 origin=codec_template(UnionTrio, MeasureWidthsOutcome, union#4) ==
  sig: () -> Decoder(measure_widths.MeasureWidthsOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure measure_widths_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#11, v0, v1)
== fn measure_widths_outcome_decoder$outcome/1 origin=lifted(measure_widths_outcome_decoder, #0) ==
  sig: (String) -> Decoder(measure_widths.MeasureWidthsOutcome)
  if cmp Eq v0 lit#17:
    v4 = call_local wide_record_decoder()
    v5 = make_closure measure_widths_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#18, v4, v5)
  else:
    v1 = record(short_record, [0, lit#15])
    v2 = record(wide_record, [lit#12, lit#13, 0, lit#14, v1, 'false'])
    v3 = record(measured_outcome, [v2])
    tail_rt gleam@dynamic@decode:failure/2(v3, lit#16)
== fn measure_widths_outcome_decoder$arm0/1 origin=lifted(measure_widths_outcome_decoder, #1) ==
  sig: (measure_widths.WideRecord) -> Decoder(measure_widths.MeasureWidthsOutcome)
  v1 = record(measured_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn measure_activity/1 origin=activity_wrapper(measure, raw=false) ==
  sig: (String) -> Activity(measure_widths.MeasureInput, measure_widths.WideRecord)
  T-ACT action=measure input_codec=measure_input_codec return=wide_record_codec
== fn step_measure/1 origin=region(measure) ==
  sig: (String) -> Result(measure_widths.MeasureWidthsOutcome, AwlError)
  v1 = call_local measure_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#19)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(measured_outcome, [v5])
  v7 = record(ok, [v6])
  return v7
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
