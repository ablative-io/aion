  sig: () -> Decoder(measure_widths.WideRecord)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure wide_record_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v0, v1)
== fn wide_record_decoder$0/1 origin=lifted(wide_record_decoder, #0) ==
  sig: (String) -> Decoder(measure_widths.WideRecord)
  v1 = call_rt aion@awl@codec:string_decoder/0() live_after=[v0]
  v2 = make_closure wide_record_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#3, v1, v2)
== fn wide_record_decoder$1/2 origin=lifted(wide_record_decoder, #1) ==
  sig: (String, String) -> Decoder(measure_widths.WideRecord)
  v2 = call_rt aion@awl@codec:int_decoder/0() live_after=[v0, v1]
  v3 = make_closure wide_record_decoder$2 captures=[v1, v0]
  tail_rt gleam@dynamic@decode:field/3(lit#4, v2, v3)
== fn wide_record_decoder$2/3 origin=lifted(wide_record_decoder, #2) ==
  sig: (Int, String, String) -> Decoder(measure_widths.WideRecord)
  v3 = call_rt aion@awl@codec:float_decoder/0() live_after=[v0, v1, v2]
  v4 = make_closure wide_record_decoder$3 captures=[v1, v2, v0]
  tail_rt gleam@dynamic@decode:field/3(lit#5, v3, v4)
== fn wide_record_decoder$3/4 origin=lifted(wide_record_decoder, #3) ==
  sig: (Float, String, String, Int) -> Decoder(measure_widths.WideRecord)
  v4 = call_local short_record_decoder() live_after=[v0, v1, v2, v3]
  v5 = make_closure wide_record_decoder$4 captures=[v1, v2, v3, v0]
  tail_rt gleam@dynamic@decode:field/3(lit#6, v4, v5)
== fn wide_record_decoder$4/5 origin=lifted(wide_record_decoder, #4) ==
  sig: (measure_widths.ShortRecord, String, String, Int, Float) -> Decoder(measure_widths.WideRecord)
  v5 = call_rt aion@awl@codec:bool_decoder/0() live_after=[v0, v1, v2, v3, v4]
  v6 = make_closure wide_record_decoder$5 captures=[v1, v2, v3, v4, v0]
  tail_rt gleam@dynamic@decode:field/3(lit#7, v5, v6)
== fn wide_record_decoder$5/6 origin=lifted(wide_record_decoder, #5) ==
  sig: (Bool, String, String, Int, Float, measure_widths.ShortRecord) -> Decoder(measure_widths.WideRecord)
  v6 = record(wide_record, [v1, v2, v3, v4, v5, v0])
  tail_rt gleam@dynamic@decode:success/1(v6)
