module escalate_finding source=escalate_finding.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_notify_reviewer:
    aion@activity:task_queue/2 [activities] (v2, lit#17)
    aion@workflow:run/1 [activities] (v3)
  step_await_ruling:
    aion@workflow:receive/1 [signals] (v1)
== durable families == activities, signals
== atoms ==
  [0] finding
  [1] ruling
  [2] dismissal
  [3] ack
  [4] notify_input
  [5] escalate_finding_input
  [6] accepted_outcome
  [7] false
  [8] ok
  [9] awl_outcome_failure
  [10] error
== literals ==
  [0] "summary"
  [1] "severity"
  [2] "accept"
  [3] "note"
  [4] "reviewer"
  [5] "note"
  [6] "delivered"
  [7] "finding"
  [8] "reviewer"
  [9] "finding"
  [10] "reviewer"
  [11] "accepted"
  [12] "outcome"
  [13] ""
  [14] "EscalateFindingOutcome"
  [15] "accepted"
  [16] "payload"
  [17] "escalation"
  [18] "dismissed"
== types ==
  record Finding tag=finding
    summary: string
    severity: int
  record Ruling tag=ruling
    accept: bool
    note: string
  record Dismissal tag=dismissal
    reviewer: string
    note: string
  record Ack tag=ack
    delivered: bool
  record NotifyInput tag=notify_input
    finding: ref(Finding)
    reviewer: string
  record EscalateFindingInput tag=escalate_finding_input
    finding: ref(Finding)
    reviewer: string
  union EscalateFindingOutcome
    accepted -> accepted_outcome(ref(Ruling))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=escalate_finding_input_codec output=escalate_finding_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(escalate_finding.EscalateFindingInput, escalate_finding.EscalateFindingOutcome, AwlError)
  T-DEF name="escalate_finding" input=escalate_finding_input_codec output=escalate_finding_outcome_codec
== fn execute/1 origin=execute ==
  sig: (escalate_finding.EscalateFindingInput) -> Result(escalate_finding.EscalateFindingOutcome, AwlError)
  T-EXEC fields=[finding:escalate_finding.Finding, reviewer:String] entry=step_notify_reviewer args=[0, 1]
== fn finding_codec/0 origin=codec_template(RecordTrio, Finding, record#0) ==
  sig: () -> Codec(escalate_finding.Finding)
  v0 = make_closure finding_to_json captures=[]
  v1 = call_local finding_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn finding_to_json/1 origin=codec_template(RecordTrio, Finding, record#0) ==
  sig: (escalate_finding.Finding) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"summary": v1|>awlc.string_to_json, "severity": v2|>awlc.int_to_json}
  return v3
