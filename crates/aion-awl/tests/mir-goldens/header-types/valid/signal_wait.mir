  sig: () -> Decoder(escalate_finding.EscalateFindingOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure escalate_finding_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#12, v0, v1)
== fn escalate_finding_outcome_decoder$outcome/1 origin=lifted(escalate_finding_outcome_decoder, #0) ==
  sig: (String) -> Decoder(escalate_finding.EscalateFindingOutcome)
  if cmp Eq v0 lit#15:
    v3 = call_local ruling_decoder()
    v4 = make_closure escalate_finding_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#16, v3, v4)
  else:
    v1 = record(ruling, ['false', lit#13])
    v2 = record(accepted_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#14)
== fn escalate_finding_outcome_decoder$arm0/1 origin=lifted(escalate_finding_outcome_decoder, #1) ==
  sig: (escalate_finding.Ruling) -> Decoder(escalate_finding.EscalateFindingOutcome)
  v1 = record(accepted_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn notify_activity/2 origin=activity_wrapper(notify, raw=false) ==
  sig: (escalate_finding.Finding, String) -> Activity(escalate_finding.NotifyInput, escalate_finding.Ack)
  T-ACT action=notify input_codec=notify_input_codec return=ack_codec
== fn ruling_signal/0 origin=signal_ref(ruling) ==
  sig: () -> Signal(escalate_finding.Ruling)
  T-SIG signal=ruling payload=ruling_codec
== fn step_notify_reviewer/2 origin=region(notify_reviewer) ==
  sig: (escalate_finding.Finding, String) -> Result(escalate_finding.EscalateFindingOutcome, AwlError)
  v2 = call_local notify_activity(v0, v1) live_after=[v1]
  v3 = call_rt aion@activity:task_queue/2(v2, lit#17) live_after=[v1]
  v4 = call_rt aion@workflow:run/1(v3) live_after=[v1]
  v5 = call_rt aion@awl@error:map_activity_error/1(v4) live_after=[v1]
  v6 = try_bind v5 live_after=[v1]
  tail_local step_await_ruling(v1)
== fn step_await_ruling/1 origin=chain_step(notify_reviewer.await_ruling) ==
  sig: (String) -> Result(escalate_finding.EscalateFindingOutcome, AwlError)
  v1 = call_local ruling_signal() live_after=[v0]
  v2 = call_rt aion@workflow:receive/1(v1) live_after=[v0]
  v3 = call_rt aion@awl@error:map_receive_error/1(v2) live_after=[v0]
  v4 = try_bind v3 live_after=[v0]
  v5 = field(v4, 1)
  if is_true v5:
    v6 = field(v4, 1)
    v7 = field(v4, 2)
    v8 = record(ruling, [v6, v7])
    v9 = record(accepted_outcome, [v8])
    v10 = record(ok, [v9])
    return v10
  else:
    v11 = field(v4, 2)
    v12 = record(dismissal, [v0, v11])
    v13 = call_local dismissal_to_json(v12)
    v14 = call_rt gleam@json:to_string/1(v13)
    v15 = record(awl_outcome_failure, [lit#18, v14])
    v16 = record(error, [v15])
    return v16
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
