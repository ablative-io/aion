  sig: () -> Decoder(escalate_finding.Finding)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure finding_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn finding_decoder$0/1 origin=lifted(finding_decoder, #0) ==
  sig: (String) -> Decoder(escalate_finding.Finding)
  v1 = call_rt aion@awl@codec:int_decoder/0() live_after=[v0]
  v2 = make_closure finding_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn finding_decoder$1/2 origin=lifted(finding_decoder, #1) ==
  sig: (Int, String) -> Decoder(escalate_finding.Finding)
  v2 = record(finding, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
