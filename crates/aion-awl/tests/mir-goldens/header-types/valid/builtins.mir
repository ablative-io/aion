  sig: () -> Codec(analyze_snapshot.TouchInput)
  v0 = make_closure touch_input_to_json captures=[]
  v1 = call_local touch_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
