module analyze_snapshot source=analyze_snapshot.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_probe:
    aion@activity:task_queue/2 [activities] (v5, lit#45)
    aion@workflow:run/1 [activities] (v6)
  step_analyze:
    aion@activity:task_queue/2 [activities] (v5, lit#46)
    aion@workflow:run/1 [activities] (v6)
  step_stamp_and_pass:
    aion@activity:task_queue/2 [activities] (v1, lit#49)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] report
  [1] flagged
  [2] analyze_input
  [3] stamp_input
  [4] touch_input
  [5] analyze_snapshot_input
  [6] passed_outcome
  [7] some
  [8] none
  [9] false
  [10] awl_outcome_failure
  [11] error
  [12] ok
