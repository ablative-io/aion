== types ==
  record Report tag=report
    path: string
    score: float
    attempts: int
    clean: bool
    labels: list(string)
    detail: nullable(string) optional
    extra_labels: nullable(list(string)) optional
  record Flagged tag=flagged
    reason: string
  record AnalyzeInput tag=analyze_input
    dir: string
    cap: float
    tries: int
    tags: list(string)
    note: nullable(string) optional
  record StampInput tag=stamp_input
    report: ref(Report)
  record TouchInput tag=touch_input
    path: string
  record AnalyzeSnapshotInput tag=analyze_snapshot_input
    dir: string
    limit: float
    tries: int
    tags: list(string)
    note: nullable(string) optional
  union AnalyzeSnapshotOutcome
    passed -> passed_outcome(ref(Report))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=analyze_snapshot_input_codec output=analyze_snapshot_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(analyze_snapshot.AnalyzeSnapshotInput, analyze_snapshot.AnalyzeSnapshotOutcome, AwlError)
  T-DEF name="analyze_snapshot" input=analyze_snapshot_input_codec output=analyze_snapshot_outcome_codec
== fn execute/1 origin=execute ==
  sig: (analyze_snapshot.AnalyzeSnapshotInput) -> Result(analyze_snapshot.AnalyzeSnapshotOutcome, AwlError)
  T-EXEC fields=[dir:String, limit:Float, tries:Int, tags:List(String), note:Option(String)] entry=step_probe args=[0, 1, 4, 3, 2]
