  sig: () -> Decoder(analyze_snapshot.TouchInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn analyze_snapshot_input_codec/0 origin=codec_template(RecordTrio, AnalyzeSnapshotInput, record#5) ==
  sig: () -> Codec(analyze_snapshot.AnalyzeSnapshotInput)
  v0 = make_closure analyze_snapshot_input_to_json captures=[]
  v1 = call_local analyze_snapshot_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn analyze_snapshot_input_to_json/1 origin=codec_template(RecordTrio, AnalyzeSnapshotInput, record#5) ==
  sig: (analyze_snapshot.AnalyzeSnapshotInput) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = field(v0, 3)
  v4 = field(v0, 4)
  v5 = field(v0, 5)
  v6 = json_obj {"dir": v1|>awlc.string_to_json, "limit": v2|>awlc.float_to_json, "tries": v3|>awlc.int_to_json, "tags": v4|>awlc.nil_to_json, "note": v5|>awlc.nil_to_json}
  return v6
== fn analyze_snapshot_input_decoder/0 origin=codec_template(RecordTrio, AnalyzeSnapshotInput, record#5) ==
  sig: () -> Decoder(analyze_snapshot.AnalyzeSnapshotInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
