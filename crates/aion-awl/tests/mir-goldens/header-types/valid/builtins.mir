  sig: () -> Codec(analyze_snapshot.AnalyzeInput)
  v0 = make_closure analyze_input_to_json captures=[]
  v1 = call_local analyze_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
