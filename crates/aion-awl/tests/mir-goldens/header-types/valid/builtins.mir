module analyze_snapshot source=analyze_snapshot.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_probe:
    aion@activity:task_queue/2 [activities] (v5, lit#1)
    aion@workflow:run/1 [activities] (v6)
  step_analyze:
    aion@activity:task_queue/2 [activities] (v5, lit#2)
    aion@workflow:run/1 [activities] (v6)
  step_stamp_and_pass:
    aion@activity:task_queue/2 [activities] (v1, lit#5)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] report
  [1] flagged
  [2] analyze_input
  [3] stamp_input
  [4] touch_input
  [5] analyze_snapshot_input
  [6] passed_outcome
  [7] awl_outcome_failure
  [8] error
  [9] ok
== types ==
  record Report tag=report
    path: string
    score: float
    attempts: int
    clean: bool
    labels: list(string)
    detail: nullable(string) optional
    extra_labels: nullable(list(string)) optional
  record Flagged tag=flagged
    reason: string
  record AnalyzeInput tag=analyze_input
    dir: string
    cap: float
    tries: int
    tags: list(string)
    note: nullable(string) optional
  record StampInput tag=stamp_input
    report: ref(Report)
  record TouchInput tag=touch_input
    path: string
  record AnalyzeSnapshotInput tag=analyze_snapshot_input
    dir: string
    limit: float
    tries: int
    tags: list(string)
    note: nullable(string) optional
  union AnalyzeSnapshotOutcome
    passed -> passed_outcome(ref(Report))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=analyze_snapshot_input_codec output=analyze_snapshot_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(analyze_snapshot.AnalyzeSnapshotInput, analyze_snapshot.AnalyzeSnapshotOutcome, AwlError)
  T-DEF name="analyze_snapshot" input=analyze_snapshot_input_codec output=analyze_snapshot_outcome_codec
== fn execute/1 origin=execute ==
  sig: (analyze_snapshot.AnalyzeSnapshotInput) -> Result(analyze_snapshot.AnalyzeSnapshotOutcome, AwlError)
  T-EXEC fields=[dir:String, limit:Float, tries:Int, tags:List(String), note:Option(String)] entry=step_probe args=[0, 1, 4, 3, 2]
== fn report_codec/0 origin=codec_template(RecordTrio, Report, record#0) ==
  sig: () -> Codec(analyze_snapshot.Report)
  v0 = make_closure report_to_json captures=[]
  v1 = call_local report_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn report_to_json/1 origin=codec_template(RecordTrio, Report, record#0) ==
  sig: (analyze_snapshot.Report) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = field(v0, 3)
  v4 = field(v0, 4)
  v5 = field(v0, 5)
  v6 = field(v0, 6)
  v7 = field(v0, 7)
  v8 = json_obj {"path": v1|>awlc.string_to_json, "score": v2|>awlc.float_to_json, "attempts": v3|>awlc.int_to_json, "clean": v4|>awlc.bool_to_json, "labels": v5|>awlc.nil_to_json, "detail": v6|>awlc.nil_to_json, "extra_labels": v7|>awlc.nil_to_json}
  return v8
== fn report_decoder/0 origin=codec_template(RecordTrio, Report, record#0) ==
  sig: () -> Decoder(analyze_snapshot.Report)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn flagged_codec/0 origin=codec_template(RecordTrio, Flagged, record#1) ==
  sig: () -> Codec(analyze_snapshot.Flagged)
  v0 = make_closure flagged_to_json captures=[]
  v1 = call_local flagged_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn flagged_to_json/1 origin=codec_template(RecordTrio, Flagged, record#1) ==
  sig: (analyze_snapshot.Flagged) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"reason": v1|>awlc.string_to_json}
  return v2
== fn flagged_decoder/0 origin=codec_template(RecordTrio, Flagged, record#1) ==
  sig: () -> Decoder(analyze_snapshot.Flagged)
  tail_rt gleam@dynamic@decode:success/1(nil)
