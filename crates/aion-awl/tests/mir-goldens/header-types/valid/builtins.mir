  sig: () -> Codec(analyze_snapshot.AnalyzeSnapshotOutcome)
  v0 = make_closure analyze_snapshot_outcome_to_json captures=[]
  v1 = call_local analyze_snapshot_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
