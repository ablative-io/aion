  sig: (analyze_snapshot.AnalyzeSnapshotOutcome) -> Json
  v1 = json_obj {}
  return v1
== fn analyze_snapshot_outcome_decoder/0 origin=codec_template(UnionTrio, AnalyzeSnapshotOutcome, union#6) ==
  sig: () -> Decoder(analyze_snapshot.AnalyzeSnapshotOutcome)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn analyze_activity/5 origin=activity_wrapper(analyze, raw=false) ==
  sig: (String, Float, Int, List(String), Option(String)) -> Activity(analyze_snapshot.AnalyzeInput, analyze_snapshot.Report)
  T-ACT action=analyze input_codec=analyze_input_codec return=report_codec
== fn stamp_activity/1 origin=activity_wrapper(stamp, raw=false) ==
  sig: (analyze_snapshot.Report) -> Activity(analyze_snapshot.StampInput, analyze_snapshot.Report)
  T-ACT action=stamp input_codec=stamp_input_codec return=report_codec
== fn touch_activity/1 origin=activity_wrapper(touch, raw=false) ==
  sig: (String) -> Activity(analyze_snapshot.TouchInput, Nil)
  T-ACT action=touch input_codec=touch_input_codec return=awlc.nil_codec
== fn step_probe/5 origin=region(probe) ==
  sig: (String, Float, Option(String), List(String), Int) -> Result(analyze_snapshot.AnalyzeSnapshotOutcome, AwlError)
  v5 = call_local touch_activity(lit#0) live_after=[v0, v1, v2, v3, v4]
  v6 = call_rt aion@activity:task_queue/2(v5, lit#1) live_after=[v0, v1, v2, v3, v4]
  v7 = call_rt aion@workflow:run/1(v6) live_after=[v0, v1, v2, v3, v4]
  v8 = call_rt aion@awl@error:map_activity_error/1(v7) live_after=[v0, v1, v2, v3, v4]
  v9 = try_bind v8 live_after=[v0, v1, v2, v3, v4]
  tail_local step_analyze(v0, v1, v2, v3, v4)
== fn step_analyze/5 origin=chain_step(probe.analyze) ==
  sig: (String, Float, Option(String), List(String), Int) -> Result(analyze_snapshot.AnalyzeSnapshotOutcome, AwlError)
  v5 = call_local analyze_activity(v0, v1, v4, v3, v2)
  v6 = call_rt aion@activity:task_queue/2(v5, lit#2)
  v7 = call_rt aion@workflow:run/1(v6)
  v8 = call_rt aion@awl@error:map_activity_error/1(v7)
  v9 = try_bind v8
  v10 = field(v9, 4)
  if is_true v10:
    tail_local step_stamp_and_pass(v9)
  else:
    v11 = record(flagged, [lit#3])
    v12 = call_local flagged_to_json(v11)
    v13 = call_rt gleam@json:to_string/1(v12)
    v14 = record(awl_outcome_failure, [lit#4, v13])
    v15 = record(error, [v14])
    return v15
== fn step_stamp_and_pass/1 origin=region(stamp_and_pass) ==
  sig: (analyze_snapshot.Report) -> Result(analyze_snapshot.AnalyzeSnapshotOutcome, AwlError)
  v1 = call_local stamp_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#5)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(passed_outcome, [v5])
  v7 = record(ok, [v6])
  return v7
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
