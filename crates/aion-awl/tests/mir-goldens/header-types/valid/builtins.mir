  sig: (analyze_snapshot.AnalyzeInput) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = field(v0, 3)
  v4 = field(v0, 4)
  v5 = field(v0, 5)
  v6 = json_obj {"dir": v1|>awlc.string_to_json, "cap": v2|>awlc.float_to_json, "tries": v3|>awlc.int_to_json, "tags": v4|>awlc.nil_to_json, "note": v5|>awlc.nil_to_json}
  return v6
== fn analyze_input_decoder/0 origin=codec_template(RecordTrio, AnalyzeInput, record#2) ==
  sig: () -> Decoder(analyze_snapshot.AnalyzeInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn stamp_input_codec/0 origin=codec_template(RecordTrio, StampInput, record#3) ==
  sig: () -> Codec(analyze_snapshot.StampInput)
  v0 = make_closure stamp_input_to_json captures=[]
  v1 = call_local stamp_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn stamp_input_to_json/1 origin=codec_template(RecordTrio, StampInput, record#3) ==
  sig: (analyze_snapshot.StampInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"report": v1|>report_to_json}
  return v2
== fn stamp_input_decoder/0 origin=codec_template(RecordTrio, StampInput, record#3) ==
  sig: () -> Decoder(analyze_snapshot.StampInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
