module release_notes source=release_notes.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_compose:
    aion@activity:timeout/2 [activities] (v4, v5)
    aion@activity:task_queue/2 [activities] (v6, lit#50)
    aion@activity:node/2 [activities] (v7, lit#51)
    aion@workflow:run/1 [activities] (v8)
  step_await_approval:
    aion@workflow:receive/1 [signals] (v2)
  step_ship:
    aion@activity:retry/2 [activities] (v1, v4)
    aion@activity:timeout/2 [activities] (v5, v6)
    aion@activity:task_queue/2 [activities] (v7, lit#54)
    aion@activity:node/2 [activities] (v8, lit#55)
    aion@workflow:run/1 [activities] (v9)
== durable families == activities, signals
== atoms ==
  [0] drafted
  [1] approved
  [2] shipped
  [3] section
  [4] draft
  [5] approval
  [6] published
  [7] rejected_draft
  [8] draft_notes_input
