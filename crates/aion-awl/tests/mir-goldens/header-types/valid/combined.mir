== types ==
  enum Stage
    drafted = "Drafted"
    approved = "Approved"
    shipped = "Shipped"
  record Section tag=section
    title: string
    body: string
    trimmed_note: nullable(string) optional
  record Draft tag=draft
    tag: string
    sections: list(ref(Section))
    stage: ref(Stage)
  record Approval tag=approval
    approve: bool
    reviewer: string
    note: nullable(string) optional
  record Published tag=published
    tag: string
    sections: list(ref(Section))
  record RejectedDraft tag=rejected_draft
    tag: string
    reviewer: string
    reason: string
  record DraftNotesInput tag=draft_notes_input
    tag: string
    workspace: string
    sections: list(string)
    hint: nullable(string) optional
  record PublishInput tag=publish_input
    draft: ref(Draft)
  record ReleaseNotesInput tag=release_notes_input
    tag: string
    workspace: string
    sections: list(string)
    style_hint: nullable(string) optional
  union ReleaseNotesOutcome
    published -> published_outcome(ref(Published))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=release_notes_input_codec output=release_notes_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(release_notes.ReleaseNotesInput, release_notes.ReleaseNotesOutcome, AwlError)
  T-DEF name="release_notes" input=release_notes_input_codec output=release_notes_outcome_codec
== fn execute/1 origin=execute ==
  sig: (release_notes.ReleaseNotesInput) -> Result(release_notes.ReleaseNotesOutcome, AwlError)
  T-EXEC fields=[tag:String, workspace:String, sections:List(String), style_hint:Option(String)] entry=step_compose args=[2, 3, 0, 1]
== fn stage_codec/0 origin=codec_template(EnumTrio, Stage, enum#0) ==
  sig: () -> Codec(release_notes.Stage)
  v0 = make_closure stage_to_json captures=[]
  v1 = call_local stage_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn stage_to_json/1 origin=codec_template(EnumTrio, Stage, enum#0) ==
  sig: (release_notes.Stage) -> Json
  select v0 {
    drafted ->
      tail_rt gleam@json:string/1(lit#0)
    approved ->
      tail_rt gleam@json:string/1(lit#1)
    shipped ->
      tail_rt gleam@json:string/1(lit#2)
  }
== fn stage_decoder/0 origin=codec_template(EnumTrio, Stage, enum#0) ==
  sig: () -> Decoder(release_notes.Stage)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure stage_decoder$then captures=[]
  tail_rt gleam@dynamic@decode:then/2(v0, v1)
== fn stage_decoder$then/1 origin=lifted(stage_decoder, #0) ==
  sig: (String) -> Decoder(release_notes.Stage)
  if cmp Eq v0 lit#6:
    tail_rt gleam@dynamic@decode:success/1('drafted')
  else:
    if cmp Eq v0 lit#5:
      tail_rt gleam@dynamic@decode:success/1('approved')
    else:
      if cmp Eq v0 lit#4:
        tail_rt gleam@dynamic@decode:success/1('shipped')
      else:
        tail_rt gleam@dynamic@decode:failure/2('drafted', lit#3)
