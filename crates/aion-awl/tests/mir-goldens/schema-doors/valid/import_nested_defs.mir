== fn step_tally/1 origin=region(tally) ==
  sig: (import_nested_defs.Order) -> Result(import_nested_defs.ImportNestedDefsOutcome, AwlError)
  v1 = field(v0, 3)
  v2 = call_rt gleam@list:length/1(v1) live_after=[v0]
  v4 = field(v0, 4)
  v3 = cmp Eq v4 lit#21
  if is_true v3:
    v5 = field(v0, 1)
    v6 = field(v5, 2)
    v7 = record(no_lines, [lit#22, v6])
    v8 = call_local no_lines_to_json(v7)
    v9 = call_rt gleam@json:to_string/1(v8)
    v10 = record(awl_outcome_failure, [lit#23, v9])
    v11 = record(error, [v10])
    return v11
  else:
    v12 = cmp Eq v2 0
    if is_true v12:
      v13 = field(v0, 1)
      v14 = field(v13, 2)
      v15 = record(no_lines, [lit#24, v14])
      v16 = call_local no_lines_to_json(v15)
      v17 = call_rt gleam@json:to_string/1(v16)
      v18 = record(awl_outcome_failure, [lit#25, v17])
      v19 = record(error, [v18])
      return v19
    else:
      tail_local step_pack_order(v0)
== fn step_pack_order/1 origin=region(pack_order) ==
  sig: (import_nested_defs.Order) -> Result(import_nested_defs.ImportNestedDefsOutcome, AwlError)
  v1 = call_local pack_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#26)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(packed_outcome, [v5])
  v7 = record(ok, [v6])
  return v7
