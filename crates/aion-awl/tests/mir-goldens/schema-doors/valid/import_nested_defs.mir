    name: string
  record Line tag=line
    quantity: int
    sku: string
  record PackInput tag=pack_input
    order: ref(Order)
  record ImportNestedDefsInput tag=import_nested_defs_input
    order: ref(Order)
  union ImportNestedDefsOutcome
    packed -> packed_outcome(ref(Packed))
