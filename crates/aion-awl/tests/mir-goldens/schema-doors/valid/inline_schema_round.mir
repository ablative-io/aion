  sig: () -> Decoder(inline_schema_round.InlineSchemaRoundInput)
  v0 = call_local round_decoder()
  v1 = make_closure inline_schema_round_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#5, v0, v1)
