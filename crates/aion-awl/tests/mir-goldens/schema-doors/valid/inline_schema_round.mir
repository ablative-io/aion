  return v2
== fn write_report_input_decoder/0 origin=codec_template(RecordTrio, WriteReportInput, record#3) ==
  sig: () -> Decoder(inline_schema_round.WriteReportInput)
  v0 = call_local round_decoder()
  v1 = make_closure write_report_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#4, v0, v1)
== fn write_report_input_decoder$0/1 origin=lifted(write_report_input_decoder, #0) ==
  sig: (inline_schema_round.Round) -> Decoder(inline_schema_round.WriteReportInput)
  v1 = record(write_report_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
