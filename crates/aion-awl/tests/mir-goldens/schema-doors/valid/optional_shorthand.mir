module optional_shorthand source=optional_shorthand.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_examine:
    aion@activity:task_queue/2 [activities] (v1, lit#18)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] note
  [1] filed
  [2] polish_input
  [3] optional_shorthand_input
  [4] filed_outcome
  [5] some
  [6] none
  [7] ok
== literals ==
  [0] "title"
  [1] "tags"
  [2] "body"
  [3] "title"
  [4] "body"
  [5] "tags"
  [6] "title"
  [7] "body"
  [8] "title"
  [9] "body"
  [10] "note"
  [11] "note"
  [12] "filed"
  [13] "outcome"
  [14] ""
  [15] "OptionalShorthandOutcome"
  [16] "filed"
  [17] "payload"
  [18] "doors"
== types ==
  record Note tag=note
    title: string
    body: nullable(string) optional
    tags: list(string)
  record Filed tag=filed
    title: string
    body: nullable(string) optional
  record PolishInput tag=polish_input
    note: ref(Note)
  record OptionalShorthandInput tag=optional_shorthand_input
    note: ref(Note)
  union OptionalShorthandOutcome
    filed -> filed_outcome(ref(Filed))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=optional_shorthand_input_codec output=optional_shorthand_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(optional_shorthand.OptionalShorthandInput, optional_shorthand.OptionalShorthandOutcome, AwlError)
