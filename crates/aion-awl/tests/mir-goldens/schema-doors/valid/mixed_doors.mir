module mixed_doors source=mixed_doors.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_enrichment:
    aion@activity:retry/2 [activities] (v1, v4)
    aion@activity:timeout/2 [activities] (v5, v6)
    aion@activity:task_queue/2 [activities] (v7, lit#32)
    aion@activity:node/2 [activities] (v8, lit#33)
    aion@workflow:run/1 [activities] (v9)
== durable families == activities
== atoms ==
  [0] submission
  [1] intake_config
  [2] filed_record
  [3] bounced
  [4] enriched
  [5] enrich_submission_input
  [6] mixed_doors_input
  [7] filed_outcome
  [8] some
  [9] none
  [10] awl_outcome_failure
  [11] error
  [12] fixed
  [13] retry_policy
  [14] ok
== literals ==
  [0] "attachments"
  [1] "title"
  [2] "category"
  [3] "contact"
  [4] "attachments"
  [5] "category"
  [6] "contact"
  [7] "title"
  [8] "max_attachments"
  [9] "archive_dir"
  [10] "archive_dir"
  [11] "max_attachments"
  [12] "reference"
  [13] "contact"
  [14] "reference"
  [15] "contact"
  [16] "reason"
  [17] "reference"
  [18] "contact"
  [19] "reference"
  [20] "contact"
  [21] "submission"
  [22] "submission"
  [23] "config"
  [24] "filed"
  [25] "outcome"
  [26] ""
  [27] "MixedDoorsOutcome"
  [28] "filed"
  [29] "payload"
  [30] "too many attachments"
  [31] "bounced"
  [32] "intake"
  [33] "shell"
== types ==
  record Submission tag=submission
    attachments: list(string)
    category: nullable(string) optional
    contact: nullable(string) optional
    title: string
  record IntakeConfig tag=intake_config
    archive_dir: nullable(string) optional
    max_attachments: int
  record FiledRecord tag=filed_record
    reference: string
    contact: nullable(string) optional
  record Bounced tag=bounced
    reason: string
  record Enriched tag=enriched
    reference: string
    contact: nullable(string) optional
  record EnrichSubmissionInput tag=enrich_submission_input
    submission: ref(Submission)
  record MixedDoorsInput tag=mixed_doors_input
    submission: ref(Submission)
    config: ref(IntakeConfig)
  union MixedDoorsOutcome
    filed -> filed_outcome(ref(FiledRecord))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=mixed_doors_input_codec output=mixed_doors_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(mixed_doors.MixedDoorsInput, mixed_doors.MixedDoorsOutcome, AwlError)
  T-DEF name="mixed_doors" input=mixed_doors_input_codec output=mixed_doors_outcome_codec
== fn execute/1 origin=execute ==
  sig: (mixed_doors.MixedDoorsInput) -> Result(mixed_doors.MixedDoorsOutcome, AwlError)
  T-EXEC fields=[submission:mixed_doors.Submission, config:mixed_doors.IntakeConfig] entry=step_size_gate args=[1, 0]
