== fn assign_activity/1 origin=activity_wrapper(assign, raw=false) ==
  sig: (import_ticket.Ticket) -> Activity(import_ticket.AssignInput, import_ticket.Triaged)
  T-ACT action=assign input_codec=assign_input_codec return=triaged_codec
== fn step_triage/1 origin=region(triage) ==
  sig: (import_ticket.Ticket) -> Result(import_ticket.ImportTicketOutcome, AwlError)
  v1 = call_local assign_activity(v0) live_after=[v0]
  v2 = call_rt aion@activity:task_queue/2(v1, lit#16) live_after=[v0]
  v3 = call_rt aion@workflow:run/1(v2) live_after=[v0]
  v4 = call_rt aion@awl@error:map_activity_error/1(v3) live_after=[v0]
  v5 = try_bind v4 live_after=[v0]
  v6 = field(v0, 1)
  v7 = cmp Ne v6 'none'
  if is_true v7:
    v8 = assert_some v6
    v9 = field(v5, 1)
    v10 = record(triaged, [v9, v8])
    v11 = record(triaged_outcome, [v10])
    v12 = record(ok, [v11])
    return v12
  else:
    v13 = record(dropped, [lit#17])
    v14 = call_local dropped_to_json(v13)
    v15 = call_rt gleam@json:to_string/1(v14)
    v16 = record(awl_outcome_failure, [lit#18, v15])
    v17 = record(error, [v16])
    return v17
