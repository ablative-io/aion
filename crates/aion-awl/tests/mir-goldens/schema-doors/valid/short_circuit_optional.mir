== fn option_detail_decoder/0 origin=codec_template(CompositeTrio, Option(Detail), composite(nullable(ref(Detail)))) ==
  sig: () -> Decoder(Option(short_circuit_optional.Detail))
  v0 = call_local detail_decoder()
  tail_rt gleam@dynamic@decode:optional/1(v0)
== fn step_decide/1 origin=region(decide) ==
  sig: (short_circuit_optional.Candidate) -> Result(short_circuit_optional.ShortCircuitOptionalOutcome, AwlError)
  v1 = field(v0, 1)
  v2 = cmp Eq v1 'none'
  if is_true v2:
    v3 = record(decision, [lit#11])
    v4 = record(accepted_outcome, [v3])
    v5 = record(ok, [v4])
    return v5
  else:
    v6 = assert_some v1
    v7 = field(v6, 1)
    if is_true v7:
      v8 = record(decision, [lit#12])
      v9 = record(accepted_outcome, [v8])
      v10 = record(ok, [v9])
      return v10
    else:
      v11 = record(decision, [lit#13])
      v12 = record(accepted_outcome, [v11])
      v13 = record(ok, [v12])
      return v13
