  return v2
== fn short_circuit_optional_input_decoder/0 origin=codec_template(RecordTrio, ShortCircuitOptionalInput, record#3) ==
  sig: () -> Decoder(short_circuit_optional.ShortCircuitOptionalInput)
  v0 = call_local candidate_decoder()
  v1 = make_closure short_circuit_optional_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#4, v0, v1)
== fn short_circuit_optional_input_decoder$0/1 origin=lifted(short_circuit_optional_input_decoder, #0) ==
  sig: (short_circuit_optional.Candidate) -> Decoder(short_circuit_optional.ShortCircuitOptionalInput)
  v1 = record(short_circuit_optional_input, [v0])
