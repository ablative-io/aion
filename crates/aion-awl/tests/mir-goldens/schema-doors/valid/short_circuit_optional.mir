  sig: (short_circuit_optional.ShortCircuitOptionalOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#5|>awlc.string_to_json, "payload": v1|>decision_to_json}
  return v2
== fn short_circuit_optional_outcome_decoder/0 origin=codec_template(UnionTrio, ShortCircuitOptionalOutcome, union#4) ==
  sig: () -> Decoder(short_circuit_optional.ShortCircuitOptionalOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure short_circuit_optional_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#6, v0, v1)
== fn short_circuit_optional_outcome_decoder$outcome/1 origin=lifted(short_circuit_optional_outcome_decoder, #0) ==
  sig: (String) -> Decoder(short_circuit_optional.ShortCircuitOptionalOutcome)
  if cmp Eq v0 lit#9:
    v3 = call_local decision_decoder()
    v4 = make_closure short_circuit_optional_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#10, v3, v4)
  else:
    v1 = record(decision, [lit#7])
    v2 = record(accepted_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#8)
== fn short_circuit_optional_outcome_decoder$arm0/1 origin=lifted(short_circuit_optional_outcome_decoder, #1) ==
  sig: (short_circuit_optional.Decision) -> Decoder(short_circuit_optional.ShortCircuitOptionalOutcome)
  v1 = record(accepted_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
