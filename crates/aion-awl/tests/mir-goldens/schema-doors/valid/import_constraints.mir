== fn register_activity/1 origin=activity_wrapper(register, raw=false) ==
  sig: (import_constraints.Profile) -> Activity(import_constraints.RegisterInput, import_constraints.Registered)
  T-ACT action=register input_codec=register_input_codec return=registered_codec
== fn step_gate/1 origin=region(gate) ==
  sig: (import_constraints.Profile) -> Result(import_constraints.ImportConstraintsOutcome, AwlError)
  v1 = field(v0, 4)
  v3 = field(v0, 1)
  v2 = cmp Ge v3 18
  if is_true v2:
    tail_local step_enroll(v0)
  else:
    v4 = concat lit#18 v1
    v5 = record(refused, [v4])
    v6 = call_local refused_to_json(v5)
    v7 = call_rt gleam@json:to_string/1(v6)
    v8 = record(awl_outcome_failure, [lit#19, v7])
    v9 = record(error, [v8])
    return v9
== fn step_enroll/1 origin=region(enroll) ==
  sig: (import_constraints.Profile) -> Result(import_constraints.ImportConstraintsOutcome, AwlError)
  v1 = call_local register_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#20)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(registered_outcome, [v5])
  v7 = record(ok, [v6])
  return v7
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
