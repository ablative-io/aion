module import_constraints source=import_constraints.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_enroll:
    aion@activity:task_queue/2 [activities] (v1, lit#20)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] profile
  [1] registered
  [2] refused
  [3] register_input
  [4] import_constraints_input
  [5] registered_outcome
  [6] some
  [7] none
  [8] awl_outcome_failure
  [9] error
  [10] ok
== literals ==
  [0] "age"
  [1] "handle"
  [2] "bio"
  [3] "email"
  [4] "age"
  [5] "bio"
  [6] "email"
  [7] "handle"
  [8] "handle"
  [9] "reason"
  [10] "profile"
  [11] "profile"
  [12] "registered"
  [13] "outcome"
  [14] ""
  [15] "ImportConstraintsOutcome"
  [16] "registered"
  [17] "payload"
  [18] "too young to register: "
  [19] "refused"
  [20] "doors"
== types ==
  record Profile tag=profile
    age: int
    bio: nullable(string) optional
    email: nullable(string) optional
    handle: string
  record Registered tag=registered
    handle: string
  record Refused tag=refused
    reason: string
  record RegisterInput tag=register_input
    profile: ref(Profile)
  record ImportConstraintsInput tag=import_constraints_input
    profile: ref(Profile)
  union ImportConstraintsOutcome
    registered -> registered_outcome(ref(Registered))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=import_constraints_input_codec output=import_constraints_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(import_constraints.ImportConstraintsInput, import_constraints.ImportConstraintsOutcome, AwlError)
  T-DEF name="import_constraints" input=import_constraints_input_codec output=import_constraints_outcome_codec
== fn execute/1 origin=execute ==
  sig: (import_constraints.ImportConstraintsInput) -> Result(import_constraints.ImportConstraintsOutcome, AwlError)
  T-EXEC fields=[profile:import_constraints.Profile] entry=step_gate args=[0]
