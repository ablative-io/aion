== types ==
  record Reading tag=reading
    celsius: float
    label: nullable(string) optional
    pattern_id: nullable(string) optional
    scaled: nullable(int) optional
  record Filed tag=filed
    note: string
  record FileReadingInput tag=file_reading_input
    reading: ref(Reading)
  record InlineVerbatimConstraintsInput tag=inline_verbatim_constraints_input
    reading: ref(Reading)
  union InlineVerbatimConstraintsOutcome
    filed -> filed_outcome(ref(Filed))
