  sig: (drafting.Published) -> Decoder(drafting.DraftingOutcome)
  v1 = record(published_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn polish_activity/2 origin=activity_wrapper(polish, raw=false) ==
  sig: (String, drafting.Draft) -> Activity(drafting.PolishInput, drafting.Draft)
  T-ACT action=polish input_codec=polish_input_codec return=draft_codec
== fn review_activity/1 origin=activity_wrapper(review, raw=false) ==
  sig: (drafting.Draft) -> Activity(drafting.ReviewInput, drafting.Verdict)
  T-ACT action=review input_codec=review_input_codec return=verdict_codec
== fn step_compose/3 origin=region(compose) ==
  sig: (Int, Int, String) -> Result(drafting.DraftingOutcome, AwlError)
  v3 = record(draft, [lit#18, 'false'])
  v4 = call_local compose_loop_0(v3, 0, v1, v2) live_after=[v0, v1, v2]
  v5 = try_bind v4 live_after=[v0, v1, v2]
  v6 = field(v5, 0)
  v7 = field(v5, 1)
  v8 = field(v6, 2)
  if is_true v8:
    tail_local step_check(v0, v6, v1, v7, v2)
  else:
    v9 = record(exhausted, [lit#21])
    v10 = call_local exhausted_to_json(v9)
    v11 = call_rt gleam@json:to_string/1(v10)
    v12 = record(awl_outcome_failure, [lit#22, v11])
    v13 = record(error, [v12])
    return v13
== fn step_check/5 origin=region(check) ==
  sig: (Int, drafting.Draft, Int, Int, String) -> Result(drafting.DraftingOutcome, AwlError)
  v5 = increment v0
  if cmp Gt v5 v2:
    v6 = record(awl_visits_exceeded, [lit#23])
    v7 = record(error, [v6])
    return v7
  else:
    v8 = call_local review_activity(v1) live_after=[v1, v2, v3, v4, v5]
    v9 = call_rt aion@duration:milliseconds/1(600000) live_after=[v1, v2, v3, v4, v5, v8]
    v10 = call_rt aion@activity:timeout/2(v8, v9) live_after=[v1, v2, v3, v4, v5]
    v11 = call_rt aion@activity:task_queue/2(v10, lit#24) live_after=[v1, v2, v3, v4, v5]
    v12 = call_rt aion@activity:node/2(v11, lit#25) live_after=[v1, v2, v3, v4, v5]
    v13 = call_rt aion@workflow:run/1(v12) live_after=[v1, v2, v3, v4, v5]
    v14 = call_rt aion@awl@error:map_activity_error/1(v13) live_after=[v1, v2, v3, v4, v5]
    v15 = try_bind v14 live_after=[v1, v2, v3, v4, v5]
    v16 = field(v15, 1)
    if is_true v16:
      v17 = field(v1, 1)
      v18 = record(published, [v17, v3])
      v19 = record(published_outcome, [v18])
      v20 = record(ok, [v19])
      return v20
    else:
      tail_local step_compose(v5, v2, v4)
== fn compose_loop_0/4 origin=loop(compose#0) ==
  sig: (drafting.Draft, Int, Int, String) -> Result(#(drafting.Draft, Int), AwlError)
  v4 = call_local polish_activity(v3, v0) live_after=[v1, v2, v3]
  v5 = call_rt aion@duration:milliseconds/1(600000) live_after=[v1, v2, v3, v4]
  v6 = call_rt aion@activity:timeout/2(v4, v5) live_after=[v1, v2, v3]
  v7 = call_rt aion@activity:task_queue/2(v6, lit#19) live_after=[v1, v2, v3]
  v8 = call_rt aion@activity:node/2(v7, lit#20) live_after=[v1, v2, v3]
  v9 = call_rt aion@workflow:run/1(v8) live_after=[v1, v2, v3]
  v10 = call_rt aion@awl@error:map_activity_error/1(v9) live_after=[v1, v2, v3]
  v11 = try_bind v10 live_after=[v1, v2, v3]
  v12 = increment v1
  v15 = field(v11, 2)
  if is_true v15:
    v13 = tuple([v11, v12])
    v14 = record(ok, [v13])
    return v14
  else:
    if cmp Ge v12 v2:
      v13 = tuple([v11, v12])
      v14 = record(ok, [v13])
      return v14
    else:
      tail_local compose_loop_0(v11, v12, v2, v3)
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
