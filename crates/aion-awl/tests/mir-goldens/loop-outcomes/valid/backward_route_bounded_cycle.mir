  v1 = make_closure drafting_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#13, v0, v1)
== fn drafting_outcome_decoder$outcome/1 origin=lifted(drafting_outcome_decoder, #0) ==
  sig: (String) -> Decoder(drafting.DraftingOutcome)
  if cmp Eq v0 lit#16:
    v3 = call_local published_decoder()
    v4 = make_closure drafting_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#17, v3, v4)
  else:
    v1 = record(published, [lit#14, 0])
    v2 = record(published_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#15)
