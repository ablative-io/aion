  return v2
== fn exhausted_decoder/0 origin=codec_template(RecordTrio, Exhausted, record#3) ==
  sig: () -> Decoder(drafting.Exhausted)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn polish_input_codec/0 origin=codec_template(RecordTrio, PolishInput, record#4) ==
  sig: () -> Codec(drafting.PolishInput)
  v0 = make_closure polish_input_to_json captures=[]
  v1 = call_local polish_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn polish_input_to_json/1 origin=codec_template(RecordTrio, PolishInput, record#4) ==
  sig: (drafting.PolishInput) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"topic": v1|>awlc.string_to_json, "prior": v2|>draft_to_json}
  return v3
== fn polish_input_decoder/0 origin=codec_template(RecordTrio, PolishInput, record#4) ==
  sig: () -> Decoder(drafting.PolishInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
