== fn drafting_outcome_codec/0 origin=codec_template(UnionTrio, DraftingOutcome, union#7) ==
  sig: () -> Codec(drafting.DraftingOutcome)
  v0 = make_closure drafting_outcome_to_json captures=[]
  v1 = call_local drafting_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn drafting_outcome_to_json/1 origin=codec_template(UnionTrio, DraftingOutcome, union#7) ==
  sig: (drafting.DraftingOutcome) -> Json
  v1 = json_obj {}
  return v1
== fn drafting_outcome_decoder/0 origin=codec_template(UnionTrio, DraftingOutcome, union#7) ==
  sig: () -> Decoder(drafting.DraftingOutcome)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn polish_activity/2 origin=activity_wrapper(polish, raw=false) ==
  sig: (String, drafting.Draft) -> Activity(drafting.PolishInput, drafting.Draft)
  T-ACT action=polish input_codec=polish_input_codec return=draft_codec
== fn review_activity/1 origin=activity_wrapper(review, raw=false) ==
  sig: (drafting.Draft) -> Activity(drafting.ReviewInput, drafting.Verdict)
  T-ACT action=review input_codec=review_input_codec return=verdict_codec
== fn step_compose/2 origin=region(compose) ==
  sig: (Int, String) -> Result(drafting.DraftingOutcome, AwlError)
  v2 = record(draft, [lit#0, 'false'])
  v3 = call_local compose_loop_0(v2, 0, v0, v1) live_after=[v0, v1]
  v4 = try_bind v3 live_after=[v0, v1]
  v5 = field(v4, 0)
  v6 = field(v4, 1)
  v7 = field(v5, 2)
  if is_true v7:
    tail_local step_check(v5, v0, v6, v1)
  else:
    v8 = record(exhausted, [lit#3])
    v9 = call_local exhausted_to_json(v8)
    v10 = call_rt gleam@json:to_string/1(v9)
    v11 = record(awl_outcome_failure, [lit#4, v10])
    v12 = record(error, [v11])
    return v12
== fn step_check/4 origin=region(check) ==
  sig: (drafting.Draft, Int, Int, String) -> Result(drafting.DraftingOutcome, AwlError)
  v4 = call_local review_activity(v0) live_after=[v0, v1, v2, v3]
  v5 = call_rt aion@duration:milliseconds/1(600000) live_after=[v0, v1, v2, v3, v4]
  v6 = call_rt aion@activity:timeout/2(v4, v5) live_after=[v0, v1, v2, v3]
  v7 = call_rt aion@activity:task_queue/2(v6, lit#5) live_after=[v0, v1, v2, v3]
  v8 = call_rt aion@activity:node/2(v7, lit#6) live_after=[v0, v1, v2, v3]
  v9 = call_rt aion@workflow:run/1(v8) live_after=[v0, v1, v2, v3]
  v10 = call_rt aion@awl@error:map_activity_error/1(v9) live_after=[v0, v1, v2, v3]
  v11 = try_bind v10 live_after=[v0, v1, v2, v3]
  v12 = field(v11, 1)
  if is_true v12:
    v13 = field(v0, 1)
    v14 = record(published, [v13, v2])
    v15 = record(published_outcome, [v14])
    v16 = record(ok, [v15])
    return v16
  else:
    tail_local step_compose(v1, v3)
== fn compose_loop_0/4 origin=loop(compose#0) ==
  sig: (drafting.Draft, Int, Int, String) -> Result(#(drafting.Draft, Int), AwlError)
  v4 = call_local polish_activity(v3, v0) live_after=[v1, v2, v3]
  v5 = call_rt aion@duration:milliseconds/1(600000) live_after=[v1, v2, v3, v4]
  v6 = call_rt aion@activity:timeout/2(v4, v5) live_after=[v1, v2, v3]
  v7 = call_rt aion@activity:task_queue/2(v6, lit#1) live_after=[v1, v2, v3]
  v8 = call_rt aion@activity:node/2(v7, lit#2) live_after=[v1, v2, v3]
  v9 = call_rt aion@workflow:run/1(v8) live_after=[v1, v2, v3]
  v10 = call_rt aion@awl@error:map_activity_error/1(v9) live_after=[v1, v2, v3]
  v11 = try_bind v10 live_after=[v1, v2, v3]
  v12 = increment v1
  v15 = field(v11, 2)
  if is_true v15:
    v13 = tuple([v11, v12])
    v14 = record(ok, [v13])
    return v14
  else:
    if cmp Ge v12 v2:
      v13 = tuple([v11, v12])
      v14 = record(ok, [v13])
      return v14
    else:
      tail_local compose_loop_0(v11, v12, v2, v3)
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
