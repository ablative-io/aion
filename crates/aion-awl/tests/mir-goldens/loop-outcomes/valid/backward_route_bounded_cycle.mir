module drafting source=drafting.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_check:
    aion@activity:timeout/2 [activities] (v8, v9)
    aion@activity:task_queue/2 [activities] (v10, lit#24)
    aion@activity:node/2 [activities] (v11, lit#25)
    aion@workflow:run/1 [activities] (v12)
  compose_loop_0:
    aion@activity:timeout/2 [activities] (v4, v5)
    aion@activity:task_queue/2 [activities] (v6, lit#19)
    aion@activity:node/2 [activities] (v7, lit#20)
    aion@workflow:run/1 [activities] (v8)
== durable families == activities
== atoms ==
  [0] draft
  [1] verdict
  [2] published
  [3] exhausted
  [4] polish_input
  [5] review_input
  [6] drafting_input
  [7] published_outcome
  [8] false
  [9] ok
  [10] awl_outcome_failure
  [11] error
  [12] awl_visits_exceeded
== literals ==
  [0] "body"
  [1] "ready"
  [2] "approved"
  [3] "notes"
  [4] "body"
  [5] "polish_rounds"
  [6] "reason"
  [7] "topic"
  [8] "prior"
  [9] "draft"
  [10] "topic"
  [11] "max_polish_rounds"
  [12] "published"
  [13] "outcome"
  [14] ""
  [15] "DraftingOutcome"
  [16] "published"
  [17] "payload"
  [18] ""
  [19] "writing"
  [20] "writer"
  [21] "draft never stabilized"
  [22] "exhausted_draft"
  [23] "step `check` exceeded its `max … visits` bound at line 36, column 3"
  [24] "writing"
  [25] "reviewer"
== types ==
  record Draft tag=draft
    body: string
    ready: bool
  record Verdict tag=verdict
    approved: bool
    notes: string
  record Published tag=published
    body: string
    polish_rounds: int
  record Exhausted tag=exhausted
    reason: string
  record PolishInput tag=polish_input
    topic: string
    prior: ref(Draft)
  record ReviewInput tag=review_input
    draft: ref(Draft)
  record DraftingInput tag=drafting_input
    topic: string
    max_polish_rounds: int
  union DraftingOutcome
    published -> published_outcome(ref(Published))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=drafting_input_codec output=drafting_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(drafting.DraftingInput, drafting.DraftingOutcome, AwlError)
  T-DEF name="drafting" input=drafting_input_codec output=drafting_outcome_codec
== fn execute/1 origin=execute ==
  sig: (drafting.DraftingInput) -> Result(drafting.DraftingOutcome, AwlError)
  T-EXEC fields=[topic:String, max_polish_rounds:Int] entry=step_compose args=[zero, 1, 0]
== fn draft_codec/0 origin=codec_template(RecordTrio, Draft, record#0) ==
  sig: () -> Codec(drafting.Draft)
  v0 = make_closure draft_to_json captures=[]
  v1 = call_local draft_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
