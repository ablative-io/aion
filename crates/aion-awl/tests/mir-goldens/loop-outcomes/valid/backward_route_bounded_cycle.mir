  sig: () -> Codec(drafting.ReviewInput)
  v0 = make_closure review_input_to_json captures=[]
  v1 = call_local review_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn review_input_to_json/1 origin=codec_template(RecordTrio, ReviewInput, record#5) ==
  sig: (drafting.ReviewInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"draft": v1|>draft_to_json}
  return v2
== fn review_input_decoder/0 origin=codec_template(RecordTrio, ReviewInput, record#5) ==
  sig: () -> Decoder(drafting.ReviewInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
