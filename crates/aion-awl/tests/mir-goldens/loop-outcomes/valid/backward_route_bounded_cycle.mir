module drafting source=drafting.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_check:
    aion@activity:timeout/2 [activities] (v4, v5)
    aion@activity:task_queue/2 [activities] (v6, lit#5)
    aion@activity:node/2 [activities] (v7, lit#6)
    aion@workflow:run/1 [activities] (v8)
  compose_loop_0:
    aion@activity:timeout/2 [activities] (v4, v5)
    aion@activity:task_queue/2 [activities] (v6, lit#1)
    aion@activity:node/2 [activities] (v7, lit#2)
    aion@workflow:run/1 [activities] (v8)
== durable families == activities
== atoms ==
  [0] draft
  [1] verdict
  [2] published
  [3] exhausted
  [4] polish_input
  [5] review_input
  [6] drafting_input
  [7] published_outcome
  [8] false
  [9] ok
  [10] awl_outcome_failure
  [11] error
== types ==
  record Draft tag=draft
    body: string
    ready: bool
  record Verdict tag=verdict
    approved: bool
    notes: string
  record Published tag=published
    body: string
    polish_rounds: int
  record Exhausted tag=exhausted
    reason: string
  record PolishInput tag=polish_input
    topic: string
    prior: ref(Draft)
  record ReviewInput tag=review_input
    draft: ref(Draft)
  record DraftingInput tag=drafting_input
    topic: string
    max_polish_rounds: int
  union DraftingOutcome
    published -> published_outcome(ref(Published))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=drafting_input_codec output=drafting_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(drafting.DraftingInput, drafting.DraftingOutcome, AwlError)
  T-DEF name="drafting" input=drafting_input_codec output=drafting_outcome_codec
== fn execute/1 origin=execute ==
  sig: (drafting.DraftingInput) -> Result(drafting.DraftingOutcome, AwlError)
  T-EXEC fields=[topic:String, max_polish_rounds:Int] entry=step_compose args=[1, 0]
== fn draft_codec/0 origin=codec_template(RecordTrio, Draft, record#0) ==
  sig: () -> Codec(drafting.Draft)
  v0 = make_closure draft_to_json captures=[]
  v1 = call_local draft_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn draft_to_json/1 origin=codec_template(RecordTrio, Draft, record#0) ==
  sig: (drafting.Draft) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"body": v1|>awlc.string_to_json, "ready": v2|>awlc.bool_to_json}
  return v3
== fn draft_decoder/0 origin=codec_template(RecordTrio, Draft, record#0) ==
  sig: () -> Decoder(drafting.Draft)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn verdict_codec/0 origin=codec_template(RecordTrio, Verdict, record#1) ==
  sig: () -> Codec(drafting.Verdict)
  v0 = make_closure verdict_to_json captures=[]
  v1 = call_local verdict_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn verdict_to_json/1 origin=codec_template(RecordTrio, Verdict, record#1) ==
  sig: (drafting.Verdict) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"approved": v1|>awlc.bool_to_json, "notes": v2|>awlc.string_to_json}
  return v3
== fn verdict_decoder/0 origin=codec_template(RecordTrio, Verdict, record#1) ==
  sig: () -> Decoder(drafting.Verdict)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn published_codec/0 origin=codec_template(RecordTrio, Published, record#2) ==
  sig: () -> Codec(drafting.Published)
  v0 = make_closure published_to_json captures=[]
  v1 = call_local published_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn published_to_json/1 origin=codec_template(RecordTrio, Published, record#2) ==
  sig: (drafting.Published) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"body": v1|>awlc.string_to_json, "polish_rounds": v2|>awlc.int_to_json}
  return v3
== fn published_decoder/0 origin=codec_template(RecordTrio, Published, record#2) ==
  sig: () -> Decoder(drafting.Published)
  tail_rt gleam@dynamic@decode:success/1(nil)
