  sig: (float_threshold_guard.Published) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"score": v1|>awlc.float_to_json, "summary": v2|>awlc.string_to_json}
  return v3
== fn published_decoder/0 origin=codec_template(RecordTrio, Published, record#1) ==
  sig: () -> Decoder(float_threshold_guard.Published)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn rejected_codec/0 origin=codec_template(RecordTrio, Rejected, record#2) ==
  sig: () -> Codec(float_threshold_guard.Rejected)
  v0 = make_closure rejected_to_json captures=[]
  v1 = call_local rejected_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn rejected_to_json/1 origin=codec_template(RecordTrio, Rejected, record#2) ==
  sig: (float_threshold_guard.Rejected) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"summary": v1|>awlc.string_to_json}
  return v2
== fn rejected_decoder/0 origin=codec_template(RecordTrio, Rejected, record#2) ==
  sig: () -> Decoder(float_threshold_guard.Rejected)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn grade_input_codec/0 origin=codec_template(RecordTrio, GradeInput, record#3) ==
  sig: () -> Codec(float_threshold_guard.GradeInput)
  v0 = make_closure grade_input_to_json captures=[]
  v1 = call_local grade_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn grade_input_to_json/1 origin=codec_template(RecordTrio, GradeInput, record#3) ==
  sig: (float_threshold_guard.GradeInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"essay": v1|>awlc.string_to_json}
  return v2
== fn grade_input_decoder/0 origin=codec_template(RecordTrio, GradeInput, record#3) ==
  sig: () -> Decoder(float_threshold_guard.GradeInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
