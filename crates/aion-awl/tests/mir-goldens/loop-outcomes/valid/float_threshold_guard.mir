  sig: () -> Codec(float_threshold_guard.FloatThresholdGuardInput)
  v0 = make_closure float_threshold_guard_input_to_json captures=[]
  v1 = call_local float_threshold_guard_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn float_threshold_guard_input_to_json/1 origin=codec_template(RecordTrio, FloatThresholdGuardInput, record#4) ==
  sig: (float_threshold_guard.FloatThresholdGuardInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"essay": v1|>awlc.string_to_json}
  return v2
