module float_threshold_guard source=float_threshold_guard.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_grade:
    aion@activity:timeout/2 [activities] (v1, v2)
    aion@activity:task_queue/2 [activities] (v3, lit#0)
    aion@activity:node/2 [activities] (v4, lit#1)
    aion@workflow:run/1 [activities] (v5)
== durable families == activities
== atoms ==
  [0] verdict
  [1] published
  [2] rejected
  [3] grade_input
  [4] float_threshold_guard_input
  [5] published_outcome
  [6] ok
  [7] awl_outcome_failure
  [8] error
== types ==
  record Verdict tag=verdict
    score: float
    summary: string
  record Published tag=published
    score: float
    summary: string
  record Rejected tag=rejected
    summary: string
  record GradeInput tag=grade_input
    essay: string
  record FloatThresholdGuardInput tag=float_threshold_guard_input
    essay: string
  union FloatThresholdGuardOutcome
    published -> published_outcome(ref(Published))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=float_threshold_guard_input_codec output=float_threshold_guard_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(float_threshold_guard.FloatThresholdGuardInput, float_threshold_guard.FloatThresholdGuardOutcome, AwlError)
  T-DEF name="float_threshold_guard" input=float_threshold_guard_input_codec output=float_threshold_guard_outcome_codec
== fn execute/1 origin=execute ==
  sig: (float_threshold_guard.FloatThresholdGuardInput) -> Result(float_threshold_guard.FloatThresholdGuardOutcome, AwlError)
  T-EXEC fields=[essay:String] entry=step_grade args=[0]
== fn verdict_codec/0 origin=codec_template(RecordTrio, Verdict, record#0) ==
  sig: () -> Codec(float_threshold_guard.Verdict)
  v0 = make_closure verdict_to_json captures=[]
  v1 = call_local verdict_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn verdict_to_json/1 origin=codec_template(RecordTrio, Verdict, record#0) ==
  sig: (float_threshold_guard.Verdict) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"score": v1|>awlc.float_to_json, "summary": v2|>awlc.string_to_json}
  return v3
== fn verdict_decoder/0 origin=codec_template(RecordTrio, Verdict, record#0) ==
  sig: () -> Decoder(float_threshold_guard.Verdict)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn published_codec/0 origin=codec_template(RecordTrio, Published, record#1) ==
  sig: () -> Codec(float_threshold_guard.Published)
  v0 = make_closure published_to_json captures=[]
  v1 = call_local published_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
