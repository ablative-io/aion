  sig: () -> Decoder(float_threshold_guard.FloatThresholdGuardInput)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn float_threshold_guard_outcome_codec/0 origin=codec_template(UnionTrio, FloatThresholdGuardOutcome, union#5) ==
  sig: () -> Codec(float_threshold_guard.FloatThresholdGuardOutcome)
  v0 = make_closure float_threshold_guard_outcome_to_json captures=[]
  v1 = call_local float_threshold_guard_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn float_threshold_guard_outcome_to_json/1 origin=codec_template(UnionTrio, FloatThresholdGuardOutcome, union#5) ==
  sig: (float_threshold_guard.FloatThresholdGuardOutcome) -> Json
  v1 = json_obj {}
  return v1
== fn float_threshold_guard_outcome_decoder/0 origin=codec_template(UnionTrio, FloatThresholdGuardOutcome, union#5) ==
  sig: () -> Decoder(float_threshold_guard.FloatThresholdGuardOutcome)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn grade_activity/1 origin=activity_wrapper(grade, raw=false) ==
  sig: (String) -> Activity(float_threshold_guard.GradeInput, float_threshold_guard.Verdict)
  T-ACT action=grade input_codec=grade_input_codec return=verdict_codec
== fn step_grade/1 origin=region(grade) ==
  sig: (String) -> Result(float_threshold_guard.FloatThresholdGuardOutcome, AwlError)
  v1 = call_local grade_activity(v0)
  v2 = call_rt aion@duration:milliseconds/1(300000) live_after=[v1]
  v3 = call_rt aion@activity:timeout/2(v1, v2)
  v4 = call_rt aion@activity:task_queue/2(v3, lit#0)
  v5 = call_rt aion@activity:node/2(v4, lit#1)
  v6 = call_rt aion@workflow:run/1(v5)
  v7 = call_rt aion@awl@error:map_activity_error/1(v6)
  v8 = try_bind v7
  v10 = field(v8, 1)
  v9 = cmp FGt v10 lit#2
  if is_true v9:
    v11 = field(v8, 1)
    v12 = field(v8, 2)
    v13 = record(published, [v11, v12])
    v14 = record(published_outcome, [v13])
    v15 = record(ok, [v14])
    return v15
  else:
    v16 = field(v8, 2)
    v17 = record(rejected, [v16])
    v18 = call_local rejected_to_json(v17)
    v19 = call_rt gleam@json:to_string/1(v18)
    v20 = record(awl_outcome_failure, [lit#3, v19])
    v21 = record(error, [v20])
    return v21
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
