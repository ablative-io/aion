module chained_polish source=chained_polish.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_outline:
    aion@activity:timeout/2 [activities] (v2, v3)
    aion@activity:task_queue/2 [activities] (v4, lit#15)
    aion@activity:node/2 [activities] (v5, lit#16)
    aion@workflow:run/1 [activities] (v6)
  polish_loop_0:
    aion@activity:timeout/2 [activities] (v3, v4)
    aion@activity:task_queue/2 [activities] (v5, lit#17)
    aion@activity:node/2 [activities] (v6, lit#18)
    aion@workflow:run/1 [activities] (v7)
== durable families == activities
== atoms ==
  [0] draft
  [1] polished
  [2] ran_out
  [3] outline_input
  [4] refine_input
  [5] chained_polish_input
  [6] polished_outcome
  [7] ok
  [8] awl_outcome_failure
  [9] error
== literals ==
  [0] "body"
  [1] "ready"
  [2] "body"
  [3] "rounds"
  [4] "reason"
  [5] "topic"
  [6] "prior"
  [7] "topic"
  [8] "rounds_cap"
  [9] "polished"
  [10] "outcome"
  [11] ""
  [12] "ChainedPolishOutcome"
  [13] "polished"
  [14] "payload"
  [15] "writing"
  [16] "writer"
  [17] "writing"
  [18] "writer"
  [19] "the draft never settled"
  [20] "ran_out"
== types ==
  record Draft tag=draft
    body: string
    ready: bool
  record Polished tag=polished
    body: string
    rounds: int
  record RanOut tag=ran_out
    reason: string
  record OutlineInput tag=outline_input
    topic: string
  record RefineInput tag=refine_input
    prior: ref(Draft)
  record ChainedPolishInput tag=chained_polish_input
    topic: string
    rounds_cap: int
  union ChainedPolishOutcome
    polished -> polished_outcome(ref(Polished))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=chained_polish_input_codec output=chained_polish_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(chained_polish.ChainedPolishInput, chained_polish.ChainedPolishOutcome, AwlError)
  T-DEF name="chained_polish" input=chained_polish_input_codec output=chained_polish_outcome_codec
== fn execute/1 origin=execute ==
  sig: (chained_polish.ChainedPolishInput) -> Result(chained_polish.ChainedPolishOutcome, AwlError)
  T-EXEC fields=[topic:String, rounds_cap:Int] entry=step_outline args=[1, 0]
