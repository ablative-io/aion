== fn chained_polish_outcome_decoder$outcome/1 origin=lifted(chained_polish_outcome_decoder, #0) ==
  sig: (String) -> Decoder(chained_polish.ChainedPolishOutcome)
  if cmp Eq v0 lit#13:
    v3 = call_local polished_decoder()
    v4 = make_closure chained_polish_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#14, v3, v4)
  else:
    v1 = record(polished, [lit#11, 0])
    v2 = record(polished_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#12)
