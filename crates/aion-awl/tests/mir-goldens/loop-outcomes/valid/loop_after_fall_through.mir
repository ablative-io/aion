  sig: () -> Codec(chained_polish.Draft)
  v0 = make_closure draft_to_json captures=[]
  v1 = call_local draft_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn draft_to_json/1 origin=codec_template(RecordTrio, Draft, record#0) ==
  sig: (chained_polish.Draft) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"body": v1|>awlc.string_to_json, "ready": v2|>awlc.bool_to_json}
  return v3
