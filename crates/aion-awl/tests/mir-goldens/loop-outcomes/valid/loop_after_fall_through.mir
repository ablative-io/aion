  tail_rt gleam@dynamic@decode:success/1(v1)
== fn outline_activity/1 origin=activity_wrapper(outline, raw=false) ==
  sig: (String) -> Activity(chained_polish.OutlineInput, chained_polish.Draft)
  T-ACT action=outline input_codec=outline_input_codec return=draft_codec
== fn refine_activity/1 origin=activity_wrapper(refine, raw=false) ==
  sig: (chained_polish.Draft) -> Activity(chained_polish.RefineInput, chained_polish.Draft)
  T-ACT action=refine input_codec=refine_input_codec return=draft_codec
== fn step_outline/2 origin=region(outline) ==
  sig: (Int, String) -> Result(chained_polish.ChainedPolishOutcome, AwlError)
  v2 = call_local outline_activity(v1) live_after=[v0]
  v3 = call_rt aion@duration:milliseconds/1(300000) live_after=[v0, v2]
  v4 = call_rt aion@activity:timeout/2(v2, v3) live_after=[v0]
  v5 = call_rt aion@activity:task_queue/2(v4, lit#15) live_after=[v0]
  v6 = call_rt aion@activity:node/2(v5, lit#16) live_after=[v0]
  v7 = call_rt aion@workflow:run/1(v6) live_after=[v0]
  v8 = call_rt aion@awl@error:map_activity_error/1(v7) live_after=[v0]
  v9 = try_bind v8 live_after=[v0]
  tail_local step_polish(v0, v9)
== fn step_polish/2 origin=chain_step(outline.polish) ==
  sig: (Int, chained_polish.Draft) -> Result(chained_polish.ChainedPolishOutcome, AwlError)
  v2 = call_local polish_loop_0(v1, 0, v0)
  v3 = try_bind v2
  v4 = field(v3, 0)
  v5 = field(v3, 1)
  v6 = field(v4, 2)
  if is_true v6:
    v7 = field(v4, 1)
    v8 = record(polished, [v7, v5])
    v9 = record(polished_outcome, [v8])
    v10 = record(ok, [v9])
    return v10
  else:
    v11 = record(ran_out, [lit#19])
    v12 = call_local ran_out_to_json(v11)
    v13 = call_rt gleam@json:to_string/1(v12)
    v14 = record(awl_outcome_failure, [lit#20, v13])
    v15 = record(error, [v14])
    return v15
== fn polish_loop_0/3 origin=loop(polish#0) ==
  sig: (chained_polish.Draft, Int, Int) -> Result(#(chained_polish.Draft, Int), AwlError)
  v3 = call_local refine_activity(v0) live_after=[v1, v2]
  v4 = call_rt aion@duration:milliseconds/1(300000) live_after=[v1, v2, v3]
  v5 = call_rt aion@activity:timeout/2(v3, v4) live_after=[v1, v2]
  v6 = call_rt aion@activity:task_queue/2(v5, lit#17) live_after=[v1, v2]
  v7 = call_rt aion@activity:node/2(v6, lit#18) live_after=[v1, v2]
  v8 = call_rt aion@workflow:run/1(v7) live_after=[v1, v2]
  v9 = call_rt aion@awl@error:map_activity_error/1(v8) live_after=[v1, v2]
  v10 = try_bind v9 live_after=[v1, v2]
  v11 = increment v1
  v14 = field(v10, 2)
  if is_true v14:
    v12 = tuple([v10, v11])
    v13 = record(ok, [v12])
    return v13
  else:
    if cmp Ge v11 v2:
      v12 = tuple([v10, v11])
      v13 = record(ok, [v12])
      return v13
    else:
      tail_local polish_loop_0(v10, v11, v2)
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
