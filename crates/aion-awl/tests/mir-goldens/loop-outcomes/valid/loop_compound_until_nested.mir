module settle_draft source=settle_draft.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  settle_loop_0:
    aion@activity:task_queue/2 [activities] (v6, lit#21)
    aion@workflow:run/1 [activities] (v7)
  settle_loop_1:
    aion@activity:task_queue/2 [activities] (v3, lit#20)
    aion@workflow:run/1 [activities] (v4)
== durable families == activities
== atoms ==
  [0] detail
  [1] draft
  [2] summary
  [3] inspect_input
  [4] revise_input
  [5] settle_draft_input
  [6] settled_outcome
  [7] some
  [8] none
  [9] false
  [10] ok
  [11] awl_outcome_failure
  [12] error
== literals ==
  [0] "approved"
  [1] "body"
  [2] "ready"
  [3] "detail"
  [4] "body"
  [5] "ready"
  [6] "detail"
  [7] "body"
  [8] "rounds"
  [9] "prior"
  [10] "prior"
  [11] "max_rounds"
  [12] "max_checks"
  [13] "settled"
  [14] "outcome"
  [15] ""
  [16] "SettleDraftOutcome"
  [17] "settled"
  [18] "payload"
  [19] ""
  [20] "reviewer"
  [21] "reviewer"
  [22] "done"
  [23] "exhausted"
== types ==
  record Detail tag=detail
    approved: bool
  record Draft tag=draft
    body: string
    ready: bool
    detail: nullable(ref(Detail)) optional
  record Summary tag=summary
    body: string
    rounds: int
  record InspectInput tag=inspect_input
    prior: ref(Draft)
  record ReviseInput tag=revise_input
    prior: ref(Draft)
  record SettleDraftInput tag=settle_draft_input
    max_rounds: int
    max_checks: int
  union SettleDraftOutcome
    settled -> settled_outcome(ref(Summary))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=settle_draft_input_codec output=settle_draft_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(settle_draft.SettleDraftInput, settle_draft.SettleDraftOutcome, AwlError)
  T-DEF name="settle_draft" input=settle_draft_input_codec output=settle_draft_outcome_codec
== fn execute/1 origin=execute ==
  sig: (settle_draft.SettleDraftInput) -> Result(settle_draft.SettleDraftOutcome, AwlError)
  T-EXEC fields=[max_rounds:Int, max_checks:Int] entry=step_settle args=[1, 0]
