== fn step_settle/2 origin=region(settle) ==
  sig: (Int, Int) -> Result(settle_draft.SettleDraftOutcome, AwlError)
  v2 = record(draft, [lit#19, 'false', 'none'])
  v3 = call_local settle_loop_0(v2, 0, v1, v0)
  v4 = try_bind v3
  v5 = field(v4, 0)
  v6 = field(v4, 1)
  v7 = field(v5, 2)
  if is_true v7:
    v8 = field(v5, 1)
    v9 = record(summary, [v8, v6])
    v10 = record(settled_outcome, [v9])
    v11 = record(ok, [v10])
    return v11
  else:
    v12 = field(v5, 1)
    v13 = record(summary, [v12, v6])
    v14 = call_local summary_to_json(v13)
    v15 = call_rt gleam@json:to_string/1(v14)
    v16 = record(awl_outcome_failure, [lit#23, v15])
    v17 = record(error, [v16])
    return v17
== fn settle_loop_0/4 origin=loop(settle#0) ==
  sig: (settle_draft.Draft, Int, Int, Int) -> Result(#(settle_draft.Draft, Int), AwlError)
  v4 = call_local settle_loop_1(v0, 0, v3) live_after=[v1, v2, v3]
  v5 = try_bind v4 live_after=[v1, v2, v3]
  v6 = call_local revise_activity(v5) live_after=[v1, v2, v3]
  v7 = call_rt aion@activity:task_queue/2(v6, lit#21) live_after=[v1, v2, v3]
  v8 = call_rt aion@workflow:run/1(v7) live_after=[v1, v2, v3]
  v9 = call_rt aion@awl@error:map_activity_error/1(v8) live_after=[v1, v2, v3]
  v10 = try_bind v9 live_after=[v1, v2, v3]
  v11 = increment v1
  v14 = field(v10, 2)
  if is_true v14:
    v16 = field(v10, 1)
    v15 = cmp Eq v16 lit#22
    if is_true v15:
      v12 = tuple([v10, v11])
      v13 = record(ok, [v12])
      return v13
    else:
      if cmp Ge v11 v2:
        v12 = tuple([v10, v11])
        v13 = record(ok, [v12])
        return v13
      else:
        tail_local settle_loop_0(v10, v11, v2, v3)
  else:
    if cmp Ge v11 v2:
      v12 = tuple([v10, v11])
      v13 = record(ok, [v12])
      return v13
    else:
      tail_local settle_loop_0(v10, v11, v2, v3)
== fn settle_loop_1/3 origin=loop(settle#1) ==
  sig: (settle_draft.Draft, Int, Int) -> Result(settle_draft.Draft, AwlError)
  v3 = call_local inspect_activity(v0) live_after=[v1, v2]
  v4 = call_rt aion@activity:task_queue/2(v3, lit#20) live_after=[v1, v2]
  v5 = call_rt aion@workflow:run/1(v4) live_after=[v1, v2]
  v6 = call_rt aion@awl@error:map_activity_error/1(v5) live_after=[v1, v2]
  v7 = try_bind v6 live_after=[v1, v2]
  v8 = field(v7, 3)
  v9 = increment v1
  v11 = cmp Eq v8 'none'
  if is_true v11:
    v10 = record(ok, [v7])
    return v10
  else:
    v12 = assert_some v8
    v13 = field(v12, 1)
    if is_true v13:
      v10 = record(ok, [v7])
      return v10
    else:
      if cmp Ge v9 v2:
        v10 = record(ok, [v7])
        return v10
      else:
        tail_local settle_loop_1(v7, v9, v2)
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
