== fn poll_job_outcome_decoder$outcome/1 origin=lifted(poll_job_outcome_decoder, #0) ==
  sig: (String) -> Decoder(poll_job.PollJobOutcome)
  if cmp Eq v0 lit#14:
    v3 = call_local finished_decoder()
    v4 = make_closure poll_job_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#15, v3, v4)
  else:
    v1 = record(finished, [lit#12, 0])
    v2 = record(finished_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#13)
