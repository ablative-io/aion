module fork_in_loop_live_ins source=fork_in_loop_live_ins.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_prepare_batch:
    aion@activity:task_queue/2 [activities] (v2, lit#15)
    aion@workflow:run/1 [activities] (v3)
  review_rounds_loop_0:
    aion@workflow:map/2 [activities] (v4, v5)
    aion@activity:task_queue/2 [activities] (v9, lit#17)
    aion@workflow:run/1 [activities] (v10)
  review_rounds_fork_0:
    aion@activity:task_queue/2 [activities] (v1, lit#16)
== durable families == activities
== atoms ==
  [0] batch
  [1] verdict
  [2] round
  [3] summary
  [4] fold_input
  [5] inspect_input
  [6] prepare_input
  [7] fork_in_loop_live_ins_input
  [8] completed_outcome
  [9] false
  [10] ok
  [11] awl_outcome_failure
  [12] error
== literals ==
  [0] "items"
  [1] "blocking"
  [2] "complete"
  [3] "complete"
  [4] "prior"
  [5] "verdicts"
  [6] "item"
  [7] "items"
  [8] "items"
  [9] "max_rounds"
  [10] "completed"
  [11] "outcome"
  [12] "ForkInLoopLiveInsOutcome"
  [13] "completed"
  [14] "payload"
  [15] "review"
  [16] "review"
  [17] "review"
  [18] "exhausted"
== types ==
  record Batch tag=batch
    items: list(string)
  record Verdict tag=verdict
    blocking: bool
  record Round tag=round
    complete: bool
  record Summary tag=summary
    complete: bool
  record FoldInput tag=fold_input
    prior: ref(Round)
    verdicts: list(ref(Verdict))
  record InspectInput tag=inspect_input
    item: string
  record PrepareInput tag=prepare_input
    items: list(string)
  record ForkInLoopLiveInsInput tag=fork_in_loop_live_ins_input
    items: list(string)
    max_rounds: int
  union ForkInLoopLiveInsOutcome
    completed -> completed_outcome(ref(Summary))
