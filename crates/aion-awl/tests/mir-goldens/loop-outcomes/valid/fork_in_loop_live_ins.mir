== fn step_prepare_batch/2 origin=region(prepare_batch) ==
  sig: (List(String), Int) -> Result(fork_in_loop_live_ins.ForkInLoopLiveInsOutcome, AwlError)
  v2 = call_local prepare_activity(v0) live_after=[v1]
  v3 = call_rt aion@activity:task_queue/2(v2, lit#15) live_after=[v1]
  v4 = call_rt aion@workflow:run/1(v3) live_after=[v1]
  v5 = call_rt aion@awl@error:map_activity_error/1(v4) live_after=[v1]
  v6 = try_bind v5 live_after=[v1]
  tail_local step_review_rounds(v6, v1)
== fn step_review_rounds/2 origin=chain_step(prepare_batch.review_rounds) ==
  sig: (fork_in_loop_live_ins.Batch, Int) -> Result(fork_in_loop_live_ins.ForkInLoopLiveInsOutcome, AwlError)
  v2 = record(round, ['false'])
  v3 = call_local review_rounds_loop_0(v2, 0, v1, v0)
  v4 = try_bind v3
  v5 = field(v4, 1)
  if is_true v5:
    v6 = field(v4, 1)
    v7 = record(summary, [v6])
    v8 = record(completed_outcome, [v7])
    v9 = record(ok, [v8])
    return v9
  else:
    v10 = field(v4, 1)
    v11 = record(summary, [v10])
    v12 = call_local summary_to_json(v11)
    v13 = call_rt gleam@json:to_string/1(v12)
    v14 = record(awl_outcome_failure, [lit#18, v13])
    v15 = record(error, [v14])
    return v15
== fn review_rounds_loop_0/4 origin=loop(review_rounds#0) ==
  sig: (fork_in_loop_live_ins.Round, Int, Int, fork_in_loop_live_ins.Batch) -> Result(fork_in_loop_live_ins.Round, AwlError)
  v4 = field(v3, 1)
  v5 = make_closure review_rounds_fork_0 captures=[]
  v6 = call_rt aion@workflow:map/2(v4, v5) live_after=[v0, v1, v2, v3]
  v7 = call_rt aion@awl@error:map_activity_error/1(v6) live_after=[v0, v1, v2, v3]
  v8 = try_bind v7 live_after=[v0, v1, v2, v3]
  v9 = call_local fold_activity(v0, v8) live_after=[v1, v2, v3, v8]
  v10 = call_rt aion@activity:task_queue/2(v9, lit#17) live_after=[v1, v2, v3, v8]
  v11 = call_rt aion@workflow:run/1(v10) live_after=[v1, v2, v3, v8]
  v12 = call_rt aion@awl@error:map_activity_error/1(v11) live_after=[v1, v2, v3, v8]
  v13 = try_bind v12 live_after=[v1, v2, v3, v8]
  v14 = increment v1
  v16 = cmp Eq v8 nil
  if is_true v16:
    v15 = record(ok, [v13])
    return v15
  else:
    if cmp Ge v14 v2:
      v15 = record(ok, [v13])
      return v15
    else:
      tail_local review_rounds_loop_0(v13, v14, v2, v3)
== fn review_rounds_fork_0/1 origin=fork(review_rounds#0) ==
  sig: (String) -> Activity(fork_in_loop_live_ins.InspectInput, fork_in_loop_live_ins.Verdict)
  v1 = call_local inspect_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#16)
  return v2
