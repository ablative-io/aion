== fn step_check_all/1 origin=region(check_all) ==
  sig: (List(fork_collection_join.Doc)) -> Result(fork_collection_join.ForkCollectionJoinOutcome, AwlError)
  v1 = make_closure check_all_fork_0 captures=[]
  v2 = call_rt aion@workflow:map/2(v0, v1)
  v3 = call_rt aion@awl@error:map_activity_error/1(v2)
  v4 = try_bind v3
  v5 = call_rt gleam@list:length/1(v4) live_after=[v4]
  v6 = make_closure awl_combinator_0 captures=[]
  v7 = call_rt gleam@list:filter/2(v4, v6) live_after=[v5]
  v8 = cmp Eq v7 nil
  if is_true v8:
    v9 = record(clean, [v5])
    v10 = record(clean_outcome, [v9])
    v11 = record(ok, [v10])
    return v11
  else:
    v12 = record(flagged, [v7])
    v13 = call_local flagged_to_json(v12)
    v14 = call_rt gleam@json:to_string/1(v13)
    v15 = record(awl_outcome_failure, [lit#14, v14])
    v16 = record(error, [v15])
    return v16
