  [14] "flagged"
== types ==
  record Doc tag=doc
    title: string
    body: string
  record Verdict tag=verdict
    title: string
    failing: bool
  record Clean tag=clean
    total: int
  record Flagged tag=flagged
    failures: list(ref(Verdict))
  record CheckDocInput tag=check_doc_input
    doc: ref(Doc)
  record ForkCollectionJoinInput tag=fork_collection_join_input
    docs: list(ref(Doc))
  union ForkCollectionJoinOutcome
    clean -> clean_outcome(ref(Clean))
