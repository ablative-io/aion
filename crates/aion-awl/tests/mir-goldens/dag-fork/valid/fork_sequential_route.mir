  sig: (fork_sequential_route.Applied) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"receipts": v1|>awlc.nil_to_json}
  return v2
== fn applied_decoder/0 origin=codec_template(RecordTrio, Applied, record#2) ==
  sig: () -> Decoder(fork_sequential_route.Applied)
  tail_rt gleam@dynamic@decode:success/1(nil)
== fn apply_one_input_codec/0 origin=codec_template(RecordTrio, ApplyOneInput, record#3) ==
  sig: () -> Codec(fork_sequential_route.ApplyOneInput)
  v0 = make_closure apply_one_input_to_json captures=[]
  v1 = call_local apply_one_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
