  sig: (fork_sequential_route.Receipt) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"name": v1|>awlc.string_to_json, "ok": v2|>awlc.bool_to_json}
  return v3
== fn receipt_decoder/0 origin=codec_template(RecordTrio, Receipt, record#1) ==
  sig: () -> Decoder(fork_sequential_route.Receipt)
  tail_rt gleam@dynamic@decode:success/1(nil)
