module fork_sequential_route source=fork_sequential_route.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  apply_all_fork_0:
    aion@activity:task_queue/2 [activities] (v2, lit#12)
    aion@workflow:run/1 [activities] (v3)
== durable families == activities
== atoms ==
  [0] migration
  [1] receipt
  [2] applied
  [3] apply_one_input
  [4] fork_sequential_route_input
  [5] applied_outcome
  [6] ok
== literals ==
  [0] "name"
  [1] "sql"
  [2] "name"
  [3] "ok"
  [4] "receipts"
  [5] "migration"
  [6] "migrations"
  [7] "applied"
  [8] "outcome"
  [9] "ForkSequentialRouteOutcome"
  [10] "applied"
  [11] "payload"
  [12] "db"
== types ==
  record Migration tag=migration
    name: string
    sql: string
  record Receipt tag=receipt
    name: string
    ok: bool
  record Applied tag=applied
    receipts: list(ref(Receipt))
  record ApplyOneInput tag=apply_one_input
    migration: ref(Migration)
  record ForkSequentialRouteInput tag=fork_sequential_route_input
    migrations: list(ref(Migration))
  union ForkSequentialRouteOutcome
    applied -> applied_outcome(ref(Applied))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fork_sequential_route_input_codec output=fork_sequential_route_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(fork_sequential_route.ForkSequentialRouteInput, fork_sequential_route.ForkSequentialRouteOutcome, AwlError)
  T-DEF name="fork_sequential_route" input=fork_sequential_route_input_codec output=fork_sequential_route_outcome_codec
== fn execute/1 origin=execute ==
  sig: (fork_sequential_route.ForkSequentialRouteInput) -> Result(fork_sequential_route.ForkSequentialRouteOutcome, AwlError)
  T-EXEC fields=[migrations:List(fork_sequential_route.Migration)] entry=step_apply_all args=[0]
