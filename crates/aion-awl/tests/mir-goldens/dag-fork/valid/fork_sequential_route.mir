  sig: () -> Codec(fork_sequential_route.ForkSequentialRouteInput)
  v0 = make_closure fork_sequential_route_input_to_json captures=[]
  v1 = call_local fork_sequential_route_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
