== fn apply_one_activity/1 origin=activity_wrapper(apply_one, raw=false) ==
  sig: (sequential_migrations.Migration) -> Activity(sequential_migrations.ApplyOneInput, sequential_migrations.Receipt)
  T-ACT action=apply_one input_codec=apply_one_input_codec return=receipt_codec
== fn step_apply_all/1 origin=region(apply_all) ==
  sig: (List(sequential_migrations.Migration)) -> Result(sequential_migrations.SequentialMigrationsOutcome, AwlError)
  v1 = make_closure apply_all_fork_0 captures=[]
  v2 = call_rt gleam@list:try_fold/3(v0, nil, v1)
  v3 = try_bind v2
  v4 = call_rt gleam@list:reverse/1(v3)
  v5 = call_rt gleam@list:length/1(v4) live_after=[v4]
  v6 = make_closure awl_combinator_0 captures=[]
  v7 = call_rt gleam@list:filter/2(v4, v6) live_after=[v5]
  v8 = call_rt gleam@list:length/1(v7) live_after=[v5]
  v9 = cmp Eq v8 v5
  if is_true v9:
    v10 = record(applied, [v8])
    v11 = record(applied_outcome, [v10])
    v12 = record(ok, [v11])
    return v12
  else:
    v13 = record(stalled, [v8])
    v14 = call_local stalled_to_json(v13)
    v15 = call_rt gleam@json:to_string/1(v14)
    v16 = record(awl_outcome_failure, [lit#14, v15])
    v17 = record(error, [v16])
    return v17
== fn apply_all_fork_0/2 origin=fork(apply_all#0) ==
  sig: (List(sequential_migrations.Receipt), sequential_migrations.Migration) -> Result(List(sequential_migrations.Receipt), AwlError)
  v2 = call_local apply_one_activity(v1) live_after=[v0]
  v3 = call_rt aion@activity:task_queue/2(v2, lit#13) live_after=[v0]
  v4 = call_rt aion@workflow:run/1(v3) live_after=[v0]
  v5 = call_rt aion@awl@error:map_activity_error/1(v4) live_after=[v0]
  v6 = try_bind v5 live_after=[v0]
  v7 = cons v6 v0
  v8 = record(ok, [v7])
  return v8
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
== fn awl_combinator_0/1 origin=lifted(execute, #0) ==
  sig: (sequential_migrations.Receipt) -> Bool
  v1 = field(v0, 2)
  return v1
