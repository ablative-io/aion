module sequential_migrations source=sequential_migrations.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  apply_all_fork_0:
    aion@activity:task_queue/2 [activities] (v2, lit#13)
    aion@workflow:run/1 [activities] (v3)
== durable families == activities
== atoms ==
  [0] migration
  [1] receipt
  [2] applied
  [3] stalled
  [4] apply_one_input
  [5] sequential_migrations_input
  [6] applied_outcome
  [7] ok
  [8] awl_outcome_failure
  [9] error
== literals ==
  [0] "name"
  [1] "sql"
  [2] "name"
  [3] "ok"
  [4] "count"
  [5] "completed"
  [6] "migration"
  [7] "migrations"
  [8] "applied"
  [9] "outcome"
  [10] "SequentialMigrationsOutcome"
  [11] "applied"
  [12] "payload"
  [13] "db"
  [14] "stalled"
== types ==
  record Migration tag=migration
    name: string
    sql: string
  record Receipt tag=receipt
    name: string
    ok: bool
  record Applied tag=applied
    count: int
  record Stalled tag=stalled
    completed: int
  record ApplyOneInput tag=apply_one_input
    migration: ref(Migration)
  record SequentialMigrationsInput tag=sequential_migrations_input
    migrations: list(ref(Migration))
  union SequentialMigrationsOutcome
    applied -> applied_outcome(ref(Applied))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=sequential_migrations_input_codec output=sequential_migrations_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(sequential_migrations.SequentialMigrationsInput, sequential_migrations.SequentialMigrationsOutcome, AwlError)
  T-DEF name="sequential_migrations" input=sequential_migrations_input_codec output=sequential_migrations_outcome_codec
== fn execute/1 origin=execute ==
  sig: (sequential_migrations.SequentialMigrationsInput) -> Result(sequential_migrations.SequentialMigrationsOutcome, AwlError)
  T-EXEC fields=[migrations:List(sequential_migrations.Migration)] entry=step_apply_all args=[0]
