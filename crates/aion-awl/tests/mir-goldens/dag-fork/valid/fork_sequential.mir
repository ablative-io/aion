  sig: (sequential_migrations.Migration) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"name": v1|>awlc.string_to_json, "sql": v2|>awlc.string_to_json}
  return v3
