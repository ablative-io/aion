== fn sequential_migrations_outcome_decoder$outcome/1 origin=lifted(sequential_migrations_outcome_decoder, #0) ==
  sig: (String) -> Decoder(sequential_migrations.SequentialMigrationsOutcome)
  if cmp Eq v0 lit#11:
    v3 = call_local applied_decoder()
    v4 = make_closure sequential_migrations_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#12, v3, v4)
  else:
    v1 = record(applied, [0])
    v2 = record(applied_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#10)
