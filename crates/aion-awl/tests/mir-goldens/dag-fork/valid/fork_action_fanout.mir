module fork_action_fanout source=fork_action_fanout.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_fan_out:
    aion@workflow:map/2 [activities] (v0, v2)
  fan_out_fork_0:
    aion@activity:task_queue/2 [activities] (v2, lit#14)
== durable families == activities
== atoms ==
  [0] half
  [1] report
  [2] reviewed
  [3] review_half_input
  [4] fork_action_fanout_input
  [5] reviewed_outcome
  [6] ok
== literals ==
  [0] "name"
  [1] "body"
  [2] "name"
  [3] "ok"
  [4] "reports"
  [5] "half"
  [6] "revision"
  [7] "halves"
  [8] "revision"
  [9] "reviewed"
  [10] "outcome"
  [11] "ForkActionFanoutOutcome"
  [12] "reviewed"
  [13] "payload"
  [14] "review"
== types ==
  record Half tag=half
    name: string
    body: string
  record Report tag=report
    name: string
    ok: bool
  record Reviewed tag=reviewed
    reports: list(ref(Report))
  record ReviewHalfInput tag=review_half_input
    half: ref(Half)
    revision: string
  record ForkActionFanoutInput tag=fork_action_fanout_input
    halves: list(ref(Half))
    revision: string
  union ForkActionFanoutOutcome
    reviewed -> reviewed_outcome(ref(Reviewed))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fork_action_fanout_input_codec output=fork_action_fanout_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(fork_action_fanout.ForkActionFanoutInput, fork_action_fanout.ForkActionFanoutOutcome, AwlError)
  T-DEF name="fork_action_fanout" input=fork_action_fanout_input_codec output=fork_action_fanout_outcome_codec
== fn execute/1 origin=execute ==
  sig: (fork_action_fanout.ForkActionFanoutInput) -> Result(fork_action_fanout.ForkActionFanoutOutcome, AwlError)
  T-EXEC fields=[halves:List(fork_action_fanout.Half), revision:String] entry=step_fan_out args=[0, 1]
