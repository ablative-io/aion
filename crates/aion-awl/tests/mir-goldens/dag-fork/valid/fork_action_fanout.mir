== fn step_fan_out/2 origin=region(fan_out) ==
  sig: (List(fork_action_fanout.Half), String) -> Result(fork_action_fanout.ForkActionFanoutOutcome, AwlError)
  v2 = make_closure fan_out_fork_0 captures=[v1]
  v3 = call_rt aion@workflow:map/2(v0, v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  v6 = record(reviewed, [v5])
  v7 = record(reviewed_outcome, [v6])
  v8 = record(ok, [v7])
  return v8
== fn fan_out_fork_0/2 origin=fork(fan_out#0) ==
  sig: (fork_action_fanout.Half, String) -> Activity(fork_action_fanout.ReviewHalfInput, fork_action_fanout.Report)
  v2 = call_local review_half_activity(v0, v1)
  v3 = call_rt aion@activity:task_queue/2(v2, lit#14)
  return v3
