== fn step_check_all/1 origin=region(check_all) ==
  sig: (List(empty_fork_collection.Doc)) -> Result(empty_fork_collection.EmptyForkCollectionOutcome, AwlError)
  v1 = make_closure check_all_fork_0 captures=[]
  v2 = call_rt aion@workflow:map/2(v0, v1)
  v3 = call_rt aion@awl@error:map_activity_error/1(v2)
  v4 = try_bind v3
  v5 = call_rt gleam@list:length/1(v4)
  v6 = record(summary, [v5])
