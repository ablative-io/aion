module empty_fork_collection source=empty_fork_collection.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_check_all:
    aion@workflow:map/2 [activities] (v0, v1)
  check_all_fork_0:
    aion@activity:task_queue/2 [activities] (v1, lit#11)
== durable families == activities
== atoms ==
  [0] doc
  [1] verdict
  [2] summary
  [3] check_doc_input
  [4] empty_fork_collection_input
  [5] summarized_outcome
  [6] ok
== literals ==
  [0] "title"
  [1] "title"
  [2] "ok"
  [3] "checked"
  [4] "doc"
  [5] "docs"
  [6] "summarized"
  [7] "outcome"
  [8] "EmptyForkCollectionOutcome"
  [9] "summarized"
  [10] "payload"
  [11] "review"
== types ==
  record Doc tag=doc
    title: string
  record Verdict tag=verdict
    title: string
    ok: bool
  record Summary tag=summary
    checked: int
  record CheckDocInput tag=check_doc_input
    doc: ref(Doc)
  record EmptyForkCollectionInput tag=empty_fork_collection_input
    docs: list(ref(Doc))
  union EmptyForkCollectionOutcome
    summarized -> summarized_outcome(ref(Summary))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=empty_fork_collection_input_codec output=empty_fork_collection_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(empty_fork_collection.EmptyForkCollectionInput, empty_fork_collection.EmptyForkCollectionOutcome, AwlError)
