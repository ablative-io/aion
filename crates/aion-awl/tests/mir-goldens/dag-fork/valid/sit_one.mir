  sig: (sit_one.SittingSpec) -> Decoder(sit_one.SittingRow)
  v1 = call_rt aion@awl@codec:bool_decoder/0() live_after=[v0]
  v2 = make_closure sitting_row_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#4, v1, v2)
== fn sitting_row_decoder$1/2 origin=lifted(sitting_row_decoder, #1) ==
  sig: (Bool, sit_one.SittingSpec) -> Decoder(sit_one.SittingRow)
