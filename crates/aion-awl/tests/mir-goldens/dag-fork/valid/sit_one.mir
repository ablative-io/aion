  sig: (String) -> Decoder(sit_one.SittingSpec)
  v1 = call_rt aion@awl@codec:string_decoder/0() live_after=[v0]
  v2 = make_closure sitting_spec_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn sitting_spec_decoder$1/2 origin=lifted(sitting_spec_decoder, #1) ==
  sig: (String, String) -> Decoder(sit_one.SittingSpec)
  v2 = call_rt aion@awl@codec:string_decoder/0() live_after=[v0, v1]
  v3 = make_closure sitting_spec_decoder$2 captures=[v1, v0]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v2, v3)
== fn sitting_spec_decoder$2/3 origin=lifted(sitting_spec_decoder, #2) ==
  sig: (String, String, String) -> Decoder(sit_one.SittingSpec)
  v3 = record(sitting_spec, [v1, v2, v0])
  tail_rt gleam@dynamic@decode:success/1(v3)
