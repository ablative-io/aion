module sit_one source=sit_one.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
== durable families == 
== atoms ==
  [0] sitting_spec
  [1] sitting_row
  [2] sit_one_input
  [3] sat_outcome
  [4] false
  [5] true
  [6] ok
== literals ==
  [0] "harness"
  [1] "model"
  [2] "effort"
  [3] "spec"
  [4] "first_try"
  [5] "spec"
  [6] "pack_revision"
  [7] "sat"
  [8] "outcome"
  [9] ""
  [10] ""
  [11] ""
  [12] "SitOneOutcome"
  [13] "sat"
  [14] "payload"
== types ==
  record SittingSpec tag=sitting_spec
    harness: string
    model: string
    effort: string
  record SittingRow tag=sitting_row
    spec: ref(SittingSpec)
    first_try: bool
  record SitOneInput tag=sit_one_input
    spec: ref(SittingSpec)
    pack_revision: string
  union SitOneOutcome
    sat -> sat_outcome(ref(SittingRow))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=sit_one_input_codec output=sit_one_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(sit_one.SitOneInput, sit_one.SitOneOutcome, AwlError)
  T-DEF name="sit_one" input=sit_one_input_codec output=sit_one_outcome_codec
== fn execute/1 origin=execute ==
  sig: (sit_one.SitOneInput) -> Result(sit_one.SitOneOutcome, AwlError)
  T-EXEC fields=[spec:sit_one.SittingSpec, pack_revision:String] entry=step_report args=[0]
== fn sitting_spec_codec/0 origin=codec_template(RecordTrio, SittingSpec, record#0) ==
  sig: () -> Codec(sit_one.SittingSpec)
  v0 = make_closure sitting_spec_to_json captures=[]
  v1 = call_local sitting_spec_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn sitting_spec_to_json/1 origin=codec_template(RecordTrio, SittingSpec, record#0) ==
  sig: (sit_one.SittingSpec) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = field(v0, 3)
  v4 = json_obj {"harness": v1|>awlc.string_to_json, "model": v2|>awlc.string_to_json, "effort": v3|>awlc.string_to_json}
  return v4
== fn sitting_spec_decoder/0 origin=codec_template(RecordTrio, SittingSpec, record#0) ==
  sig: () -> Decoder(sit_one.SittingSpec)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure sitting_spec_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
