== fn sit_one_outcome_decoder$outcome/1 origin=lifted(sit_one_outcome_decoder, #0) ==
  sig: (String) -> Decoder(sit_one.SitOneOutcome)
  if cmp Eq v0 lit#13:
    v4 = call_local sitting_row_decoder()
    v5 = make_closure sit_one_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#14, v4, v5)
  else:
    v1 = record(sitting_spec, [lit#9, lit#10, lit#11])
    v2 = record(sitting_row, [v1, 'false'])
    v3 = record(sat_outcome, [v2])
    tail_rt gleam@dynamic@decode:failure/2(v3, lit#12)
== fn sit_one_outcome_decoder$arm0/1 origin=lifted(sit_one_outcome_decoder, #1) ==
  sig: (sit_one.SittingRow) -> Decoder(sit_one.SitOneOutcome)
  v1 = record(sat_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn step_report/1 origin=region(report) ==
  sig: (sit_one.SittingSpec) -> Result(sit_one.SitOneOutcome, AwlError)
  v1 = record(sitting_row, [v0, 'true'])
  v2 = record(sat_outcome, [v1])
  v3 = record(ok, [v2])
  return v3
