== fn step_fan/1 origin=region(fan) ==
  sig: (List(String)) -> Result(runtime_sized_fork.RuntimeSizedForkOutcome, AwlError)
  v1 = make_closure fan_fork_0 captures=[]
  v2 = call_rt aion@workflow:map/2(v0, v1)
  v3 = call_rt aion@awl@error:map_activity_error/1(v2)
  v4 = try_bind v3
  v5 = record(probes, [v4])
  v6 = record(probed_outcome, [v5])
  v7 = record(ok, [v6])
  return v7
