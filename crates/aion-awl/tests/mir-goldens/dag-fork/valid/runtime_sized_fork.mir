module runtime_sized_fork source=runtime_sized_fork.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_fan:
    aion@workflow:map/2 [activities] (v0, v1)
  fan_fork_0:
    aion@activity:task_queue/2 [activities] (v1, lit#10)
== durable families == activities
== atoms ==
  [0] snapshot
  [1] probes
  [2] probe_region_input
  [3] runtime_sized_fork_input
  [4] probed_outcome
  [5] ok
== literals ==
  [0] "region"
  [1] "healthy"
  [2] "snapshots"
  [3] "region"
  [4] "regions"
  [5] "probed"
  [6] "outcome"
  [7] "RuntimeSizedForkOutcome"
  [8] "probed"
  [9] "payload"
  [10] "probe"
== types ==
  record Snapshot tag=snapshot
    region: string
    healthy: bool
  record Probes tag=probes
    snapshots: list(ref(Snapshot))
  record ProbeRegionInput tag=probe_region_input
    region: string
  record RuntimeSizedForkInput tag=runtime_sized_fork_input
    regions: list(string)
  union RuntimeSizedForkOutcome
    probed -> probed_outcome(ref(Probes))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=runtime_sized_fork_input_codec output=runtime_sized_fork_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(runtime_sized_fork.RuntimeSizedForkInput, runtime_sized_fork.RuntimeSizedForkOutcome, AwlError)
  T-DEF name="runtime_sized_fork" input=runtime_sized_fork_input_codec output=runtime_sized_fork_outcome_codec
== fn execute/1 origin=execute ==
  sig: (runtime_sized_fork.RuntimeSizedForkInput) -> Result(runtime_sized_fork.RuntimeSizedForkOutcome, AwlError)
  T-EXEC fields=[regions:List(String)] entry=step_fan args=[0]
