module fork_named_branches source=fork_named_branches.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_gather:
    aion@activity:task_queue/2 [activities] (v1, lit#18)
    aion@activity:task_queue/2 [activities] (v3, lit#19)
    aion@workflow:all/1 [activities] (v5)
  step_build_dossier:
    aion@activity:task_queue/2 [activities] (v4, lit#22)
    aion@workflow:run/1 [activities] (v5)
== durable families == activities
== atoms ==
  [0] profile
  [1] history
  [2] dossier
  [3] unusable
  [4] assemble_input
  [5] fetch_history_input
  [6] fetch_profile_input
  [7] fork_named_branches_input
  [8] assembled_outcome
  [9] false
  [10] ok
  [11] awl_outcome_failure
  [12] error
== literals ==
  [0] "name"
  [1] "email"
  [2] "events"
  [3] "name"
  [4] "events"
  [5] "complete"
  [6] "reason"
  [7] "name"
  [8] "events"
  [9] "id"
  [10] "id"
  [11] "user_id"
  [12] "assembled"
  [13] "outcome"
  [14] ""
  [15] "ForkNamedBranchesOutcome"
  [16] "assembled"
  [17] "payload"
  [18] "directory"
  [19] "directory"
  [20] "fetch_profile"
  [21] "fetch_history"
  [22] "directory"
  [23] "profile or history incomplete"
  [24] "unusable"
== types ==
  record Profile tag=profile
    name: string
    email: string
  record History tag=history
    events: list(string)
  record Dossier tag=dossier
    name: string
    events: list(string)
    complete: bool
  record Unusable tag=unusable
    reason: string
  record AssembleInput tag=assemble_input
    name: string
    events: list(string)
  record FetchHistoryInput tag=fetch_history_input
    id: string
  record FetchProfileInput tag=fetch_profile_input
    id: string
  record ForkNamedBranchesInput tag=fork_named_branches_input
    user_id: string
  union ForkNamedBranchesOutcome
    assembled -> assembled_outcome(ref(Dossier))
