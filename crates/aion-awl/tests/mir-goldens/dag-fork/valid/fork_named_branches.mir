module fork_named_branches source=fork_named_branches.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_gather:
    aion@activity:task_queue/2 [activities] (v1, lit#0)
    aion@activity:task_queue/2 [activities] (v3, lit#1)
    aion@workflow:all/1 [activities] (v5)
  step_build_dossier:
    aion@activity:task_queue/2 [activities] (v4, lit#4)
    aion@workflow:run/1 [activities] (v5)
== durable families == activities
== atoms ==
  [0] profile
  [1] history
  [2] dossier
  [3] unusable
  [4] assemble_input
  [5] fetch_history_input
  [6] fetch_profile_input
  [7] fork_named_branches_input
  [8] assembled_outcome
  [9] ok
  [10] awl_outcome_failure
  [11] error
== types ==
  record Profile tag=profile
    name: string
    email: string
  record History tag=history
    events: list(string)
  record Dossier tag=dossier
    name: string
    events: list(string)
    complete: bool
  record Unusable tag=unusable
    reason: string
  record AssembleInput tag=assemble_input
    name: string
    events: list(string)
  record FetchHistoryInput tag=fetch_history_input
    id: string
  record FetchProfileInput tag=fetch_profile_input
    id: string
  record ForkNamedBranchesInput tag=fork_named_branches_input
    user_id: string
  union ForkNamedBranchesOutcome
    assembled -> assembled_outcome(ref(Dossier))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fork_named_branches_input_codec output=fork_named_branches_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(fork_named_branches.ForkNamedBranchesInput, fork_named_branches.ForkNamedBranchesOutcome, AwlError)
  T-DEF name="fork_named_branches" input=fork_named_branches_input_codec output=fork_named_branches_outcome_codec
== fn execute/1 origin=execute ==
  sig: (fork_named_branches.ForkNamedBranchesInput) -> Result(fork_named_branches.ForkNamedBranchesOutcome, AwlError)
  T-EXEC fields=[user_id:String] entry=step_gather args=[0]
== fn profile_codec/0 origin=codec_template(RecordTrio, Profile, record#0) ==
  sig: () -> Codec(fork_named_branches.Profile)
  v0 = make_closure profile_to_json captures=[]
  v1 = call_local profile_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn profile_to_json/1 origin=codec_template(RecordTrio, Profile, record#0) ==
  sig: (fork_named_branches.Profile) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"name": v1|>awlc.string_to_json, "email": v2|>awlc.string_to_json}
  return v3
== fn profile_decoder/0 origin=codec_template(RecordTrio, Profile, record#0) ==
  sig: () -> Decoder(fork_named_branches.Profile)
  tail_rt gleam@dynamic@decode:success/1(nil)
