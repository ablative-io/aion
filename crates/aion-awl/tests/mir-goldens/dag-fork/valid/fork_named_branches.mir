== fn step_gather/1 origin=region(gather) ==
  sig: (String) -> Result(fork_named_branches.ForkNamedBranchesOutcome, AwlError)
  v1 = call_local fetch_profile_activity_raw(v0) live_after=[v0]
  v2 = call_rt aion@activity:task_queue/2(v1, lit#0) live_after=[v0]
  v3 = call_local fetch_history_activity_raw(v0) live_after=[v2]
  v4 = call_rt aion@activity:task_queue/2(v3, lit#1) live_after=[v2]
  v5 = list([v2, v4])
  v6 = call_rt aion@workflow:all/1(v5)
  v7 = call_rt aion@awl@error:map_activity_error/1(v6)
  v8 = try_bind v7
  assert_list [v9, v10] = v8
  v11 = call_local profile_codec() live_after=[v9, v10]
  v12 = call_rt aion@awl@codec:decoded/3(v11, v9, lit#2) live_after=[v10]
  v13 = try_bind v12 live_after=[v10]
  v14 = call_local history_codec() live_after=[v10, v13]
  v15 = call_rt aion@awl@codec:decoded/3(v14, v10, lit#3) live_after=[v13]
  v16 = try_bind v15 live_after=[v13]
  tail_local step_build_dossier(v16, v13)
== fn step_build_dossier/2 origin=chain_step(gather.build_dossier) ==
  sig: (fork_named_branches.History, fork_named_branches.Profile) -> Result(fork_named_branches.ForkNamedBranchesOutcome, AwlError)
  v2 = field(v1, 1)
  v3 = field(v0, 1)
  v4 = call_local assemble_activity(v2, v3)
  v5 = call_rt aion@activity:task_queue/2(v4, lit#4)
  v6 = call_rt aion@workflow:run/1(v5)
  v7 = call_rt aion@awl@error:map_activity_error/1(v6)
  v8 = try_bind v7
  v9 = field(v8, 3)
  if is_true v9:
    v10 = field(v8, 1)
    v11 = field(v8, 2)
    v12 = field(v8, 3)
    v13 = record(dossier, [v10, v11, v12])
    v14 = record(assembled_outcome, [v13])
    v15 = record(ok, [v14])
    return v15
  else:
    v16 = record(unusable, [lit#5])
    v17 = call_local unusable_to_json(v16)
    v18 = call_rt gleam@json:to_string/1(v17)
    v19 = record(awl_outcome_failure, [lit#6, v18])
    v20 = record(error, [v19])
    return v20
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
