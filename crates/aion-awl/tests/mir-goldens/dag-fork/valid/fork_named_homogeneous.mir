module fork_named_homogeneous source=fork_named_homogeneous.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_gather:
    aion@activity:task_queue/2 [activities] (v2, lit#14)
    aion@activity:task_queue/2 [activities] (v4, lit#15)
    aion@workflow:all/1 [activities] (v6)
== durable families == activities
== atoms ==
  [0] snapshot
  [1] compared
  [2] probe_region_input
  [3] fork_named_homogeneous_input
  [4] compared_outcome
  [5] false
  [6] ok
== literals ==
  [0] "region"
  [1] "healthy"
  [2] "first"
  [3] "second"
  [4] "region"
  [5] "primary"
  [6] "secondary"
  [7] "compared"
  [8] "outcome"
  [9] ""
  [10] ""
  [11] "ForkNamedHomogeneousOutcome"
  [12] "compared"
  [13] "payload"
  [14] "probe"
  [15] "probe"
== types ==
  record Snapshot tag=snapshot
    region: string
    healthy: bool
  record Compared tag=compared
    first: ref(Snapshot)
    second: ref(Snapshot)
  record ProbeRegionInput tag=probe_region_input
    region: string
  record ForkNamedHomogeneousInput tag=fork_named_homogeneous_input
    primary: string
    secondary: string
  union ForkNamedHomogeneousOutcome
    compared -> compared_outcome(ref(Compared))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fork_named_homogeneous_input_codec output=fork_named_homogeneous_outcome_codec
