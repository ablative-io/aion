== fn probe_region_activity/1 origin=activity_wrapper(probe_region, raw=false) ==
  sig: (String) -> Activity(fork_named_homogeneous.ProbeRegionInput, fork_named_homogeneous.Snapshot)
  T-ACT action=probe_region input_codec=probe_region_input_codec return=snapshot_codec
== fn step_gather/2 origin=region(gather) ==
  sig: (String, String) -> Result(fork_named_homogeneous.ForkNamedHomogeneousOutcome, AwlError)
  v2 = call_local probe_region_activity(v0) live_after=[v1]
  v3 = call_rt aion@activity:task_queue/2(v2, lit#0) live_after=[v1]
  v4 = call_local probe_region_activity(v1) live_after=[v3]
  v5 = call_rt aion@activity:task_queue/2(v4, lit#1) live_after=[v3]
  v6 = list([v3, v5])
  v7 = call_rt aion@workflow:all/1(v6)
  v8 = call_rt aion@awl@error:map_activity_error/1(v7)
  v9 = try_bind v8
  assert_list [v10, v11] = v9
  v12 = record(compared, [v10, v11])
  v13 = record(compared_outcome, [v12])
  v14 = record(ok, [v13])
  return v14
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
