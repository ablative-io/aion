  sig: (String) -> Decoder(fork_named_homogeneous.ForkNamedHomogeneousOutcome)
  if cmp Eq v0 lit#12:
    v5 = call_local compared_decoder()
    v6 = make_closure fork_named_homogeneous_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#13, v5, v6)
