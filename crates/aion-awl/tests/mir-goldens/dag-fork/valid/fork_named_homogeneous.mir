== fn execute/1 origin=execute ==
  sig: (fork_named_homogeneous.ForkNamedHomogeneousInput) -> Result(fork_named_homogeneous.ForkNamedHomogeneousOutcome, AwlError)
  T-EXEC fields=[primary:String, secondary:String] entry=step_gather args=[0, 1]
