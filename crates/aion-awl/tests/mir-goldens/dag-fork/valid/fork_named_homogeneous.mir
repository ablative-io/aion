module fork_named_homogeneous source=fork_named_homogeneous.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_gather:
    aion@activity:task_queue/2 [activities] (v2, lit#0)
    aion@activity:task_queue/2 [activities] (v4, lit#1)
    aion@workflow:all/1 [activities] (v6)
== durable families == activities
== atoms ==
  [0] snapshot
  [1] compared
  [2] probe_region_input
  [3] fork_named_homogeneous_input
  [4] compared_outcome
  [5] ok
== types ==
  record Snapshot tag=snapshot
    region: string
    healthy: bool
  record Compared tag=compared
    first: ref(Snapshot)
    second: ref(Snapshot)
  record ProbeRegionInput tag=probe_region_input
    region: string
  record ForkNamedHomogeneousInput tag=fork_named_homogeneous_input
    primary: string
    secondary: string
  union ForkNamedHomogeneousOutcome
    compared -> compared_outcome(ref(Compared))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fork_named_homogeneous_input_codec output=fork_named_homogeneous_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(fork_named_homogeneous.ForkNamedHomogeneousInput, fork_named_homogeneous.ForkNamedHomogeneousOutcome, AwlError)
  T-DEF name="fork_named_homogeneous" input=fork_named_homogeneous_input_codec output=fork_named_homogeneous_outcome_codec
== fn execute/1 origin=execute ==
  sig: (fork_named_homogeneous.ForkNamedHomogeneousInput) -> Result(fork_named_homogeneous.ForkNamedHomogeneousOutcome, AwlError)
  T-EXEC fields=[primary:String, secondary:String] entry=step_gather args=[0, 1]
== fn snapshot_codec/0 origin=codec_template(RecordTrio, Snapshot, record#0) ==
  sig: () -> Codec(fork_named_homogeneous.Snapshot)
  v0 = make_closure snapshot_to_json captures=[]
  v1 = call_local snapshot_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn snapshot_to_json/1 origin=codec_template(RecordTrio, Snapshot, record#0) ==
  sig: (fork_named_homogeneous.Snapshot) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"region": v1|>awlc.string_to_json, "healthy": v2|>awlc.bool_to_json}
  return v3
== fn snapshot_decoder/0 origin=codec_template(RecordTrio, Snapshot, record#0) ==
  sig: () -> Decoder(fork_named_homogeneous.Snapshot)
  tail_rt gleam@dynamic@decode:success/1(nil)
