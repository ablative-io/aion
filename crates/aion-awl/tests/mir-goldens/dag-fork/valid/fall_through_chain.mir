module fall_through_chain source=fall_through_chain.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_clean_input:
    aion@activity:task_queue/2 [activities] (v1, lit#0)
    aion@workflow:run/1 [activities] (v2)
  step_render_page:
    aion@activity:task_queue/2 [activities] (v2, lit#1)
    aion@workflow:run/1 [activities] (v3)
  step_publish_page:
    aion@activity:task_queue/2 [activities] (v2, lit#2)
    aion@workflow:run/1 [activities] (v3)
== durable families == activities
== atoms ==
  [0] cleaned
  [1] rendered
  [2] published
  [3] clean_input
  [4] publish_input
  [5] render_input
  [6] fall_through_chain_input
  [7] published_outcome
  [8] ok
== types ==
  record Cleaned tag=cleaned
    text: string
  record Rendered tag=rendered
    html: string
  record Published tag=published
    url: string
  record CleanInput tag=clean_input
    raw: string
  record PublishInput tag=publish_input
    html: string
  record RenderInput tag=render_input
    text: string
  record FallThroughChainInput tag=fall_through_chain_input
    raw: string
  union FallThroughChainOutcome
    published -> published_outcome(ref(Published))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=fall_through_chain_input_codec output=fall_through_chain_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(fall_through_chain.FallThroughChainInput, fall_through_chain.FallThroughChainOutcome, AwlError)
  T-DEF name="fall_through_chain" input=fall_through_chain_input_codec output=fall_through_chain_outcome_codec
== fn execute/1 origin=execute ==
  sig: (fall_through_chain.FallThroughChainInput) -> Result(fall_through_chain.FallThroughChainOutcome, AwlError)
  T-EXEC fields=[raw:String] entry=step_clean_input args=[0]
== fn cleaned_codec/0 origin=codec_template(RecordTrio, Cleaned, record#0) ==
  sig: () -> Codec(fall_through_chain.Cleaned)
  v0 = make_closure cleaned_to_json captures=[]
  v1 = call_local cleaned_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn cleaned_to_json/1 origin=codec_template(RecordTrio, Cleaned, record#0) ==
  sig: (fall_through_chain.Cleaned) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"text": v1|>awlc.string_to_json}
  return v2
== fn cleaned_decoder/0 origin=codec_template(RecordTrio, Cleaned, record#0) ==
  sig: () -> Decoder(fall_through_chain.Cleaned)
  tail_rt gleam@dynamic@decode:success/1(nil)
