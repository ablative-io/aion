== fn clean_activity/1 origin=activity_wrapper(clean, raw=false) ==
  sig: (String) -> Activity(fall_through_chain.CleanInput, fall_through_chain.Cleaned)
  T-ACT action=clean input_codec=clean_input_codec return=cleaned_codec
== fn publish_activity/1 origin=activity_wrapper(publish, raw=false) ==
  sig: (String) -> Activity(fall_through_chain.PublishInput, fall_through_chain.Published)
  T-ACT action=publish input_codec=publish_input_codec return=published_codec
== fn render_activity/1 origin=activity_wrapper(render, raw=false) ==
  sig: (String) -> Activity(fall_through_chain.RenderInput, fall_through_chain.Rendered)
  T-ACT action=render input_codec=render_input_codec return=rendered_codec
== fn step_clean_input/1 origin=region(clean_input) ==
  sig: (String) -> Result(fall_through_chain.FallThroughChainOutcome, AwlError)
  v1 = call_local clean_activity(v0)
  v2 = call_rt aion@activity:task_queue/2(v1, lit#0)
  v3 = call_rt aion@workflow:run/1(v2)
  v4 = call_rt aion@awl@error:map_activity_error/1(v3)
  v5 = try_bind v4
  tail_local step_render_page(v5)
== fn step_render_page/1 origin=chain_step(clean_input.render_page) ==
  sig: (fall_through_chain.Cleaned) -> Result(fall_through_chain.FallThroughChainOutcome, AwlError)
  v1 = field(v0, 1)
  v2 = call_local render_activity(v1)
  v3 = call_rt aion@activity:task_queue/2(v2, lit#1)
  v4 = call_rt aion@workflow:run/1(v3)
  v5 = call_rt aion@awl@error:map_activity_error/1(v4)
  v6 = try_bind v5
  tail_local step_publish_page(v6)
== fn step_publish_page/1 origin=chain_step(clean_input.publish_page) ==
  sig: (fall_through_chain.Rendered) -> Result(fall_through_chain.FallThroughChainOutcome, AwlError)
  v1 = field(v0, 1)
  v2 = call_local publish_activity(v1)
  v3 = call_rt aion@activity:task_queue/2(v2, lit#2)
  v4 = call_rt aion@workflow:run/1(v3)
  v5 = call_rt aion@awl@error:map_activity_error/1(v4)
  v6 = try_bind v5
  v7 = record(published_outcome, [v6])
  v8 = record(ok, [v7])
  return v8
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
