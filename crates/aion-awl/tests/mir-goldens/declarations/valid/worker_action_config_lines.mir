  sig: (build_once.BuildOnceOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#6|>awlc.string_to_json, "payload": v1|>build_result_to_json}
  return v2
== fn build_once_outcome_decoder/0 origin=codec_template(UnionTrio, BuildOnceOutcome, union#5) ==
  sig: () -> Decoder(build_once.BuildOnceOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure build_once_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#7, v0, v1)
== fn build_once_outcome_decoder$outcome/1 origin=lifted(build_once_outcome_decoder, #0) ==
  sig: (String) -> Decoder(build_once.BuildOnceOutcome)
  if cmp Eq v0 lit#10:
    v3 = call_local build_result_decoder()
    v4 = make_closure build_once_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#11, v3, v4)
  else:
    v1 = record(build_result, [lit#8, 'false'])
    v2 = record(built_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#9)
== fn build_once_outcome_decoder$arm0/1 origin=lifted(build_once_outcome_decoder, #1) ==
  sig: (build_once.BuildResult) -> Decoder(build_once.BuildOnceOutcome)
  v1 = record(built_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn collect_log_activity/1 origin=activity_wrapper(collect_log, raw=false) ==
  sig: (String) -> Activity(build_once.CollectLogInput, build_once.BuildFailure)
  T-ACT action=collect_log input_codec=collect_log_input_codec return=build_failure_codec
== fn compile_activity/1 origin=activity_wrapper(compile, raw=false) ==
  sig: (String) -> Activity(build_once.CompileInput, build_once.BuildResult)
  T-ACT action=compile input_codec=compile_input_codec return=build_result_codec
== fn step_compile/1 origin=region(compile) ==
  sig: (String) -> Result(build_once.BuildOnceOutcome, AwlError)
  v1 = call_local compile_activity(v0) live_after=[v0]
  v2 = call_rt aion@duration:milliseconds/1(45000) live_after=[v0, v1]
  v3 = record(fixed, [v2])
  v4 = record(retry_policy, [3, v3])
  v5 = call_rt aion@activity:retry/2(v1, v4) live_after=[v0]
  v6 = call_rt aion@duration:milliseconds/1(1200000) live_after=[v0, v5]
  v7 = call_rt aion@activity:timeout/2(v5, v6) live_after=[v0]
  v8 = call_rt aion@activity:task_queue/2(v7, lit#12) live_after=[v0]
  v9 = call_rt aion@activity:node/2(v8, lit#13) live_after=[v0]
  v10 = call_rt aion@workflow:run/1(v9) live_after=[v0]
  v11 = call_rt aion@awl@error:map_activity_error/1(v10) live_after=[v0]
  v12 = try_bind v11 live_after=[v0]
  v13 = field(v12, 2)
  if is_true v13:
    v14 = field(v12, 1)
    v15 = field(v12, 2)
    v16 = record(build_result, [v14, v15])
    v17 = record(built_outcome, [v16])
    v18 = record(ok, [v17])
    return v18
  else:
    tail_local step_salvage(v0)
== fn step_salvage/1 origin=region(salvage) ==
  sig: (String) -> Result(build_once.BuildOnceOutcome, AwlError)
  v1 = call_local collect_log_activity(v0)
  v2 = call_rt aion@duration:milliseconds/1(90000) live_after=[v1]
  v3 = call_rt aion@activity:timeout/2(v1, v2)
  v4 = call_rt aion@activity:task_queue/2(v3, lit#14)
  v5 = call_rt aion@activity:node/2(v4, lit#15)
  v6 = call_rt aion@workflow:run/1(v5)
  v7 = call_rt aion@awl@error:map_activity_error/1(v6)
  v8 = try_bind v7
  v9 = call_local build_failure_to_json(v8)
  v10 = call_rt gleam@json:to_string/1(v9)
  v11 = record(awl_outcome_failure, [lit#16, v10])
  v12 = record(error, [v11])
  return v12
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
