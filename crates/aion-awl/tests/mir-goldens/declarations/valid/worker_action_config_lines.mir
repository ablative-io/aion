module build_once source=build_once.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_compile:
    aion@activity:retry/2 [activities] (v1, v4)
    aion@activity:timeout/2 [activities] (v5, v6)
    aion@activity:task_queue/2 [activities] (v7, lit#12)
    aion@activity:node/2 [activities] (v8, lit#13)
    aion@workflow:run/1 [activities] (v9)
  step_salvage:
    aion@activity:timeout/2 [activities] (v1, v2)
    aion@activity:task_queue/2 [activities] (v3, lit#14)
    aion@activity:node/2 [activities] (v4, lit#15)
    aion@workflow:run/1 [activities] (v5)
== durable families == activities
== atoms ==
  [0] build_result
  [1] build_failure
  [2] collect_log_input
  [3] compile_input
  [4] build_once_input
  [5] built_outcome
  [6] false
  [7] fixed
  [8] retry_policy
  [9] ok
  [10] awl_outcome_failure
  [11] error
== literals ==
  [0] "artifact_path"
  [1] "ok"
  [2] "log_tail"
  [3] "project_dir"
  [4] "project_dir"
  [5] "project_dir"
  [6] "built"
  [7] "outcome"
  [8] ""
  [9] "BuildOnceOutcome"
  [10] "built"
  [11] "payload"
  [12] "builder"
  [13] "shell"
  [14] "builder"
  [15] "shell"
  [16] "broken"
== types ==
  record BuildResult tag=build_result
    artifact_path: string
    ok: bool
  record BuildFailure tag=build_failure
    log_tail: string
  record CollectLogInput tag=collect_log_input
    project_dir: string
  record CompileInput tag=compile_input
    project_dir: string
  record BuildOnceInput tag=build_once_input
    project_dir: string
  union BuildOnceOutcome
    built -> built_outcome(ref(BuildResult))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=build_once_input_codec output=build_once_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(build_once.BuildOnceInput, build_once.BuildOnceOutcome, AwlError)
  T-DEF name="build_once" input=build_once_input_codec output=build_once_outcome_codec
== fn execute/1 origin=execute ==
  sig: (build_once.BuildOnceInput) -> Result(build_once.BuildOnceOutcome, AwlError)
  T-EXEC fields=[project_dir:String] entry=step_compile args=[0]
== fn build_result_codec/0 origin=codec_template(RecordTrio, BuildResult, record#0) ==
  sig: () -> Codec(build_once.BuildResult)
  v0 = make_closure build_result_to_json captures=[]
  v1 = call_local build_result_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn build_result_to_json/1 origin=codec_template(RecordTrio, BuildResult, record#0) ==
  sig: (build_once.BuildResult) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"artifact_path": v1|>awlc.string_to_json, "ok": v2|>awlc.bool_to_json}
  return v3
== fn build_result_decoder/0 origin=codec_template(RecordTrio, BuildResult, record#0) ==
  sig: () -> Decoder(build_once.BuildResult)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure build_result_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn build_result_decoder$0/1 origin=lifted(build_result_decoder, #0) ==
  sig: (String) -> Decoder(build_once.BuildResult)
  v1 = call_rt aion@awl@codec:bool_decoder/0() live_after=[v0]
  v2 = make_closure build_result_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn build_result_decoder$1/2 origin=lifted(build_result_decoder, #1) ==
  sig: (Bool, String) -> Decoder(build_once.BuildResult)
  v2 = record(build_result, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
== fn build_failure_codec/0 origin=codec_template(RecordTrio, BuildFailure, record#1) ==
  sig: () -> Codec(build_once.BuildFailure)
  v0 = make_closure build_failure_to_json captures=[]
  v1 = call_local build_failure_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
