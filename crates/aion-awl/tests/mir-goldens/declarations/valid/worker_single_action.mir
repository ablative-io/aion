  sig: () -> Decoder(notify_once.SendMessageInput)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure send_message_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v0, v1)
== fn send_message_input_decoder$0/1 origin=lifted(send_message_input_decoder, #0) ==
  sig: (String) -> Decoder(notify_once.SendMessageInput)
  v1 = record(send_message_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
