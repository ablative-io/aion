  sig: () -> Decoder(notify_once.NotifyOnceInput)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure notify_once_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#3, v0, v1)
== fn notify_once_input_decoder$0/1 origin=lifted(notify_once_input_decoder, #0) ==
  sig: (String) -> Decoder(notify_once.NotifyOnceInput)
