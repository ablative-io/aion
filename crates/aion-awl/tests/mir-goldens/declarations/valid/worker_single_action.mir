module notify_once source=notify_once.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_send:
    aion@activity:task_queue/2 [activities] (v1, lit#10)
    aion@workflow:run/1 [activities] (v2)
== durable families == activities
== atoms ==
  [0] receipt
  [1] send_message_input
  [2] notify_once_input
  [3] sent_outcome
  [4] false
  [5] ok
== literals ==
  [0] "id"
  [1] "accepted"
  [2] "message"
  [3] "message"
  [4] "sent"
  [5] "outcome"
  [6] ""
  [7] "NotifyOnceOutcome"
  [8] "sent"
  [9] "payload"
  [10] "notifier"
== types ==
  record Receipt tag=receipt
    id: string
    accepted: bool
  record SendMessageInput tag=send_message_input
    message: string
  record NotifyOnceInput tag=notify_once_input
    message: string
  union NotifyOnceOutcome
    sent -> sent_outcome(ref(Receipt))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=notify_once_input_codec output=notify_once_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(notify_once.NotifyOnceInput, notify_once.NotifyOnceOutcome, AwlError)
  T-DEF name="notify_once" input=notify_once_input_codec output=notify_once_outcome_codec
== fn execute/1 origin=execute ==
  sig: (notify_once.NotifyOnceInput) -> Result(notify_once.NotifyOnceOutcome, AwlError)
  T-EXEC fields=[message:String] entry=step_send args=[0]
== fn receipt_codec/0 origin=codec_template(RecordTrio, Receipt, record#0) ==
  sig: () -> Codec(notify_once.Receipt)
  v0 = make_closure receipt_to_json captures=[]
  v1 = call_local receipt_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn receipt_to_json/1 origin=codec_template(RecordTrio, Receipt, record#0) ==
  sig: (notify_once.Receipt) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"id": v1|>awlc.string_to_json, "accepted": v2|>awlc.bool_to_json}
  return v3
== fn receipt_decoder/0 origin=codec_template(RecordTrio, Receipt, record#0) ==
  sig: () -> Decoder(notify_once.Receipt)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure receipt_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn receipt_decoder$0/1 origin=lifted(receipt_decoder, #0) ==
  sig: (String) -> Decoder(notify_once.Receipt)
  v1 = call_rt aion@awl@codec:bool_decoder/0() live_after=[v0]
  v2 = make_closure receipt_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn receipt_decoder$1/2 origin=lifted(receipt_decoder, #1) ==
  sig: (Bool, String) -> Decoder(notify_once.Receipt)
  v2 = record(receipt, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
