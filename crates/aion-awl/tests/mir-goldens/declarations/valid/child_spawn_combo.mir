module child_spawn_combo source=child_spawn_combo.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_grade:
    aion@workflow:spawn_and_wait/6 [children] (lit#13, v2, v1, v3, v4, v5)
    aion@workflow:spawn/6 [children] (lit#14, v11, v10, v12, v13, v14)
== durable families == children
== atoms ==
  [0] grade
  [1] child_spawn_combo_input
  [2] scored_outcome
  [3] ok
== literals ==
  [0] "score"
  [1] "essay"
  [2] "scored"
  [3] "outcome"
  [4] "ChildSpawnComboOutcome"
  [5] "scored"
  [6] "payload"
  [7] "child"
  [8] "outcome"
  [9] "payload"
  [10] "child"
  [11] "outcome"
  [12] "payload"
  [13] "score_essay"
  [14] "notify_graded"
== types ==
  record Grade tag=grade
    score: int
  record ChildSpawnComboInput tag=child_spawn_combo_input
    essay: string
  union ChildSpawnComboOutcome
    scored -> scored_outcome(ref(Grade))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=child_spawn_combo_input_codec output=child_spawn_combo_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(child_spawn_combo.ChildSpawnComboInput, child_spawn_combo.ChildSpawnComboOutcome, AwlError)
  T-DEF name="child_spawn_combo" input=child_spawn_combo_input_codec output=child_spawn_combo_outcome_codec
== fn execute/1 origin=execute ==
  sig: (child_spawn_combo.ChildSpawnComboInput) -> Result(child_spawn_combo.ChildSpawnComboOutcome, AwlError)
  T-EXEC fields=[essay:String] entry=step_grade args=[0]
== fn grade_codec/0 origin=codec_template(RecordTrio, Grade, record#0) ==
  sig: () -> Codec(child_spawn_combo.Grade)
  v0 = make_closure grade_to_json captures=[]
  v1 = call_local grade_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn grade_to_json/1 origin=codec_template(RecordTrio, Grade, record#0) ==
  sig: (child_spawn_combo.Grade) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"score": v1|>awlc.int_to_json}
  return v2
== fn grade_decoder/0 origin=codec_template(RecordTrio, Grade, record#0) ==
  sig: () -> Decoder(child_spawn_combo.Grade)
  v0 = call_rt aion@awl@codec:int_decoder/0()
  v1 = make_closure grade_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn grade_decoder$0/1 origin=lifted(grade_decoder, #0) ==
  sig: (Int) -> Decoder(child_spawn_combo.Grade)
  v1 = record(grade, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn child_spawn_combo_input_codec/0 origin=codec_template(RecordTrio, ChildSpawnComboInput, record#1) ==
  sig: () -> Codec(child_spawn_combo.ChildSpawnComboInput)
  v0 = make_closure child_spawn_combo_input_to_json captures=[]
  v1 = call_local child_spawn_combo_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn child_spawn_combo_input_to_json/1 origin=codec_template(RecordTrio, ChildSpawnComboInput, record#1) ==
  sig: (child_spawn_combo.ChildSpawnComboInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"essay": v1|>awlc.string_to_json}
  return v2
