  sig: () -> Decoder(child_spawn_combo.ChildSpawnComboInput)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure child_spawn_combo_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v0, v1)
== fn child_spawn_combo_input_decoder$0/1 origin=lifted(child_spawn_combo_input_decoder, #0) ==
  sig: (String) -> Decoder(child_spawn_combo.ChildSpawnComboInput)
  v1 = record(child_spawn_combo_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn child_spawn_combo_outcome_codec/0 origin=codec_template(UnionTrio, ChildSpawnComboOutcome, union#2) ==
  sig: () -> Codec(child_spawn_combo.ChildSpawnComboOutcome)
  v0 = make_closure child_spawn_combo_outcome_to_json captures=[]
  v1 = call_local child_spawn_combo_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn child_spawn_combo_outcome_to_json/1 origin=codec_template(UnionTrio, ChildSpawnComboOutcome, union#2) ==
  sig: (child_spawn_combo.ChildSpawnComboOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#2|>awlc.string_to_json, "payload": v1|>grade_to_json}
  return v2
== fn child_spawn_combo_outcome_decoder/0 origin=codec_template(UnionTrio, ChildSpawnComboOutcome, union#2) ==
  sig: () -> Decoder(child_spawn_combo.ChildSpawnComboOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure child_spawn_combo_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#3, v0, v1)
== fn child_spawn_combo_outcome_decoder$outcome/1 origin=lifted(child_spawn_combo_outcome_decoder, #0) ==
  sig: (String) -> Decoder(child_spawn_combo.ChildSpawnComboOutcome)
  if cmp Eq v0 lit#5:
    v3 = call_local grade_decoder()
    v4 = make_closure child_spawn_combo_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#6, v3, v4)
  else:
    v1 = record(grade, [0])
    v2 = record(scored_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#4)
== fn child_spawn_combo_outcome_decoder$arm0/1 origin=lifted(child_spawn_combo_outcome_decoder, #1) ==
  sig: (child_spawn_combo.Grade) -> Decoder(child_spawn_combo.ChildSpawnComboOutcome)
  v1 = record(scored_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
