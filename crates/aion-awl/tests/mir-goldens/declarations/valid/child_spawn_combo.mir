== fn step_grade/1 origin=region(grade) ==
  sig: (String) -> Result(child_spawn_combo.ChildSpawnComboOutcome, AwlError)
  v1 = json_obj {"essay": v0|>awlc.string_to_json}
  v2 = make_closure awl$child_witness captures=[]
  v3 = call_rt aion@awl@codec:json_value/0() live_after=[v1, v2]
  v4 = call_local awl_child_output_grade_codec() live_after=[v1, v2, v3]
  v5 = call_rt aion@awl@error:codec/0() live_after=[v1, v2, v3, v4]
  v6 = call_rt aion@workflow:spawn_and_wait/6(lit#13, v2, v1, v3, v4, v5)
  v7 = call_rt aion@awl@error:map_child_error/1(v6)
  v8 = try_bind v7
  v9 = field(v8, 1)
  v10 = json_obj {"score": v9|>awlc.int_to_json}
  v11 = make_closure awl$child_witness captures=[]
  v12 = call_rt aion@awl@codec:json_value/0() live_after=[v8, v10, v11]
  v13 = call_local awl_child_output_nil_codec() live_after=[v8, v10, v11, v12]
  v14 = call_rt aion@awl@error:codec/0() live_after=[v8, v10, v11, v12, v13]
  v15 = call_rt aion@workflow:spawn/6(lit#14, v11, v10, v12, v13, v14) live_after=[v8]
  v16 = call_rt aion@awl@error:map_spawn_error/1(v15) live_after=[v8]
  v17 = try_bind v16 live_after=[v8]
  v18 = field(v8, 1)
  v19 = record(grade, [v18])
  v20 = record(scored_outcome, [v19])
  v21 = record(ok, [v20])
  return v21
== fn awl$child_witness/1 origin=child_witness ==
  sig: (Json) -> Result(Dynamic, AwlError)
  T-WIT
