  sig: () -> Codec(child_spawn_combo.Grade)
  v0 = make_closure awl_child_output_grade_to_json captures=[]
  v1 = call_local awl_child_output_grade_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
