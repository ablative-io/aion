module transcribe_and_summarize source=transcribe_and_summarize.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_transcribe:
    aion@activity:retry/2 [activities] (v1, v4)
    aion@activity:timeout/2 [activities] (v5, v6)
    aion@activity:task_queue/2 [activities] (v7, lit#12)
    aion@activity:node/2 [activities] (v8, lit#13)
    aion@workflow:run/1 [activities] (v9)
  step_summarize:
    aion@activity:timeout/2 [activities] (v2, v3)
    aion@activity:task_queue/2 [activities] (v4, lit#14)
    aion@activity:node/2 [activities] (v5, lit#15)
    aion@workflow:run/1 [activities] (v6)
== durable families == activities
== atoms ==
  [0] transcript
  [1] summary
  [2] summarize_input
  [3] transcribe_input
  [4] transcribe_and_summarize_input
  [5] summarized_outcome
  [6] fixed
  [7] retry_policy
  [8] ok
== literals ==
  [0] "text"
  [1] "minutes"
  [2] "text"
  [3] "text"
  [4] "recording_path"
  [5] "recording_path"
  [6] "summarized"
  [7] "outcome"
  [8] ""
  [9] "TranscribeAndSummarizeOutcome"
  [10] "summarized"
  [11] "payload"
  [12] "audio"
  [13] "gpu"
  [14] "language"
  [15] "model"
== types ==
  record Transcript tag=transcript
    text: string
    minutes: int
  record Summary tag=summary
    text: string
  record SummarizeInput tag=summarize_input
    text: string
  record TranscribeInput tag=transcribe_input
    recording_path: string
  record TranscribeAndSummarizeInput tag=transcribe_and_summarize_input
    recording_path: string
  union TranscribeAndSummarizeOutcome
    summarized -> summarized_outcome(ref(Summary))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=transcribe_and_summarize_input_codec output=transcribe_and_summarize_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(transcribe_and_summarize.TranscribeAndSummarizeInput, transcribe_and_summarize.TranscribeAndSummarizeOutcome, AwlError)
  T-DEF name="transcribe_and_summarize" input=transcribe_and_summarize_input_codec output=transcribe_and_summarize_outcome_codec
== fn execute/1 origin=execute ==
  sig: (transcribe_and_summarize.TranscribeAndSummarizeInput) -> Result(transcribe_and_summarize.TranscribeAndSummarizeOutcome, AwlError)
  T-EXEC fields=[recording_path:String] entry=step_transcribe args=[0]
== fn transcript_codec/0 origin=codec_template(RecordTrio, Transcript, record#0) ==
  sig: () -> Codec(transcribe_and_summarize.Transcript)
  v0 = make_closure transcript_to_json captures=[]
  v1 = call_local transcript_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
