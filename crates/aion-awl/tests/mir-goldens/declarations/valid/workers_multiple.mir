== fn transcribe_and_summarize_outcome_decoder$outcome/1 origin=lifted(transcribe_and_summarize_outcome_decoder, #0) ==
  sig: (String) -> Decoder(transcribe_and_summarize.TranscribeAndSummarizeOutcome)
  if cmp Eq v0 lit#10:
    v3 = call_local summary_decoder()
    v4 = make_closure transcribe_and_summarize_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#11, v3, v4)
  else:
    v1 = record(summary, [lit#8])
    v2 = record(summarized_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#9)
