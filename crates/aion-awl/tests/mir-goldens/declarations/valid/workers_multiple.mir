  sig: (transcribe_and_summarize.Transcript) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"text": v1|>awlc.string_to_json, "minutes": v2|>awlc.int_to_json}
  return v3
