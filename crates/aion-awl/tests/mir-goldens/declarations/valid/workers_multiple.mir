== fn step_transcribe/1 origin=region(transcribe) ==
  sig: (String) -> Result(transcribe_and_summarize.TranscribeAndSummarizeOutcome, AwlError)
  v1 = call_local transcribe_activity(v0)
  v2 = call_rt aion@duration:milliseconds/1(60000) live_after=[v1]
  v3 = record(fixed, [v2])
  v4 = record(retry_policy, [2, v3])
  v5 = call_rt aion@activity:retry/2(v1, v4)
  v6 = call_rt aion@duration:milliseconds/1(10800000) live_after=[v5]
  v7 = call_rt aion@activity:timeout/2(v5, v6)
  v8 = call_rt aion@activity:task_queue/2(v7, lit#12)
  v9 = call_rt aion@activity:node/2(v8, lit#13)
  v10 = call_rt aion@workflow:run/1(v9)
  v11 = call_rt aion@awl@error:map_activity_error/1(v10)
  v12 = try_bind v11
  tail_local step_summarize(v12)
== fn step_summarize/1 origin=chain_step(transcribe.summarize) ==
  sig: (transcribe_and_summarize.Transcript) -> Result(transcribe_and_summarize.TranscribeAndSummarizeOutcome, AwlError)
  v1 = field(v0, 1)
  v2 = call_local summarize_activity(v1)
  v3 = call_rt aion@duration:milliseconds/1(600000) live_after=[v2]
  v4 = call_rt aion@activity:timeout/2(v2, v3)
  v5 = call_rt aion@activity:task_queue/2(v4, lit#14)
  v6 = call_rt aion@activity:node/2(v5, lit#15)
  v7 = call_rt aion@workflow:run/1(v6)
  v8 = call_rt aion@awl@error:map_activity_error/1(v7)
  v9 = try_bind v8
  v10 = record(summarized_outcome, [v9])
  v11 = record(ok, [v10])
  return v11
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
