== types ==
  record Build tag=build
    artifact: string
    ok: bool
  record Changelog tag=changelog
    text: string
    entries: int
  record Release tag=release
    version: string
    artifact: string
    changelog: string
  record Abort tag=abort
    reason: string
  record AnnounceInput tag=announce_input
    text: string
  record CutBuildInput tag=cut_build_input
    repo: string
    version: string
  record SignArtifactInput tag=sign_artifact_input
    artifact: string
  record TagReleaseInput tag=tag_release_input
    version: string
  record ReleasePipelineInput tag=release_pipeline_input
    version: string
    repo: string
  union ReleasePipelineOutcome
    released -> released_outcome(ref(Release))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=release_pipeline_input_codec output=release_pipeline_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(release_pipeline.ReleasePipelineInput, release_pipeline.ReleasePipelineOutcome, AwlError)
  T-DEF name="release_pipeline" input=release_pipeline_input_codec output=release_pipeline_outcome_codec
== fn execute/1 origin=execute ==
  sig: (release_pipeline.ReleasePipelineInput) -> Result(release_pipeline.ReleasePipelineOutcome, AwlError)
  T-EXEC fields=[version:String, repo:String] entry=step_build args=[1, 0]
