  sig: () -> Decoder(timeout_inside_retry.Fetched)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure fetched_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn fetched_decoder$0/1 origin=lifted(fetched_decoder, #0) ==
  sig: (String) -> Decoder(timeout_inside_retry.Fetched)
  v1 = record(fetched, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
