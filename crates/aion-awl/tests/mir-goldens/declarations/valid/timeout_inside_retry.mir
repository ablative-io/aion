module timeout_inside_retry source=timeout_inside_retry.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_call:
    aion@activity:retry/2 [activities] (v1, v5)
    aion@activity:timeout/2 [activities] (v6, v7)
    aion@activity:task_queue/2 [activities] (v8, lit#10)
    aion@activity:node/2 [activities] (v9, lit#11)
    aion@workflow:run/1 [activities] (v10)
== durable families == activities
== atoms ==
  [0] fetched
  [1] fetch_input
  [2] timeout_inside_retry_input
  [3] fetched_outcome
  [4] exponential
  [5] retry_policy
  [6] ok
== literals ==
  [0] "body"
  [1] "endpoint"
  [2] "endpoint"
  [3] "fetched"
  [4] "outcome"
  [5] ""
  [6] "TimeoutInsideRetryOutcome"
  [7] "fetched"
  [8] "payload"
  [9] float(2.0)
  [10] "net"
  [11] "network"
== types ==
  record Fetched tag=fetched
    body: string
  record FetchInput tag=fetch_input
    endpoint: string
  record TimeoutInsideRetryInput tag=timeout_inside_retry_input
    endpoint: string
  union TimeoutInsideRetryOutcome
    fetched -> fetched_outcome(ref(Fetched))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=timeout_inside_retry_input_codec output=timeout_inside_retry_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(timeout_inside_retry.TimeoutInsideRetryInput, timeout_inside_retry.TimeoutInsideRetryOutcome, AwlError)
  T-DEF name="timeout_inside_retry" input=timeout_inside_retry_input_codec output=timeout_inside_retry_outcome_codec
== fn execute/1 origin=execute ==
  sig: (timeout_inside_retry.TimeoutInsideRetryInput) -> Result(timeout_inside_retry.TimeoutInsideRetryOutcome, AwlError)
  T-EXEC fields=[endpoint:String] entry=step_call args=[0]
== fn fetched_codec/0 origin=codec_template(RecordTrio, Fetched, record#0) ==
  sig: () -> Codec(timeout_inside_retry.Fetched)
  v0 = make_closure fetched_to_json captures=[]
  v1 = call_local fetched_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
