  sig: () -> Decoder(timeout_inside_retry.TimeoutInsideRetryOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure timeout_inside_retry_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#4, v0, v1)
== fn timeout_inside_retry_outcome_decoder$outcome/1 origin=lifted(timeout_inside_retry_outcome_decoder, #0) ==
  sig: (String) -> Decoder(timeout_inside_retry.TimeoutInsideRetryOutcome)
  if cmp Eq v0 lit#7:
    v3 = call_local fetched_decoder()
    v4 = make_closure timeout_inside_retry_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#8, v3, v4)
  else:
    v1 = record(fetched, [lit#5])
    v2 = record(fetched_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#6)
== fn timeout_inside_retry_outcome_decoder$arm0/1 origin=lifted(timeout_inside_retry_outcome_decoder, #1) ==
  sig: (timeout_inside_retry.Fetched) -> Decoder(timeout_inside_retry.TimeoutInsideRetryOutcome)
  v1 = record(fetched_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn fetch_activity/1 origin=activity_wrapper(fetch, raw=false) ==
  sig: (String) -> Activity(timeout_inside_retry.FetchInput, timeout_inside_retry.Fetched)
  T-ACT action=fetch input_codec=fetch_input_codec return=fetched_codec
== fn step_call/1 origin=region(call) ==
  sig: (String) -> Result(timeout_inside_retry.TimeoutInsideRetryOutcome, AwlError)
  v1 = call_local fetch_activity(v0)
  v2 = call_rt aion@duration:milliseconds/1(5000) live_after=[v1]
  v3 = call_rt aion@duration:milliseconds/1(120000) live_after=[v1, v2]
  v4 = record(exponential, [v2, lit#9, v3])
  v5 = record(retry_policy, [4, v4])
  v6 = call_rt aion@activity:retry/2(v1, v5)
  v7 = call_rt aion@duration:milliseconds/1(30000) live_after=[v6]
  v8 = call_rt aion@activity:timeout/2(v6, v7)
  v9 = call_rt aion@activity:task_queue/2(v8, lit#10)
  v10 = call_rt aion@activity:node/2(v9, lit#11)
  v11 = call_rt aion@workflow:run/1(v10)
  v12 = call_rt aion@awl@error:map_activity_error/1(v11)
  v13 = try_bind v12
  v14 = field(v13, 1)
  v15 = record(fetched, [v14])
  v16 = record(fetched_outcome, [v15])
  v17 = record(ok, [v16])
  return v17
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
