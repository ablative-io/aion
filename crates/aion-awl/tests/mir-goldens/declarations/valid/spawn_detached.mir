  sig: (Nil) -> Decoder(Nil)
  tail_rt gleam@dynamic@decode:success/1(v0)
== fn ship_activity/1 origin=activity_wrapper(ship, raw=false) ==
  sig: (String) -> Activity(process_order.ShipInput, process_order.OrderResult)
  T-ACT action=ship input_codec=ship_input_codec return=order_result_codec
== fn step_ship/1 origin=region(ship) ==
  sig: (String) -> Result(process_order.ProcessOrderOutcome, AwlError)
  v1 = json_obj {"order_id": v0|>awlc.string_to_json}
  v2 = make_closure awl$child_witness captures=[]
  v3 = call_rt aion@awl@codec:json_value/0() live_after=[v0, v1, v2]
  v4 = call_local awl_child_output_nil_codec() live_after=[v0, v1, v2, v3]
  v5 = call_rt aion@awl@error:codec/0() live_after=[v0, v1, v2, v3, v4]
  v6 = call_rt aion@workflow:spawn/6(lit#13, v2, v1, v3, v4, v5) live_after=[v0]
  v7 = call_rt aion@awl@error:map_spawn_error/1(v6) live_after=[v0]
  v8 = try_bind v7 live_after=[v0]
  v9 = call_local ship_activity(v0)
  v10 = call_rt aion@duration:milliseconds/1(30000) live_after=[v9]
  v11 = record(fixed, [v10])
  v12 = record(retry_policy, [2, v11])
  v13 = call_rt aion@activity:retry/2(v9, v12)
  v14 = call_rt aion@duration:milliseconds/1(600000) live_after=[v13]
  v15 = call_rt aion@activity:timeout/2(v13, v14)
  v16 = call_rt aion@activity:task_queue/2(v15, lit#14)
  v17 = call_rt aion@activity:node/2(v16, lit#15)
  v18 = call_rt aion@workflow:run/1(v17)
  v19 = call_rt aion@awl@error:map_activity_error/1(v18)
  v20 = try_bind v19
  v21 = field(v20, 2)
  if is_true v21:
    v22 = field(v20, 1)
    v23 = field(v20, 2)
    v24 = record(order_result, [v22, v23])
    v25 = record(shipped_outcome, [v24])
    v26 = record(ok, [v25])
    return v26
  else:
    v27 = field(v20, 1)
    v28 = field(v20, 2)
    v29 = record(order_result, [v27, v28])
    v30 = call_local order_result_to_json(v29)
    v31 = call_rt gleam@json:to_string/1(v30)
    v32 = record(awl_outcome_failure, [lit#16, v31])
    v33 = record(error, [v32])
    return v33
== fn awl$dead_body/1 origin=dead_body ==
  sig: (Dynamic) -> Result(Dynamic, AwlError)
  T-DEAD
== fn awl$child_witness/1 origin=child_witness ==
  sig: (Json) -> Result(Dynamic, AwlError)
  T-WIT
