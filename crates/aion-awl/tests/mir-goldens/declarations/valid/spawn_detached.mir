module process_order source=process_order.awl
exports: run/1, definition/0, execute/1
== effect schedule ==
  step_ship:
    aion@workflow:spawn/6 [children] (lit#13, v2, v1, v3, v4, v5)
    aion@activity:retry/2 [activities] (v9, v12)
    aion@activity:timeout/2 [activities] (v13, v14)
    aion@activity:task_queue/2 [activities] (v15, lit#14)
    aion@activity:node/2 [activities] (v16, lit#15)
    aion@workflow:run/1 [activities] (v17)
== durable families == activities, children
== atoms ==
  [0] order_result
  [1] ship_input
  [2] process_order_input
  [3] shipped_outcome
  [4] false
  [5] fixed
  [6] retry_policy
  [7] ok
  [8] awl_outcome_failure
  [9] error
== literals ==
  [0] "order_id"
  [1] "delivered"
  [2] "order_id"
  [3] "order_id"
  [4] "shipped"
  [5] "outcome"
  [6] ""
  [7] "ProcessOrderOutcome"
  [8] "shipped"
  [9] "payload"
  [10] "child"
  [11] "outcome"
  [12] "payload"
  [13] "audit_trail"
  [14] "orders"
  [15] "warehouse"
  [16] "stuck"
== types ==
  record OrderResult tag=order_result
    order_id: string
    delivered: bool
  record ShipInput tag=ship_input
    order_id: string
  record ProcessOrderInput tag=process_order_input
    order_id: string
  union ProcessOrderOutcome
    shipped -> shipped_outcome(ref(OrderResult))
== fn run/1 origin=run ==
  sig: (Dynamic) -> Result(String, AwlError)
  T-RUN input=process_order_input_codec output=process_order_outcome_codec
== fn definition/0 origin=definition ==
  sig: () -> WorkflowDefinition(process_order.ProcessOrderInput, process_order.ProcessOrderOutcome, AwlError)
  T-DEF name="process_order" input=process_order_input_codec output=process_order_outcome_codec
== fn execute/1 origin=execute ==
  sig: (process_order.ProcessOrderInput) -> Result(process_order.ProcessOrderOutcome, AwlError)
  T-EXEC fields=[order_id:String] entry=step_ship args=[0]
== fn order_result_codec/0 origin=codec_template(RecordTrio, OrderResult, record#0) ==
  sig: () -> Codec(process_order.OrderResult)
  v0 = make_closure order_result_to_json captures=[]
  v1 = call_local order_result_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn order_result_to_json/1 origin=codec_template(RecordTrio, OrderResult, record#0) ==
  sig: (process_order.OrderResult) -> Json
  v1 = field(v0, 1)
  v2 = field(v0, 2)
  v3 = json_obj {"order_id": v1|>awlc.string_to_json, "delivered": v2|>awlc.bool_to_json}
  return v3
== fn order_result_decoder/0 origin=codec_template(RecordTrio, OrderResult, record#0) ==
  sig: () -> Decoder(process_order.OrderResult)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure order_result_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#0, v0, v1)
== fn order_result_decoder$0/1 origin=lifted(order_result_decoder, #0) ==
  sig: (String) -> Decoder(process_order.OrderResult)
  v1 = call_rt aion@awl@codec:bool_decoder/0() live_after=[v0]
  v2 = make_closure order_result_decoder$1 captures=[v0]
  tail_rt gleam@dynamic@decode:field/3(lit#1, v1, v2)
== fn order_result_decoder$1/2 origin=lifted(order_result_decoder, #1) ==
  sig: (Bool, String) -> Decoder(process_order.OrderResult)
  v2 = record(order_result, [v1, v0])
  tail_rt gleam@dynamic@decode:success/1(v2)
== fn ship_input_codec/0 origin=codec_template(RecordTrio, ShipInput, record#1) ==
  sig: () -> Codec(process_order.ShipInput)
  v0 = make_closure ship_input_to_json captures=[]
  v1 = call_local ship_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn ship_input_to_json/1 origin=codec_template(RecordTrio, ShipInput, record#1) ==
  sig: (process_order.ShipInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"order_id": v1|>awlc.string_to_json}
  return v2
== fn ship_input_decoder/0 origin=codec_template(RecordTrio, ShipInput, record#1) ==
  sig: () -> Decoder(process_order.ShipInput)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure ship_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#2, v0, v1)
== fn ship_input_decoder$0/1 origin=lifted(ship_input_decoder, #0) ==
  sig: (String) -> Decoder(process_order.ShipInput)
  v1 = record(ship_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
