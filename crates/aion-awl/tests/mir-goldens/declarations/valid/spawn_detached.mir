  sig: () -> Codec(process_order.ProcessOrderInput)
  v0 = make_closure process_order_input_to_json captures=[]
  v1 = call_local process_order_input_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn process_order_input_to_json/1 origin=codec_template(RecordTrio, ProcessOrderInput, record#2) ==
  sig: (process_order.ProcessOrderInput) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"order_id": v1|>awlc.string_to_json}
  return v2
== fn process_order_input_decoder/0 origin=codec_template(RecordTrio, ProcessOrderInput, record#2) ==
  sig: () -> Decoder(process_order.ProcessOrderInput)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure process_order_input_decoder$0 captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#3, v0, v1)
== fn process_order_input_decoder$0/1 origin=lifted(process_order_input_decoder, #0) ==
  sig: (String) -> Decoder(process_order.ProcessOrderInput)
  v1 = record(process_order_input, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
== fn process_order_outcome_codec/0 origin=codec_template(UnionTrio, ProcessOrderOutcome, union#3) ==
  sig: () -> Codec(process_order.ProcessOrderOutcome)
  v0 = make_closure process_order_outcome_to_json captures=[]
  v1 = call_local process_order_outcome_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
== fn process_order_outcome_to_json/1 origin=codec_template(UnionTrio, ProcessOrderOutcome, union#3) ==
  sig: (process_order.ProcessOrderOutcome) -> Json
  v1 = field(v0, 1)
  v2 = json_obj {"outcome": lit#4|>awlc.string_to_json, "payload": v1|>order_result_to_json}
  return v2
== fn process_order_outcome_decoder/0 origin=codec_template(UnionTrio, ProcessOrderOutcome, union#3) ==
  sig: () -> Decoder(process_order.ProcessOrderOutcome)
  v0 = call_rt aion@awl@codec:string_decoder/0()
  v1 = make_closure process_order_outcome_decoder$outcome captures=[]
  tail_rt gleam@dynamic@decode:field/3(lit#5, v0, v1)
== fn process_order_outcome_decoder$outcome/1 origin=lifted(process_order_outcome_decoder, #0) ==
  sig: (String) -> Decoder(process_order.ProcessOrderOutcome)
  if cmp Eq v0 lit#8:
    v3 = call_local order_result_decoder()
    v4 = make_closure process_order_outcome_decoder$arm0 captures=[]
    tail_rt gleam@dynamic@decode:field/3(lit#9, v3, v4)
  else:
    v1 = record(order_result, [lit#6, 'false'])
    v2 = record(shipped_outcome, [v1])
    tail_rt gleam@dynamic@decode:failure/2(v2, lit#7)
== fn process_order_outcome_decoder$arm0/1 origin=lifted(process_order_outcome_decoder, #1) ==
  sig: (process_order.OrderResult) -> Decoder(process_order.ProcessOrderOutcome)
  v1 = record(shipped_outcome, [v0])
  tail_rt gleam@dynamic@decode:success/1(v1)
