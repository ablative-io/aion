  sig: () -> Codec(Nil)
  v0 = make_closure awl_child_output_nil_to_json captures=[]
  v1 = call_local awl_child_output_nil_decoder() live_after=[v0]
  tail_rt aion@codec:json_codec/2(v0, v1)
