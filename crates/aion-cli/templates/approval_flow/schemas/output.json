{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["request_id", "decision", "decided_by"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string" },
    "decision": { "enum": ["approved", "rejected", "timed_out"] },
    "decided_by": { "type": "string" }
  }
}
