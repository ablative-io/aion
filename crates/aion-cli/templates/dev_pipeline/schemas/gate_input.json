{
  "$comment": "Generated by aion generate from src/{{name}}_io.gleam — do not edit; run `aion generate`.",
  "type": "object",
  "required": ["workspace", "files_touched", "scope"],
  "additionalProperties": false,
  "properties": {
    "workspace": {
      "type": "object",
      "required": ["path", "branch", "placement", "isolation"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "branch": { "type": "string" },
        "placement": { "type": "string", "enum": ["local", "remote"] },
        "isolation": { "type": "string", "enum": ["worktree", "copy", "overlay", "vm"] }
      }
    },
    "files_touched": { "type": "array", "items": { "type": "string" } },
    "scope": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["workspace_wide", "affected_closure"] },
        "modules": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
