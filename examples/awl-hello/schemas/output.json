{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "The awl_hello outcome envelope: which declared workflow outcome fired, with its payload.",
  "type": "object",
  "required": ["outcome", "payload"],
  "properties": {
    "outcome": { "const": "shouted" },
    "payload": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string" }
      }
    }
  }
}
