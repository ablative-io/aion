{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "required": ["order_id", "shipment_id", "carrier"],
      "additionalProperties": false,
      "properties": {
        "order_id": { "type": "string" },
        "shipment_id": { "type": "string" },
        "carrier": { "type": "string" }
      }
    },
    {
      "type": "object",
      "required": ["type", "message"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "shipping_failed" },
        "message": { "type": "string" }
      }
    }
  ]
}
