{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ablative.io/yggdrasil/remediation-flow/verdict.schema.json",
  "title": "Verdict",
  "description": "Stage 3 (adversarial verification) output: per-finding rulings with concrete evidence, plus surviving class siblings which become new ledger entries (DESIGN.md Stage 3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["brief_id", "per_finding", "class_siblings_found"],
  "properties": {
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "per_finding": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "ruling", "evidence"],
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^YG-[0-9]+$"
          },
          "ruling": {
            "type": "string",
            "enum": ["fixed", "partial", "not_fixed", "regression_introduced"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1,
            "description": "What was checked, concretely: files read, scenarios attempted (Gate 3 rejects rulings without this)."
          }
        }
      }
    },
    "class_siblings_found": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line", "description"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 0 },
          "description": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Surviving instances of the same defect class found during class-check — each becomes a NEW ledger entry."
    }
  }
}
