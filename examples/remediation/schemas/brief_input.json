{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "The child remediation_brief workflow input: one brief (brief.schema.json shape), its member ledger entries (agent-facing fields of ledger-entry.schema.json; extra bookkeeping fields are permitted and ignored), and the run configuration.",
  "additionalProperties": true,
  "required": ["brief", "entries", "config"],
  "properties": {
    "brief": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "finding_ids", "root_cause", "scope", "acceptance", "wave", "deep_cluster"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "finding_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "root_cause": { "type": "string" },
        "scope": {
          "type": "object",
          "additionalProperties": true,
          "required": ["files_expected", "boundaries"],
          "properties": {
            "files_expected": { "type": "array", "items": { "type": "string" } },
            "boundaries": { "type": "array", "items": { "type": "string" } }
          }
        },
        "acceptance": { "type": "array", "items": { "type": "string" } },
        "wave": { "type": "integer", "minimum": 0 },
        "deep_cluster": { "type": "boolean" }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "file", "line", "category", "severity", "detail", "failure_scenario", "recommendation"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 0 },
          "category": { "type": "string", "enum": ["correction", "completion", "improvement"] },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "detail": { "type": "string" },
          "failure_scenario": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repo_root", "ledger_path"],
      "properties": {
        "repo_root": { "type": "string", "description": "The repository the fixes land in." },
        "ledger_path": { "type": "string", "description": "The in-repo findings ledger the applier maintains (DECISIONS.md D1)." },
        "base_branch": { "type": "string", "description": "The branch per-brief worktrees are based on; defaults to main." },
        "max_fix_cycles": { "type": "integer", "minimum": 1, "description": "Developer-round budget (initial fix + loop-backs); defaults to 3." }
      }
    }
  }
}
