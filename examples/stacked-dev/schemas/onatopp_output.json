{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "onatopp_dev output",
  "type": "object",
  "required": ["dev_result", "build_warm", "verify_rounds"],
  "additionalProperties": false,
  "properties": {
    "dev_result": {
      "type": "object",
      "required": ["session_id", "files_touched", "summary"],
      "additionalProperties": false,
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "files_touched": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" }
      }
    },
    "build_warm": {
      "type": "object",
      "required": ["ok", "duration_ms"],
      "additionalProperties": false,
      "properties": {
        "ok": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "verify_rounds": { "type": "integer", "minimum": 1 }
  }
}
