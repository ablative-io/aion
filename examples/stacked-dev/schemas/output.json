{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "stacked_dev output",
  "type": "object",
  "required": [
    "pr_url",
    "merge_commit",
    "session_id",
    "build_warm",
    "verify_rounds",
    "review_rounds"
  ],
  "additionalProperties": false,
  "properties": {
    "pr_url": { "type": "string", "minLength": 1 },
    "merge_commit": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "build_warm": {
      "type": "object",
      "required": ["ok", "duration_ms"],
      "additionalProperties": false,
      "properties": {
        "ok": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "verify_rounds": { "type": "integer", "minimum": 1 },
    "review_rounds": { "type": "integer", "minimum": 1 }
  }
}
