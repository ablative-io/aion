{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "stacked_dev input",
  "description": "Every loop cap, backoff, and deadline is required — the caller decides them, the workflow bakes no defaults (open question Q5).",
  "type": "object",
  "required": [
    "repo_root",
    "brief_id",
    "base_ref",
    "placement",
    "isolation",
    "brief",
    "design",
    "checklist",
    "stories",
    "verify_fix_cap",
    "review_cap",
    "round_backoff_ms",
    "review_deadline_ms"
  ],
  "additionalProperties": false,
  "properties": {
    "repo_root": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute path to the repository the worktree is provisioned from."
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "placement": {
      "type": "string",
      "enum": [
        "local",
        "remote"
      ]
    },
    "isolation": {
      "type": "string",
      "enum": [
        "worktree",
        "copy",
        "overlay",
        "vm"
      ]
    },
    "brief": {
      "type": "string",
      "minLength": 1
    },
    "design": {
      "type": "string"
    },
    "checklist": {
      "type": "string"
    },
    "stories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verify_fix_cap": {
      "type": "integer",
      "minimum": 1
    },
    "review_cap": {
      "type": "integer",
      "minimum": 1
    },
    "round_backoff_ms": {
      "type": "integer",
      "minimum": 0
    },
    "review_deadline_ms": {
      "type": "integer",
      "minimum": 0
    }
  }
}
